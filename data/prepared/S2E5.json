[
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:00:17,291 --> 00:00:18,832",
        "text": "Вот и он, друзья."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:00:18,833 --> 00:00:22,332",
        "text": "Чемпион Пилтоверской боксерской лиги в легком весе."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:00:22,333 --> 00:00:25,875",
        "text": "Густов «Хмурый» Челюстник."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:02:46,708 --> 00:02:49,416",
        "text": "Хорошо выглядишь, сестренка."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:02:51,041 --> 00:02:52,333",
        "text": "Подожди, просто..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:02:58,208 --> 00:03:01,708",
        "text": "Я не хочу больше слышать ни слова из твоего рта."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:04,416 --> 00:03:05,249",
        "text": "Это Вандер."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:05,250 --> 00:03:08,583",
        "text": "Я не попадусь на твои уловки."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:10,583 --> 00:03:11,416",
        "text": "Он... жив."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:17,125 --> 00:03:19,791",
        "text": "Мы обе знаем, что это чушь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:38,666 --> 00:03:40,666",
        "text": "Ему нужна наша помощь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:03:41,541 --> 00:03:42,666",
        "text": "Я могу это доказать."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:04:50,541 --> 00:04:53,291",
        "text": "АРКЕЙН Месяцы миротворческой оккупации."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:05:57,791 --> 00:05:59,500",
        "text": "Бесчисленные операции."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:00,125 --> 00:06:02,958",
        "text": "Океаны пота и слез."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:04,791 --> 00:06:08,958",
        "text": "Казалось, что мы наконец-то увидим конец извращенным мерзостям Зауна."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:11,250 --> 00:06:12,666",
        "text": "Как же я была глупа!"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:14,708 --> 00:06:16,083",
        "text": "Зверь пришел за тобой."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:16,916 --> 00:06:18,833",
        "text": "Ты призвал его."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:20,166 --> 00:06:21,749",
        "text": "По моему опыту, только виновные отвечают на обвинения молчанием."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:25,833 --> 00:06:27,665",
        "text": "По моему опыту, никто из власть имущих не бывает невиновным."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:30,416 --> 00:06:32,790",
        "text": "В глубине этой тюрьмы есть камеры, настолько лишенные света, свежего воздуха и всех основных человеческих благ, что до сих пор я запрещала их использовать."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:40,666 --> 00:06:42,207",
        "text": "Если ты не хочешь провести остаток своих дней в одной из них, у тебя только один выход."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:06:57,708 --> 00:07:01,958",
        "text": "Расскажи всё, что нам нужно знать, чтобы выследить зверя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:03,541 --> 00:07:05,333",
        "text": "Твоя молодость подводит тебя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:05,916 --> 00:07:08,290",
        "text": "Терпение присуще возрасту."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:08,291 --> 00:07:11,875",
        "text": "И тем, и другим я обладаю в избытке."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:12,458 --> 00:07:15,457",
        "text": "Это твой последний шанс."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:15,458 --> 00:07:17,416",
        "text": "Скажи мне, что ты планировал."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:18,458 --> 00:07:21,875",
        "text": "Как Джинкс была в этом замешана?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:26,500 --> 00:07:28,416",
        "text": "Ты сгниешь здесь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:07:50,833 --> 00:07:52,166",
        "text": "Элора?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:08:02,166 --> 00:08:04,541",
        "text": "Черная Роза."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:06,833 --> 00:09:09,624",
        "text": "Надеюсь, тебе понравятся эти места."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:09,625 --> 00:09:13,041",
        "text": "На мои просьбы о переводе они так и не ответили."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:13,583 --> 00:09:14,458",
        "text": "Кто это?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:15,958 --> 00:09:18,165",
        "text": "Не уверен, что вообще знаю."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:18,166 --> 00:09:22,333",
        "text": "Наши хозяева умеют всё перевернуть с ног на голову."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:26,291 --> 00:09:27,708",
        "text": "Они убили мою подругу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:29,291 --> 00:09:30,291",
        "text": "Элора была там."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:31,166 --> 00:09:32,083",
        "text": "А потом..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:33,583 --> 00:09:35,666",
        "text": "Элора."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:38,958 --> 00:09:40,665",
        "text": "Хранители старого мира всегда рады показать свое могущество."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:46,375 --> 00:09:47,708",
        "text": "Что это за место?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:49,708 --> 00:09:51,000",
        "text": "Насколько я могу судить, Окулорум."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:09:53,208 --> 00:09:54,874",
        "text": "Согласно легенде, древние строили специальные камеры, чтобы запереть лжепророков."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:01,208 --> 00:10:03,540",
        "text": "Но, как по мне, это просто причудливые ямы, в которые принцы-павлины любят бросать своих друзей."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:07,458 --> 00:10:08,666",
        "text": "Принцы-павлины?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:09,625 --> 00:10:12,624",
        "text": "Простите, это старая семейная шутка."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:12,625 --> 00:10:16,707",
        "text": "Знаете, такие правители с творческим началом."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:16,708 --> 00:10:18,166",
        "text": "Выйди на свет."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:31,250 --> 00:10:32,666",
        "text": "Кино?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:45,583 --> 00:10:46,916",
        "text": "Это я, брат."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:47,541 --> 00:10:48,458",
        "text": "Мэл."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:49,875 --> 00:10:50,708",
        "text": "Мэл."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:52,583 --> 00:10:53,708",
        "text": "Ты выросла."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:10:55,208 --> 00:10:57,208",
        "text": "Я надеялся, что они не доберутся до тебя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:11:47,791 --> 00:11:50,333",
        "text": "Здесь я его потеряла."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:14,625 --> 00:12:15,457",
        "text": "Круто, да?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:15,458 --> 00:12:17,291",
        "text": "Даже не токсично."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:20,458 --> 00:12:21,291",
        "text": "Почти уверена."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:30,208 --> 00:12:32,749",
        "text": "С чего бы Вандеру быть здесь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:32,750 --> 00:12:34,290",
        "text": "Не знаю."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:34,291 --> 00:12:35,625",
        "text": "Спроси его сама."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:37,291 --> 00:12:40,791",
        "text": "Когда ты уже признаешь, что это лишь одна из твоих фантазий?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:41,375 --> 00:12:44,249",
        "text": "Или не хочешь, чтобы ребенок знал, какой бред ты несешь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:44,250 --> 00:12:46,249",
        "text": "Она не всегда была такой."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:46,250 --> 00:12:50,500",
        "text": "Вообще-то она была довольно крутой, пока я не надрала ей задницу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:51,416 --> 00:12:52,665",
        "text": "Понимаешь, о чём я?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:52,666 --> 00:12:53,875",
        "text": "Бред."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:12:57,333 --> 00:12:59,582",
        "text": "Хотелось бы, чтобы мне привиделось, что ты решила объединиться с головорезами, убившими маму и папу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:02,750 --> 00:13:06,207",
        "text": "По крайней мере, они не увидели, в какую психопатку превратилась дочь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:06,208 --> 00:13:07,291",
        "text": "В кого?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:08,416 --> 00:13:09,790",
        "text": "Проснись, сестренка."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:09,791 --> 00:13:10,999",
        "text": "Я герой."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:11,000 --> 00:13:13,415",
        "text": "Я вышибла половину Зауна из Тихого омута, пока ты валялась в отключке на дне стакана."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:16,333 --> 00:13:19,833",
        "text": "А теперь хватит. Иди дальше, пока я снова не надрала тебе зад."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:20,958 --> 00:13:22,874",
        "text": "Ты не продержишься и секунды без всех своих уродливых приспособлений и трусливых трюков."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:26,875 --> 00:13:29,457",
        "text": "А как насчет этих переделанных гребаных перчаток, которые ты даже не сама создала?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:36,500 --> 00:13:38,250",
        "text": "Думаешь, они мне нужны, чтобы..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:41,833 --> 00:13:44,333",
        "text": "Вот. Секунда."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:51,083 --> 00:13:52,957",
        "text": "Последний шанс сдаться."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:13:52,958 --> 00:13:55,125",
        "text": "Вперед, жирные руки."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:16,250 --> 00:14:17,208",
        "text": "Эй, мелочь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:17,958 --> 00:14:19,583",
        "text": "Внутренности на месте?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:45,583 --> 00:14:47,416",
        "text": "Только не бросай нас."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:48,958 --> 00:14:50,291",
        "text": "Почему ты пришла за мной?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:52,583 --> 00:14:54,500",
        "text": "Вообще-то тебе не нужна моя помощь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:14:55,458 --> 00:14:57,041",
        "text": "Уже давно не нужна."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:00,291 --> 00:15:03,040",
        "text": "Когда Вандер нуждался в нас ранее, мы действовали в одиночку и ничего не получилось."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:08,375 --> 00:15:09,208",
        "text": "Так что... ...может быть, это новый шанс."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:14,583 --> 00:15:15,791",
        "text": "Кроме того, он и твой отец тоже."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:37,083 --> 00:15:38,833",
        "text": "Я ждал тебя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:39,500 --> 00:15:41,415",
        "text": "Уверен в себе, не так ли?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:41,416 --> 00:15:43,332",
        "text": "Взгляд всегда один и тот же."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:43,333 --> 00:15:45,166",
        "text": "Когда человек жаждет оружия."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:46,458 --> 00:15:49,791",
        "text": "Я сражалась в битвах от Кровавых утесов до равнины Далмора."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:50,375 --> 00:15:52,750",
        "text": "Я никогда не видела столь дикого зверя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:53,458 --> 00:15:56,166",
        "text": "Нет зверя более дикого, чем человек."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:15:57,750 --> 00:15:59,625",
        "text": "Полагаю, у тебя есть предложение."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:05,625 --> 00:16:06,791",
        "text": "Ты будешь служить мне."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:07,666 --> 00:16:09,457",
        "text": "Мои враги станут твоими."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:09,458 --> 00:16:11,499",
        "text": "Твое оружие будет моим."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:11,500 --> 00:16:14,707",
        "text": "Взамен я удовлетворю все твои потребности."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:14,708 --> 00:16:17,457",
        "text": "К тебе будут относиться как к уважаемому советнику."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:17,458 --> 00:16:20,166",
        "text": "Но я требую абсолютной преданности."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:27,541 --> 00:16:29,332",
        "text": "Не испытывай это, иначе будешь тосковать по подземельям Кейтлин."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:34,083 --> 00:16:36,375",
        "text": "Ты уже знаешь, чего я хочу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:37,291 --> 00:16:38,999",
        "text": "Он не чудовище."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:39,000 --> 00:16:40,707",
        "text": "Когда-то он был человеком."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:40,708 --> 00:16:42,583",
        "text": "И очень уважаемым."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:44,375 --> 00:16:46,333",
        "text": "Жертва великой трагедии."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:54,291 --> 00:16:56,291",
        "text": "У него была свирепая воля к жизни."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:16:57,208 --> 00:16:59,208",
        "text": "Невероятная стойкость к боли."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:01,083 --> 00:17:02,000",
        "text": "С ним я добился успехов, невозможных ни с одним другим существом."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:08,708 --> 00:17:09,833",
        "text": "Но разум..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:10,875 --> 00:17:12,791",
        "text": "Разум я не смог восстановить."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:15,791 --> 00:17:18,583",
        "text": "Человек, навсегда затерявшийся внутри зверя, которого влечет лишь запах крови."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:29,750 --> 00:17:30,916",
        "text": "Так я думал."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:33,083 --> 00:17:36,416",
        "text": "Теперь кажется, что мне еще предстоит найти подходящий катализатор."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:17:44,958 --> 00:17:46,833",
        "text": "Пузыри и камни."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:04,500 --> 00:18:06,791",
        "text": "В Ноксусе состоялись твои похороны."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:08,416 --> 00:18:10,291",
        "text": "Мама заказала статую?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:12,166 --> 00:18:14,249",
        "text": "Я провела обряд в Пилтовере."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:14,250 --> 00:18:15,875",
        "text": "Она считает, что ты умер."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:16,416 --> 00:18:18,958",
        "text": "Мне нравится ее разочаровывать."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:33,833 --> 00:18:35,708",
        "text": "Как ты догадалась это сделать?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:36,541 --> 00:18:37,500",
        "text": "Не знаю."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:38,375 --> 00:18:39,625",
        "text": "Я просто почувствовала..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:40,541 --> 00:18:42,375",
        "text": "Это похоже на какую-то головоломку."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:48,041 --> 00:18:49,749",
        "text": "Кино, что с тобой случилось?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:49,750 --> 00:18:51,333",
        "text": "Как ты здесь оказался?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:51,916 --> 00:18:53,166",
        "text": "Она тебе не сказала."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:18:57,916 --> 00:19:02,874",
        "text": "После нескольких встреч с сомнительными дворянами в Базилике до меня стали доходить странные слухи о матушке."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:06,375 --> 00:19:08,415",
        "text": "Не такие, как обычно."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:08,416 --> 00:19:10,999",
        "text": "Говорят, много лет назад она проезжала через их родной город и... ...влюбилась."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:17,625 --> 00:19:18,958",
        "text": "Это не наша мать."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:19,500 --> 00:19:20,540",
        "text": "Действительно."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:20,541 --> 00:19:24,125",
        "text": "Но чем больше я расспрашивал, тем больше начинал в это верить."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:25,333 --> 00:19:26,457",
        "text": "Старые путевые журналы."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:26,458 --> 00:19:28,250",
        "text": "Местные рассказы."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:30,333 --> 00:19:32,041",
        "text": "Мне следовало бы оставить всё, но..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:34,166 --> 00:19:36,125",
        "text": "В результате этой связи появился ребенок."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:40,708 --> 00:19:41,916",
        "text": "Это невозможно."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:44,250 --> 00:19:46,541",
        "text": "Это причина, по которой мы здесь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:19:47,375 --> 00:19:48,333",
        "text": "Проще говоря, всё, что унаследовал этот ребенок, представляет интерес для похитителей."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:10,166 --> 00:20:12,583",
        "text": "Это позволит определить местонахождение твоего зверя?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:13,166 --> 00:20:15,208",
        "text": "Не в точности."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:22,833 --> 00:20:24,832",
        "text": "Мои семейные архивы пролили свет на многие загадки этого города."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:28,041 --> 00:20:29,291",
        "text": "Командир."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:29,875 --> 00:20:31,000",
        "text": "Генерал."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:32,791 --> 00:20:35,458",
        "text": "Одна из таких загадок привлекла мое внимание."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:36,750 --> 00:20:40,333",
        "text": "Любопытное увольнение уважаемого в академии алхимика."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:41,625 --> 00:20:44,125",
        "text": "Беспрецедентное, по общему мнению."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:45,375 --> 00:20:47,750",
        "text": "И никаких упоминаний о его преступлении."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:20:58,166 --> 00:21:00,374",
        "text": "Отсюда возник еще один кусочек головоломки, отсутствие которого всегда терзало меня."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:04,208 --> 00:21:05,583",
        "text": "Кто изобрел Мерцание?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:07,500 --> 00:21:11,291",
        "text": "Теперь у нас есть ответ, не так ли, доктор Ревек?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:15,708 --> 00:21:17,500",
        "text": "Вы – чудовище."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:21,166 --> 00:21:22,291",
        "text": "Зачем?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:22,875 --> 00:21:24,458",
        "text": "Зачем всё это?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:33,208 --> 00:21:36,958",
        "text": "Почему кто-то совершает поступки, которые другие считают ужасными?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:21:41,500 --> 00:21:42,583",
        "text": "Ради любви."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:22,000 --> 00:22:23,124",
        "text": "Возможно, в другой жизни... ...вы бы подружились."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:29,750 --> 00:22:32,708",
        "text": "Всё, что я делал, было для того, чтобы вылечить ее."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:37,708 --> 00:22:40,458",
        "text": "Я верю, что зверь может быть решающим звеном."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:41,666 --> 00:22:44,416",
        "text": "Что именно вы пытаетесь вылечить?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:47,333 --> 00:22:49,250",
        "text": "Недуг, от которого мы все пострадаем."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:52,708 --> 00:22:53,541",
        "text": "Смерть."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:22:54,625 --> 00:22:57,583",
        "text": "Представьте себе мир, в котором больше не нужно ее бояться."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:02,166 --> 00:23:04,166",
        "text": "Мэл? Я вытащу нас отсюда."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:24,750 --> 00:23:28,124",
        "text": "Допустим, это какой-то скверный лабиринт."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:28,125 --> 00:23:32,165",
        "text": "Обычно для тех, кто не проходит испытания, есть последствия."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:32,166 --> 00:23:33,749",
        "text": "Смертельные последствия."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:33,750 --> 00:23:35,541",
        "text": "Я заслуживаю знать правду."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:36,166 --> 00:23:37,582",
        "text": "Конечно."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:37,583 --> 00:23:40,207",
        "text": "Тебя мучает вопрос, почему она скрывала это от тебя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:40,208 --> 00:23:41,916",
        "text": "Столько лет."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:43,541 --> 00:23:44,875",
        "text": "Мне чего-то не хватает."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:23:47,041 --> 00:23:49,708",
        "text": "Здорового чувства самосохранения, я бы сказал."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:02,666 --> 00:24:04,208",
        "text": "Ты не мой брат."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:12,208 --> 00:24:14,583",
        "text": "Кто ты? Что ты сделал с Кино?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:38,500 --> 00:24:41,416",
        "text": "Мы возлагали на него большие надежды."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:42,000 --> 00:24:46,250",
        "text": "Сначала казалось убедительным, что он мог быть ребенком."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:47,291 --> 00:24:48,666",
        "text": "Но потом твоя мать... ...привела нас к тебе."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:24:52,000 --> 00:24:53,000",
        "text": "Сестра."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:39,541 --> 00:26:40,375",
        "text": "Что это?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:41,375 --> 00:26:42,708",
        "text": "Послание от Вандера."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:44,083 --> 00:26:45,083",
        "text": "Для Силко."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:51,416 --> 00:26:54,957",
        "text": "«Силко, я искал везде, но...» Я искал везде, но..."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:54,958 --> 00:26:57,166",
        "text": "Очевидно, что ты не хочешь, чтобы тебя нашли."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:26:58,291 --> 00:27:00,165",
        "text": "Боже, я в этом полный профан."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:00,166 --> 00:27:01,416",
        "text": "Прости."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:01,958 --> 00:27:04,999",
        "text": "Когда она умерла, я потерял голову."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:05,000 --> 00:27:08,249",
        "text": "Я говорил себе, что то, что я сделал с тобой, было во благо, что ты это заслужил."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:10,333 --> 00:27:12,583",
        "text": "Но грязь была на наших руках."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:13,625 --> 00:27:16,083",
        "text": "В любом случае, ты знаешь, где меня найти."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:16,708 --> 00:27:17,958",
        "text": "Пузыри и камни."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:19,083 --> 00:27:20,125",
        "text": "В."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:27:21,791 --> 00:27:23,166",
        "text": "Если бы он нашел это, всё могло быть иначе."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:33,250 --> 00:28:34,583",
        "text": "Нужно убираться отсюда."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:35,166 --> 00:28:36,707",
        "text": "Это он. Это Вандер."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:36,708 --> 00:28:38,832",
        "text": "Это не Вандер. Это он."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:38,833 --> 00:28:41,375",
        "text": "Что-то его взбесило."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:41,958 --> 00:28:44,249",
        "text": "Нет, Вандер, нет."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:28:44,250 --> 00:28:45,833",
        "text": "Это я."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:29:02,458 --> 00:29:03,708",
        "text": "Он убьет тебя."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:29:04,291 --> 00:29:05,291",
        "text": "Не трогай его."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:29:35,166 --> 00:29:36,250",
        "text": "Слушай!"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:29:58,625 --> 00:30:00,540",
        "text": "Вай, это он."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:30:00,541 --> 00:30:02,666",
        "text": "Ты должна мне поверить."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:30:23,750 --> 00:30:24,666",
        "text": "Вандер."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:30:28,916 --> 00:30:30,333",
        "text": "Что за повод?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:30:31,375 --> 00:30:34,458",
        "text": "Разве леди не может быть в настроении для хорошей песни?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:30:35,916 --> 00:30:38,750",
        "text": "Не та леди и не та песня."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:01,833 --> 00:31:05,665",
        "text": "Сегодня придуманный этими двумя тупицами план превращения промозглой трещины в земле в процветающее, здоровое сообщество стал реальностью."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:12,541 --> 00:31:13,916",
        "text": "Сегодня?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:14,500 --> 00:31:16,291",
        "text": "Слышишь, тупица номер два?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:16,833 --> 00:31:18,958",
        "text": "Мы сделали это. Мы закончили."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:19,708 --> 00:31:21,541",
        "text": "Ты жестоко ошибаешься."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:22,083 --> 00:31:23,457",
        "text": "Я – тупица номер один."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:23,458 --> 00:31:26,083",
        "text": "Ночь откровений."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:30,458 --> 00:31:31,458",
        "text": "Я залетела."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:43,916 --> 00:31:46,041",
        "text": "Девочка. Откуда ты знаешь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:47,833 --> 00:31:49,415",
        "text": "Это не входило в мои планы, но, наверное, так бывает, когда живешь от недели к неделе."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:53,416 --> 00:31:54,500",
        "text": "Что сказал Коннол?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:55,041 --> 00:31:56,166",
        "text": "Я ему не говорила."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:31:56,875 --> 00:31:58,166",
        "text": "Набираюсь смелости."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:02,041 --> 00:32:03,832",
        "text": "Я ничего не знаю о детях."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:03,833 --> 00:32:06,374",
        "text": "Меня бросает в пот, когда я остаюсь наедине с ними."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:06,375 --> 00:32:09,415",
        "text": "Эй, ты будешь отличной матерью."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:09,416 --> 00:32:10,582",
        "text": "Заткнись."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:10,583 --> 00:32:12,333",
        "text": "Я к этому не готова."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:12,916 --> 00:32:18,499",
        "text": "Я начала придумывать имя, и меня осенило, что одно это слово – это решение, с которым ей придется жить всю жизнь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:24,375 --> 00:32:27,082",
        "text": "Я не могу защитить ее от всего этого дерьма и одновременно научиться быть родителем."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:31,875 --> 00:32:34,040",
        "text": "Потом я поняла, что мне и не нужно."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:36,333 --> 00:32:37,249",
        "text": "Почему?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:37,250 --> 00:32:40,416",
        "text": "Потому что, как только я вам сказала, то сразу взяла вас на крючок."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:41,458 --> 00:32:43,666",
        "text": "Вы двое разберетесь с этим Зауном."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:44,333 --> 00:32:48,083",
        "text": "Даже если вам придется вырезать его из камня, покрытого пузырями."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:48,625 --> 00:32:50,375",
        "text": "Вы не можете потерпеть неудачу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:50,916 --> 00:32:51,833",
        "text": "Ради нее."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:53,083 --> 00:32:53,916",
        "text": "Ради меня."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:32:55,833 --> 00:32:58,833",
        "text": "Что толку, если мы не можем вырастить пару спиногрызов?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:33:01,333 --> 00:33:02,583",
        "text": "Тогда за Заун."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:33:03,500 --> 00:33:07,416",
        "text": "Пузыри и камни."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:33:13,791 --> 00:33:15,791",
        "text": "Мне всегда нравилось имя Вайолет."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:34:15,458 --> 00:34:16,958",
        "text": "Чего ты ждешь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:34:19,208 --> 00:34:20,708",
        "text": "Он и твой отец."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:07,500 --> 00:36:08,708",
        "text": "Сейло?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:09,666 --> 00:36:11,083",
        "text": "Что ты здесь делаешь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:11,791 --> 00:36:12,916",
        "text": "Джейс."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:13,833 --> 00:36:15,750",
        "text": "Могу задать тот же вопрос."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:20,291 --> 00:36:21,666",
        "text": "Как ты передвигаешься?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:24,500 --> 00:36:27,500",
        "text": "Как думаешь, кто может починить такое сломанное существо?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:28,041 --> 00:36:30,000",
        "text": "Хочешь поговорить с ним?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:35,666 --> 00:36:36,708",
        "text": "Джейс."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:37,291 --> 00:36:40,915",
        "text": "Я боялся, что у меня не будет возможности поговорить с тобой снова."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:40,916 --> 00:36:42,166",
        "text": "Виктор?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:44,958 --> 00:36:47,458",
        "text": "Я бы предпочел пообщаться лично."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:48,750 --> 00:36:50,875",
        "text": "Но у нас так много работы."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:52,750 --> 00:36:54,125",
        "text": "Как ты это делаешь?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:36:55,791 --> 00:36:59,250",
        "text": "Это несколько выходит за рамки того, на чем мы остановились."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:01,291 --> 00:37:02,833",
        "text": "Сейло всё еще там?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:04,791 --> 00:37:06,374",
        "text": "Где еще я могу быть?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:06,375 --> 00:37:07,832",
        "text": "Торжественно клянусь, что всё, что вы обсудите, будет храниться в строжайшей тайне."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:11,458 --> 00:37:12,916",
        "text": "Я обязан Виктору... ...всем."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:16,375 --> 00:37:18,125",
        "text": "Очень любезно, Сейло."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:20,291 --> 00:37:24,750",
        "text": "У меня так много открытий, которыми я хочу поделиться с тобой."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:25,333 --> 00:37:27,541",
        "text": "Я думал, ты покончил с хекстеком."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:29,125 --> 00:37:30,333",
        "text": "И со мной."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:31,500 --> 00:37:33,583",
        "text": "Я был затуманен эмоциями."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:35,208 --> 00:37:37,665",
        "text": "Приходи. Навести меня."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:37,666 --> 00:37:39,375",
        "text": "Посмотри, чего я добился."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:40,083 --> 00:37:41,666",
        "text": "Я помог многим."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:55,625 --> 00:37:57,708",
        "text": "Ты отдал хекстек людям?"
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:37:58,958 --> 00:38:01,833",
        "text": "Как мы всегда обещали."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:03,250 --> 00:38:05,791",
        "text": "Виктор действительно творит чудеса."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:06,833 --> 00:38:08,707",
        "text": "Хекстек – это не чудо."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:08,708 --> 00:38:10,040",
        "text": "Это проклятие."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:10,041 --> 00:38:12,000",
        "text": "Мы должны положить этому конец, Виктор."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:13,083 --> 00:38:14,208",
        "text": "Мы должны."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:16,083 --> 00:38:17,541",
        "text": "Ты кажешься другим."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:18,333 --> 00:38:19,458",
        "text": "Что-то случилось."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:23,166 --> 00:38:24,875",
        "text": "Теперь я это вижу."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:25,666 --> 00:38:28,166",
        "text": "Ты тоже прикоснулся к Аркейну."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:29,916 --> 00:38:31,750",
        "text": "Твой разум пострадал."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:40,458 --> 00:38:42,083",
        "text": "Прошу меня извинить, я должен вернуться к нему."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:49,666 --> 00:38:50,999",
        "text": "Не могу позволить тебе уйти."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:51,000 --> 00:38:53,499",
        "text": "Мне жаль, что ты так считаешь."
    },
    {
        "season": 2,
        "episode": 5,
        "time_code": "00:38:53,500 --> 00:38:54,666",
        "text": "Мне тоже жаль."
    }
]