[
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:00:39,833 --> 00:00:40,666",
        "text": "Мэл."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:00:47,000 --> 00:00:49,708",
        "text": "Мэл, ты как?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:01:07,875 --> 00:01:08,708",
        "text": "Всё хорошо."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:01:35,791 --> 00:01:36,625",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:01:41,875 --> 00:01:43,875",
        "text": "Ты ранена? Я в порядке."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:01:48,291 --> 00:01:49,833",
        "text": "Идите, идите."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:03:46,041 --> 00:03:48,875",
        "text": "Аркейн Она была великой женщиной."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:05:55,750 --> 00:05:57,250",
        "text": "Хорошей подругой."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:05:58,458 --> 00:06:01,458",
        "text": "Я не знаю, как мы справимся с этим кризисом без нее."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:10,000 --> 00:06:13,083",
        "text": "Подумать только, мы чуть не предоставили суверенитет существам, которые сделали это."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:17,333 --> 00:06:19,291",
        "text": "Мы призваны поддерживать порядок."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:20,458 --> 00:06:22,541",
        "text": "А мы уснули на посту."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:23,083 --> 00:06:24,458",
        "text": "Теперь мои глаза открыты."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:25,000 --> 00:06:30,083",
        "text": "Больше никаких сказок о мире, пока мы не очистим подполье от демонов."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:30,958 --> 00:06:34,000",
        "text": "Очень любезно с твоей стороны помочь советнику Сейло, мама."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:34,583 --> 00:06:36,082",
        "text": "Поскольку идет война, я счел разумным обратиться за советом к столь опытному ветерану."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:41,125 --> 00:06:43,707",
        "text": "Давайте рассмотрим суть вопроса."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:43,708 --> 00:06:46,165",
        "text": "Наши люди напуганы, страдают."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:46,166 --> 00:06:49,582",
        "text": "Они должны знать, что их правители контролируют ситуацию."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:49,583 --> 00:06:51,665",
        "text": "Беспрецедентная демонстрация силы."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:51,666 --> 00:06:56,124",
        "text": "Наводним подземный город миротворцами, вооруженными хекстеками."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:56,125 --> 00:06:58,665",
        "text": "Под перекрестным огнем окажутся невинные."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:06:58,666 --> 00:07:02,082",
        "text": "Сколько еще советников должно погибнуть, прежде чем ты очнешься?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:02,083 --> 00:07:03,333",
        "text": "Мы в осаде."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:07,958 --> 00:07:09,333",
        "text": "Что она здесь делает?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:09,875 --> 00:07:12,290",
        "text": "Офицер Кирамман была свидетелем нападения."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:12,291 --> 00:07:15,708",
        "text": "Она подтвердила, это был поступок одного сумасшедшего."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:16,291 --> 00:07:17,249",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:17,250 --> 00:07:18,374",
        "text": "Силко мертв."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:18,375 --> 00:07:20,457",
        "text": "Подполье, лишенное лидера."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:20,458 --> 00:07:23,582",
        "text": "Если последуем твоему плану, мы рискуем объединить их против нас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:23,583 --> 00:07:25,207",
        "text": "Каково твое предложение?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:25,208 --> 00:07:26,125",
        "text": "Наказание?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:26,666 --> 00:07:27,874",
        "text": "Строгий выговор?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:27,875 --> 00:07:30,040",
        "text": "Мы используем их раскол против них самих."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:30,041 --> 00:07:31,624",
        "text": "Свалим нападение на Джинкс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:31,625 --> 00:07:34,374",
        "text": "Назначим награду. Слишком значительную, чтобы игнорировать."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:34,375 --> 00:07:35,374",
        "text": "Извини, Мэл."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:35,375 --> 00:07:38,499",
        "text": "Мне не хочется доверять наши судьбы воле случая."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:38,500 --> 00:07:40,124",
        "text": "Джинкс оказалась неуловимой."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:40,125 --> 00:07:43,833",
        "text": "Мы восстановимся лишь после того, как она предстанет перед судом."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:48,208 --> 00:07:51,625",
        "text": "Тогда всё решено, двое против одного."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:52,291 --> 00:07:53,375",
        "text": "Мы вторгнемся."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:57,541 --> 00:07:58,957",
        "text": "Можно сказать?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:07:58,958 --> 00:08:00,499",
        "text": "В подобных кризисах крайне важно демонстрировать общественности единую позицию, независимо от личных чувств."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:09,000 --> 00:08:10,125",
        "text": "Очень мудро."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:12,375 --> 00:08:14,208",
        "text": "Я поддержу вторжение."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:16,250 --> 00:08:18,500",
        "text": "Но не поддержу хекстеки."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:19,500 --> 00:08:21,165",
        "text": "У нас есть устав."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:21,166 --> 00:08:24,166",
        "text": "Такая сила должна стать последним средством."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:25,708 --> 00:08:26,875",
        "text": "Согласна."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:08:28,791 --> 00:08:31,708",
        "text": "Тогда всё решено, двое против одного."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:09:45,125 --> 00:09:46,916",
        "text": "У меня был шанс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:00,791 --> 00:10:03,166",
        "text": "Твоя мать оставила это тебе."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:04,916 --> 00:10:06,083",
        "text": "Ключ Кирамманов?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:06,666 --> 00:10:08,083",
        "text": "Нет, я не..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:09,041 --> 00:10:10,415",
        "text": "Я этого не заслуживаю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:10,416 --> 00:10:13,125",
        "text": "Теперь это твое наследие, Кейтлин."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:29,125 --> 00:10:31,041",
        "text": "Почему она до сих пор здесь?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:10:55,541 --> 00:10:56,375",
        "text": "Привет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:19,708 --> 00:11:20,958",
        "text": "Ты была права, Кейт."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:21,500 --> 00:11:22,916",
        "text": "Паудер исчезла."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:24,541 --> 00:11:25,915",
        "text": "Я могу всё исправить."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:25,916 --> 00:11:29,790",
        "text": "Если попросишь Джейса починить перчатки, я сделаю всё сама."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:29,791 --> 00:11:31,666",
        "text": "Никто больше не пострадает."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:32,208 --> 00:11:33,124",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:33,125 --> 00:11:34,749",
        "text": "Больше никаких нелегальных миссий."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:34,750 --> 00:11:36,874",
        "text": "Никаких безрассудных планов."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:36,875 --> 00:11:38,249",
        "text": "Моя мама была права."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:38,250 --> 00:11:40,874",
        "text": "Из-за самоуверенности я взяла на себя больше, чем могла."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:40,875 --> 00:11:42,500",
        "text": "И она заплатила за это."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:46,583 --> 00:11:48,833",
        "text": "Они отправят миротворцев найти Джинкс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:50,000 --> 00:11:51,375",
        "text": "Я пойду с ними."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:51,958 --> 00:11:54,125",
        "text": "Пожалуйста, я должна помочь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:11:54,750 --> 00:11:55,583",
        "text": "Ты можешь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:04,083 --> 00:12:05,000",
        "text": "Как одна из нас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:05,833 --> 00:12:08,332",
        "text": "Кейт, я не могу это надеть."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:08,333 --> 00:12:09,791",
        "text": "Люди жаждут крови."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:10,500 --> 00:12:11,915",
        "text": "Совет не остановит их."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:11,916 --> 00:12:14,958",
        "text": "Ты можешь показать, что не весь Заун поддерживает Джинкс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:15,958 --> 00:12:17,000",
        "text": "Мы покажем им."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:18,041 --> 00:12:18,958",
        "text": "Вместе."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:19,541 --> 00:12:21,290",
        "text": "Я видела, как они убили родителей."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:21,291 --> 00:12:23,540",
        "text": "Ты хоть представляешь, каково это?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:23,541 --> 00:12:24,457",
        "text": "Да."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:24,458 --> 00:12:25,541",
        "text": "Представляю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:30,375 --> 00:12:32,291",
        "text": "Я думала, ты на нашей стороне."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:12:33,375 --> 00:12:34,791",
        "text": "Ты вообще не думала."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:13:10,000 --> 00:13:11,791",
        "text": "Осторожно."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:13:13,916 --> 00:13:14,833",
        "text": "Извините."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:13:18,416 --> 00:13:19,666",
        "text": "Не впервой."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:13:25,166 --> 00:13:26,333",
        "text": "Ты в порядке?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:13:41,583 --> 00:13:42,665",
        "text": "Ты... потеряла кого-то во время нападения?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:13,291 --> 00:14:14,375",
        "text": "Как он?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:14,958 --> 00:14:16,916",
        "text": "Как и раньше. Дышит."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:18,125 --> 00:14:19,583",
        "text": "Пульс стабильный."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:20,541 --> 00:14:21,625",
        "text": "В остальном ваши прогнозы не хуже моих."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:40,416 --> 00:14:41,958",
        "text": "Что с ним происходит?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:44,708 --> 00:14:46,915",
        "text": "Развивается хекстековое ядро."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:46,916 --> 00:14:50,165",
        "text": "Рунические узоры меняются быстрее, чем я успеваю за ними."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:50,166 --> 00:14:52,791",
        "text": "Я уверен лишь в том, что это поддерживает его жизнь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:14:54,583 --> 00:14:57,458",
        "text": "Такая загадка понравилась бы Виктору, если бы он..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:01,791 --> 00:15:04,166",
        "text": "Вместо него там должен быть я."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:05,208 --> 00:15:06,458",
        "text": "Не говори так."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:07,500 --> 00:15:09,332",
        "text": "Он вернется к нам."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:09,333 --> 00:15:11,832",
        "text": "Я всё еще не понимаю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:11,833 --> 00:15:13,332",
        "text": "Он был рядом со мной."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:13,333 --> 00:15:16,665",
        "text": "Как взрыв мог сделать с ним такое, а я..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:16,666 --> 00:15:18,708",
        "text": "Я выбрался без единой царапины."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:23,833 --> 00:15:26,208",
        "text": "В таких вещах нет смысла, Джейс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:28,333 --> 00:15:29,666",
        "text": "Как Совет?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:31,083 --> 00:15:32,458",
        "text": "Мама вступила в игру."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:34,541 --> 00:15:36,874",
        "text": "Она уже вцепилась в Сейло."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:36,875 --> 00:15:39,833",
        "text": "Использует горе, чтобы получить хекстек."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:41,208 --> 00:15:43,499",
        "text": "Мэл, я обещал Виктору."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:43,500 --> 00:15:44,791",
        "text": "Больше никогда."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:45,375 --> 00:15:46,374",
        "text": "Всё хорошо."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:46,375 --> 00:15:47,415",
        "text": "Я разобралась с этим."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:47,416 --> 00:15:49,833",
        "text": "Я не позволю им испортить твою мечту."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:55,750 --> 00:15:56,833",
        "text": "Кейтлин была там."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:57,416 --> 00:15:58,957",
        "text": "Ты можешь навестить ее."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:15:58,958 --> 00:16:02,666",
        "text": "Она прекрасно это скрывает, но бедной девочке очень больно."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:16:53,458 --> 00:16:54,458",
        "text": "Привет, Тростинка."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:16:59,375 --> 00:17:00,624",
        "text": "Как ты меня нашел?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:00,625 --> 00:17:01,541",
        "text": "Твой отец."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:03,958 --> 00:17:06,958",
        "text": "Мы с мамой приходили сюда, когда нужно было сбежать."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:08,500 --> 00:17:10,750",
        "text": "Одно из немногих мест, где мы не ссорились."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:11,333 --> 00:17:13,416",
        "text": "Прости, что меня не было рядом."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:15,375 --> 00:17:16,458",
        "text": "Как Виктор?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:20,041 --> 00:17:22,250",
        "text": "Я даже не уверен, что он всё еще там."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:23,541 --> 00:17:25,041",
        "text": "С тех пор, как это случилось... в моей голове постоянно мелькают три лица."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:32,500 --> 00:17:33,375",
        "text": "Я вижу маму."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:34,458 --> 00:17:35,583",
        "text": "Когда они нашли ее."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:36,375 --> 00:17:38,832",
        "text": "И все мои мысли тонут, как камень в темной воде."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:42,291 --> 00:17:44,083",
        "text": "Но есть еще и Джинкс."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:44,833 --> 00:17:45,708",
        "text": "Она смеется."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:46,958 --> 00:17:49,707",
        "text": "Я хочу навсегда вырвать этот смех из ее глотки."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:49,708 --> 00:17:50,625",
        "text": "Кейт."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:51,291 --> 00:17:52,124",
        "text": "Я знаю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:52,125 --> 00:17:53,874",
        "text": "Теперь я понимаю, как легко их ненавидеть."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:17:56,000 --> 00:17:57,791",
        "text": "Один порочный поступок."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:00,833 --> 00:18:02,250",
        "text": "Потом я вижу Вай."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:04,291 --> 00:18:06,332",
        "text": "Я попросила ее надеть форму."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:06,333 --> 00:18:08,791",
        "text": "Стоит сказать, что она отказалась."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:09,375 --> 00:18:11,375",
        "text": "Вай? Со значком?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:11,958 --> 00:18:15,666",
        "text": "Она думает, что эти твои перчатки решат все ее проблемы."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:18,000 --> 00:18:19,416",
        "text": "Что, если она права?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:20,916 --> 00:18:23,082",
        "text": "Хекстек может сохранить жизнь, Джейс, но это не спасет нас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:33,916 --> 00:18:34,750",
        "text": "Чтобы я присоединилась к ореховому патрулю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:38,291 --> 00:18:40,541",
        "text": "А я-то думала, что у нее нет чувства юмора."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:42,291 --> 00:18:43,540",
        "text": "Я люблю орехи."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:43,541 --> 00:18:44,790",
        "text": "Ее отец прав."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:44,791 --> 00:18:47,041",
        "text": "Нет смысла оставаться здесь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:49,875 --> 00:18:50,708",
        "text": "Вот только..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:51,250 --> 00:18:53,375",
        "text": "Это я создала монстра."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:18:58,916 --> 00:18:59,750",
        "text": "Вай?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:08,250 --> 00:19:09,166",
        "text": "Ты кто?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:09,833 --> 00:19:11,875",
        "text": "Откуда знаешь мое имя?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:12,958 --> 00:19:14,333",
        "text": "Младший офицер Нолен."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:15,041 --> 00:19:16,249",
        "text": "Мэдди."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:16,250 --> 00:19:17,333",
        "text": "И... оно написано у тебя на лице."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:24,500 --> 00:19:25,582",
        "text": "Итак, в чём дело?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:25,583 --> 00:19:26,665",
        "text": "Случайный обыск?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:26,666 --> 00:19:28,500",
        "text": "Выдворение за пределы территории?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:29,208 --> 00:19:31,083",
        "text": "Или просто хотите потратить мое время?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:31,625 --> 00:19:33,290",
        "text": "Обыск? Нет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:33,291 --> 00:19:34,457",
        "text": "Нет, нет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:34,458 --> 00:19:38,249",
        "text": "Среди миротворцев о тебе ходят легенды."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:38,250 --> 00:19:42,208",
        "text": "Кейтлин устроила скандал, когда тебе пытались отказать в приеме на службу."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:42,750 --> 00:19:44,041",
        "text": "Я должна спросить."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:44,583 --> 00:19:45,540",
        "text": "Это всё правда?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:45,541 --> 00:19:48,707",
        "text": "Ты в одиночку отправилась за Силко, хотя Совет не поддержал тебя?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:48,708 --> 00:19:50,250",
        "text": "Взяла на себя всю банду?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:51,875 --> 00:19:53,290",
        "text": "Кейт рассказала?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:19:53,291 --> 00:19:54,582",
        "text": "Она сказала, что если бы все миротворцы имели сердце, как у тебя, мы могли бы сразиться с самим Ноксусом."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:00,250 --> 00:20:02,791",
        "text": "Затем пригрозила лишить финансирования ее семьи."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:03,333 --> 00:20:06,125",
        "text": "В любом случае, я рада, что ты присоединишься."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:09,500 --> 00:20:11,707",
        "text": "После того, как шериф предал нас, скажем так..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:15,750 --> 00:20:18,458",
        "text": "Приятно знать, что еще остались хорошие люди."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:39,750 --> 00:20:40,875",
        "text": "Офицер Нолен."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:42,666 --> 00:20:44,000",
        "text": "Долг зовет."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:20:44,916 --> 00:20:46,125",
        "text": "Это честь для меня, Вай."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:21:07,666 --> 00:21:09,707",
        "text": "Давайте, мэм. Сюда, мэм."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:21:09,708 --> 00:21:12,250",
        "text": "Стоп. Продолжайте двигаться, ребята."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:21:52,458 --> 00:21:55,541",
        "text": "Одна из многих привилегий работы советником – возможность время от времени стоять за этой трибуной и созерцать стольких людей, объединенных не рождением или диктатом, а ценностями, которые мы разделяем."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:08,291 --> 00:22:09,583",
        "text": "Наша надежда."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:11,458 --> 00:22:12,958",
        "text": "Наша любознательность."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:14,875 --> 00:22:18,958",
        "text": "Наше стремление оставить после себя лучший мир, чем он есть."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:20,333 --> 00:22:24,083",
        "text": "Ценности, которые мы разделяем, делают нас единым народом."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:37,166 --> 00:22:42,250",
        "text": "Сегодня мы разделяем немыслимую потерю."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:43,875 --> 00:22:45,625",
        "text": "Советника Ириуса Болбока, советника Тормана Хоскела, и советника Кассандру Кирамман отняли у нас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:53,958 --> 00:22:56,000",
        "text": "Но мы их не забудем."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:22:59,458 --> 00:23:00,832",
        "text": "Мы установили эту статую, чтобы помнить о них за их бесценный вклад."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:06,291 --> 00:23:08,208",
        "text": "За их бесчисленные заслуги."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:10,083 --> 00:23:13,040",
        "text": "А не из-за подлого поступка, который лишил их жизни."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:13,041 --> 00:23:14,833",
        "text": "Мэм, вы не можете пройти..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:19,208 --> 00:23:21,583",
        "text": "Хотя мы пережили страшный удар, уверяю вас, в Пилтовере царит верховенство закона."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:27,041 --> 00:23:29,500",
        "text": "Нет. Мы найдем виновных."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:30,208 --> 00:23:32,791",
        "text": "И они ответят за свои преступления."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:34,083 --> 00:23:35,500",
        "text": "Ужасно, не правда ли?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:23:40,375 --> 00:23:42,416",
        "text": "Потерять любимого человека."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:24:12,250 --> 00:24:15,166",
        "text": "Верхние, вы здесь не в безопасности."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:24:17,958 --> 00:24:19,416",
        "text": "Никто из вас не в безопасности."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:24:43,333 --> 00:24:44,166",
        "text": "Берегись."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:26:06,916 --> 00:26:07,791",
        "text": "Вперед."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:26:54,416 --> 00:26:56,290",
        "text": "Уведи отсюда советников."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:26:56,291 --> 00:26:57,374",
        "text": "У меня есть идея."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:26:57,375 --> 00:26:58,833",
        "text": "Что ты делаешь?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:29:25,833 --> 00:29:27,875",
        "text": "За моего сына."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:30:07,208 --> 00:30:08,500",
        "text": "Давай."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:30:10,000 --> 00:30:11,291",
        "text": "Черт."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:31:46,833 --> 00:31:48,415",
        "text": "Периметр защищен."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:31:48,416 --> 00:31:49,333",
        "text": "Посмотрим."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:03,458 --> 00:32:05,958",
        "text": "Я думала, что ты погибнешь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:11,625 --> 00:32:13,000",
        "text": "Пойдемте со мной."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:13,583 --> 00:32:14,582",
        "text": "Мемориал."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:14,583 --> 00:32:15,666",
        "text": "Я держу вас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:16,250 --> 00:32:18,957",
        "text": "Что за звери?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:18,958 --> 00:32:20,957",
        "text": "Они хотели зрелища."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:20,958 --> 00:32:22,707",
        "text": "Пытаются напугать вас."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:22,708 --> 00:32:25,041",
        "text": "Всё, что они сделали, только разозлило меня."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:25,625 --> 00:32:26,458",
        "text": "Ты..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:27,250 --> 00:32:30,040",
        "text": "Ты должна найти способ отменить вторжение."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:30,041 --> 00:32:31,082",
        "text": "Что?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:31,083 --> 00:32:33,249",
        "text": "Эта битва прошла на вашей территории."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:33,250 --> 00:32:35,540",
        "text": "Там, внизу, вы будете сражаться на их условиях."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:35,541 --> 00:32:38,457",
        "text": "Всё это не на наших условиях."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:38,458 --> 00:32:41,750",
        "text": "Возможно, стоит изменить это. Я не знаю, как, ясно?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:42,375 --> 00:32:45,249",
        "text": "Она умерла и оставила после себя огромную дыру, а я должна ее заполнить."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:48,708 --> 00:32:50,625",
        "text": "Как будто ее никогда и не было."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:51,166 --> 00:32:52,000",
        "text": "Эй."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:52,583 --> 00:32:53,416",
        "text": "Ты не должна."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:32:54,041 --> 00:32:55,750",
        "text": "Дыра станет меньше, но... ты не заполнишь ее."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:03,583 --> 00:33:05,750",
        "text": "Я была неправа, навязывая тебе значок."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:07,125 --> 00:33:08,374",
        "text": "Просто... при любом раскладе, если я пойду за твоей сестрой одна, кто-то из нас вернется в ящике."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:16,708 --> 00:33:18,208",
        "text": "Всё разваливается."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:20,083 --> 00:33:21,000",
        "text": "Нет, это не так."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:22,750 --> 00:33:23,833",
        "text": "Мы этого не допустим."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:38,083 --> 00:33:41,166",
        "text": "Знаю, ты сомневаешься в преимуществе по праву рождения, Кейтлин."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:42,958 --> 00:33:44,333",
        "text": "В этом есть своя мудрость."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:47,250 --> 00:33:48,208",
        "text": "Но помни."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:33:51,708 --> 00:33:53,041",
        "text": "Ты – Кирамман."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:23,375 --> 00:34:24,957",
        "text": "Никогда в жизни лидеры Пилтовера не были вынуждены находиться в подземельях нашей столицы."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:30,750 --> 00:34:31,958",
        "text": "Но вот мы здесь."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:32,708 --> 00:34:37,666",
        "text": "Кто еще сомневается, что враг больше, чем один сумасшедший индивид?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:38,208 --> 00:34:41,957",
        "text": "Как они пронесли столько всяких штук на церемонию?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:41,958 --> 00:34:45,040",
        "text": "Я думала, мы приняли все меры по обеспечению безопасности."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:45,041 --> 00:34:46,541",
        "text": "Должно быть, им помогали."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:47,083 --> 00:34:48,375",
        "text": "Кто-то из местных."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:48,958 --> 00:34:51,124",
        "text": "Мы не можем позволить себе лишних стенаний."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:51,125 --> 00:34:53,249",
        "text": "Если не будем защищаться с помощью хекстека, наши принципы ничего не будут значить."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:56,875 --> 00:34:57,708",
        "text": "Я..."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:34:58,791 --> 00:35:01,082",
        "text": "Мы не готовы для полномасштабного вторжения."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:01,083 --> 00:35:02,957",
        "text": "Нападение доказало это."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:02,958 --> 00:35:06,000",
        "text": "Это закрытое заседание Совета. Кто тебя впустил?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:07,041 --> 00:35:09,082",
        "text": "Я заслуженный офицер."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:09,083 --> 00:35:10,790",
        "text": "Лидер дома Кирамман."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:10,791 --> 00:35:12,749",
        "text": "Обращайся ко мне с уважением или держи рот на замке."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:16,875 --> 00:35:19,833",
        "text": "Я поведу отряд в Заун с тремя целями: найти Джинкс, ликвидировать Мерцание и обезвредить всех агентов, которые всё еще преданы Силко."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:29,083 --> 00:35:32,541",
        "text": "Почему ты думаешь, что справишься лучше, чем наши войска сегодня?"
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:35:35,625 --> 00:35:37,333",
        "text": "У нас есть несколько сюрпризов."
    },
    {
        "season": 2,
        "episode": 1,
        "time_code": "00:36:21,708 --> 00:36:24,708",
        "text": "ЧЕЛОВЕК ПРОГРЕССА"
    }
]