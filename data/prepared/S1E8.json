[
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:38,958 --> 00:00:40,416",
        "text": "Когда мне было десять, твой дед привел меня на место недавней битвы при Хильденарде."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:44,500 --> 00:00:49,458",
        "text": "Обещал дать золотой за каждый меч, который я заберу у погибших."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:49,541 --> 00:00:51,166",
        "text": "Сказал, что нам нужна сталь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:52,083 --> 00:00:53,583",
        "text": "Но я знала, что это ложь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:54,583 --> 00:00:57,791",
        "text": "Он хотел показать мне смерть."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:00:58,750 --> 00:01:02,041",
        "text": "Кено говорит, что война - результат неразумного правления."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:02,125 --> 00:01:04,500",
        "text": "У твоего брата язык хорошо подвешен."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:04,583 --> 00:01:06,791",
        "text": "Думает, он хитрый лис в волчьей стае."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:06,875 --> 00:01:10,708",
        "text": "Но запомни мои слова: чтобы выжить в этом мире, надо уметь быть и лисой, и волком."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:17,458 --> 00:01:19,125",
        "text": "Мы покроем стены золотом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:19,916 --> 00:01:22,041",
        "text": "Купим хрустальные люстры."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:22,125 --> 00:01:24,208",
        "text": "Советники буду входить здесь, но у регентши будет собственный потайной вход."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:28,291 --> 00:01:31,041",
        "text": "У нее должно быть доброе и пухлое лицо."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:31,125 --> 00:01:36,500",
        "text": "Она должна быть умна, чтобы нравиться подданым, и поступать как выгодно нам."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:36,583 --> 00:01:38,333",
        "text": "Возможно, подойдет моя дочь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:39,166 --> 00:01:40,958",
        "text": "Ты отдашь мне трон?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:41,041 --> 00:01:46,750",
        "text": "Я отдам тебе весь мир, дитя мое, если докажешь, что справишься с ним."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:01:59,916 --> 00:02:01,458",
        "text": "Как нам с ней поступить?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:08,208 --> 00:02:10,000",
        "text": "Она не доставит нам хлопот."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:10,583 --> 00:02:13,791",
        "text": "Конфискуем ее имущество и отправим в дальние колонии."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:17,875 --> 00:02:19,916",
        "text": "Она символ старого режима."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:20,583 --> 00:02:23,291",
        "text": "Казним ее сейчас - и больше никто не погибнет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:23,958 --> 00:02:26,166",
        "text": "Оставим в живых - и придется убить тысячи."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:26,250 --> 00:02:29,041",
        "text": "Мы можем показать людям свое милосердие."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:02:47,208 --> 00:02:48,708",
        "text": "Волк не знает милосердия."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:03:15,791 --> 00:03:16,791",
        "text": "Продержишься?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:03:17,625 --> 00:03:19,541",
        "text": "Я сейчас вернусь. Ладно."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:03:28,250 --> 00:03:29,208",
        "text": "Джинкс!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:04:02,666 --> 00:04:03,750",
        "text": "Он исчез."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:04:03,833 --> 00:04:04,750",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:04:07,791 --> 00:04:09,041",
        "text": "Всё было напрасно."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:05:51,375 --> 00:05:52,833",
        "text": "Советник, район оцеплен."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:05:53,333 --> 00:05:55,583",
        "text": "У меня приказ сопроводить вас в город."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:05:57,250 --> 00:05:58,500",
        "text": "Советник?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:05:59,125 --> 00:06:00,125",
        "text": "Все в порядке?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:40,083 --> 00:06:43,291",
        "text": "Кто тут живет? Еще какой-нибудь друг из совета?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:47,750 --> 00:06:49,000",
        "text": "Кейтлин!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:49,791 --> 00:06:52,833",
        "text": "Мы так волновались! Как хорошо, что ты цела!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:52,916 --> 00:06:54,250",
        "text": "А кто эта бродяжка?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:54,833 --> 00:06:55,875",
        "text": "Это Вай."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:56,416 --> 00:06:58,083",
        "text": "Она из нижнего города."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:58,166 --> 00:06:59,208",
        "text": "Я догадалась."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:06:59,875 --> 00:07:02,083",
        "text": "На пару слов, Кейтлин."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:02,833 --> 00:07:04,000",
        "text": "Наедине."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:09,500 --> 00:07:11,250",
        "text": "Ты должна выступить на совете!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:11,333 --> 00:07:13,083",
        "text": "Выступить на совете?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:13,166 --> 00:07:15,583",
        "text": "Ты понимаешь, что нарушила несколько законов?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:15,666 --> 00:07:17,791",
        "text": "Она поступала по совести."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:19,666 --> 00:07:21,166",
        "text": "Я готова за всё ответить."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:21,250 --> 00:07:23,041",
        "text": "Ты дочь советницы."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:23,125 --> 00:07:25,416",
        "text": "Твои действия бросают тень на весь совет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:25,500 --> 00:07:26,708",
        "text": "Мои действия?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:27,583 --> 00:07:29,708",
        "text": "Знаешь, что еще бросает тень на совет?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:29,791 --> 00:07:32,750",
        "text": "Бездомные на улицах. Их травят."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:32,833 --> 00:07:35,625",
        "text": "Заставляют выбирать между бандитом, который на них наживается, и правительством, которое на них плюет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:38,083 --> 00:07:39,166",
        "text": "Кейтлин!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:42,083 --> 00:07:45,250",
        "text": "Нашей дочери нужно отдохнуть после всего, через что она прошла."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:51,791 --> 00:07:53,541",
        "text": "Я назначу аудиенцию."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:55,208 --> 00:07:56,458",
        "text": "Спасибо."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:07:56,541 --> 00:07:59,958",
        "text": "Вы с подругой сами выступите перед советом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:00,041 --> 00:08:02,916",
        "text": "Рекомендую подготовиться как следует."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:24,625 --> 00:08:28,458",
        "text": "Травмы очень серьезные. Думаешь, я сам не вижу?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:30,916 --> 00:08:35,833",
        "text": "Я смогу ее спасти, но лечение будет болезненным."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:36,708 --> 00:08:39,250",
        "text": "Иногда милосерднее дать умереть."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:39,833 --> 00:08:41,458",
        "text": "Она выдержит."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:41,541 --> 00:08:46,541",
        "text": "Прежде чем начнем, я должен спросить: ты готов ее потерять?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:48,416 --> 00:08:49,458",
        "text": "Джинкс?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:50,541 --> 00:08:51,625",
        "text": "Джинкс!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:55,333 --> 00:08:57,875",
        "text": "Она не умрет, доктор."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:08:58,541 --> 00:08:59,666",
        "text": "Она не может умереть."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:02,750 --> 00:09:03,916",
        "text": "Я понял."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:07,708 --> 00:09:10,750",
        "text": "И ты пойми: это для твоего же блага."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:16,458 --> 00:09:18,708",
        "text": "У меня тоже когда-то была дочь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:33,708 --> 00:09:35,500",
        "text": "Силко не принимает гостей."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:35,583 --> 00:09:36,708",
        "text": "Не проблема."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:36,791 --> 00:09:40,500",
        "text": "Я не к нему. Хочу с тобой поболтать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:43,750 --> 00:09:46,416",
        "text": "Знаешь, как ни спрошу у ребят, чем Силко занят - всегда первым делом слышу твое имя."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:49,250 --> 00:09:53,250",
        "text": "«Сэйвика в порту» или «Сэйвика навещает крепколобых»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:54,083 --> 00:09:55,625",
        "text": "С тобой шутки плохи."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:57,875 --> 00:09:59,000",
        "text": "Ближе к делу."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:09:59,500 --> 00:10:01,708",
        "text": "Смотри, ты за штурвалом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:01,791 --> 00:10:03,916",
        "text": "Только корабль не твой."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:04,000 --> 00:10:06,708",
        "text": "Он принадлежит ему и Джинкс."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:06,791 --> 00:10:08,416",
        "text": "Вот значит как?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:08,500 --> 00:10:11,583",
        "text": "Думаешь, я кину Силко, если ко мне подлизаться?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:12,583 --> 00:10:13,791",
        "text": "Да уж, Финн."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:13,875 --> 00:10:16,791",
        "text": "Только подумаю, что тупее ты быть не можешь, как ты ставишь новый рекорд."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:18,125 --> 00:10:21,416",
        "text": "Давай начистоту. Он теряет хватку."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:21,500 --> 00:10:23,666",
        "text": "Нижний город погружается в хаос."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:23,750 --> 00:10:27,250",
        "text": "И не похоже, чтобы он спешил наводить порядок."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:28,958 --> 00:10:32,541",
        "text": "Джинкс вертит им как хочет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:32,625 --> 00:10:35,541",
        "text": "А тебе приходится разгребать его дерьмо."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:36,791 --> 00:10:40,041",
        "text": "Я не подлизываюсь, а предлагаю подумать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:46,041 --> 00:10:49,500",
        "text": "Не ты одна недовольна его поведением."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:10:50,166 --> 00:10:52,750",
        "text": "Есть игроки и покрупнее Силко."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:27,166 --> 00:11:31,083",
        "text": "Мэл. Элора. Торжественная встреча ни к чему."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:31,166 --> 00:11:34,083",
        "text": "Что ты здесь делаешь, мама? Заехала в гости."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:34,166 --> 00:11:36,750",
        "text": "Я наслышана о гостеприимстве Пилтовера."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:37,916 --> 00:11:41,625",
        "text": "Ты преодолела полконтинента, чтобы попробовать местную кухню?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:41,708 --> 00:11:43,416",
        "text": "Мэл, уже лет десять прошло."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:43,500 --> 00:11:45,208",
        "text": "С тех пор, как ты меня прогнала?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:45,291 --> 00:11:46,791",
        "text": "Не драматизируй."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:46,875 --> 00:11:50,708",
        "text": "Я хотела, чтобы ты развивалась и заботилась об интересах семьи."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:50,791 --> 00:11:51,791",
        "text": "И ты преуспела."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:11:51,875 --> 00:11:55,333",
        "text": "Ты сказала: «Быть может, твою сентиментальность больше оценят эти мягкотелые идеалисты за морем»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:00,125 --> 00:12:01,833",
        "text": "Хорошая память, в отца."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:01,916 --> 00:12:04,083",
        "text": "Не пытайся меня задобрить."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:04,166 --> 00:12:06,416",
        "text": "Мэл. Ну хватит."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:11,375 --> 00:12:12,666",
        "text": "Твоего брата больше нет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:16,291 --> 00:12:17,375",
        "text": "Что произошло?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:19,958 --> 00:12:21,958",
        "text": "Он перешел дорогу не тому человеку."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:23,000 --> 00:12:24,083",
        "text": "Я была занята."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:25,166 --> 00:12:27,500",
        "text": "Этой ошибки мне уже не исправить."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:31,250 --> 00:12:34,708",
        "text": "Твой Джейс Талис решил превратить хекстек в оружие."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:35,666 --> 00:12:36,666",
        "text": "Так и знала."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:36,750 --> 00:12:38,291",
        "text": "Будет война."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:38,375 --> 00:12:41,375",
        "text": "Ты слишком запустила проблему с нижним городом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:41,458 --> 00:12:43,000",
        "text": "Пилтовер не Ноксус."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:43,083 --> 00:12:46,000",
        "text": "Для нас война не ответ на все вопросы."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:46,083 --> 00:12:50,416",
        "text": "Я поддерживала хекстек, чтобы защитить город, а не уничтожить его."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:50,500 --> 00:12:53,208",
        "text": "Это не домыслы, а факт."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:53,291 --> 00:12:57,083",
        "text": "Если оружие создано, его непременно пустят в дело."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:12:57,166 --> 00:13:00,958",
        "text": "Я прибыла, чтобы помочь тебе принимать верные решения."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:01,041 --> 00:13:04,250",
        "text": "Мне не нужна твоя помощь. Посмотрим."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:06,416 --> 00:13:07,541",
        "text": "Госпожа Медарда?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:08,708 --> 00:13:09,708",
        "text": "Да? Да?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:13,041 --> 00:13:14,625",
        "text": "Это за мной, дорогая."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:18,958 --> 00:13:21,083",
        "text": "Попробую местную кухню."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:34,041 --> 00:13:37,791",
        "text": "Мы выступим перед советом. Сегодня вечером."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:40,583 --> 00:13:41,875",
        "text": "Ты сама до всего этого додумалась?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:42,666 --> 00:13:44,208",
        "text": "Даже не спускаясь к нам?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:46,791 --> 00:13:49,083",
        "text": "А я думала, Паудер одержимая."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:53,083 --> 00:13:55,666",
        "text": "Ты не виновата в том, что с ней стало."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:13:59,958 --> 00:14:01,875",
        "text": "Когда наши родители были живы, мы с Паудер спали на одной кровати."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:06,250 --> 00:14:09,166",
        "text": "Вот так же, только кровать была раза в два меньше."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:10,208 --> 00:14:15,208",
        "text": "У нас была игра: чье чудовище сильнее."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:16,583 --> 00:14:21,125",
        "text": "Например, она говорит: «Я жуткий ядовитый слизняк»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:22,375 --> 00:14:26,833",
        "text": "А я отвечаю: «Я шипастый краб, пожирающий слизняков»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:29,125 --> 00:14:33,416",
        "text": "Иногда я увлекалась и пугала ее."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:36,708 --> 00:14:39,416",
        "text": "Чтобы она не заплакала и не разбудила родителей, я делала вид, что прогоняю всех чудовищ."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:43,958 --> 00:14:48,083",
        "text": "Я говорила: «Пока я рядом, ни одно чудовище тебя не тронет»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:50,166 --> 00:14:51,666",
        "text": "Но появилось настоящее чудовище."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:54,791 --> 00:14:56,208",
        "text": "И я просто убежала."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:14:58,375 --> 00:14:59,541",
        "text": "Я бросила ее."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:27,541 --> 00:15:30,375",
        "text": "Знаешь, Паудер, ты сильнее, чем думаешь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:31,125 --> 00:15:32,083",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:33,750 --> 00:15:35,791",
        "text": "Прости меня, Паудер."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:35,875 --> 00:15:38,291",
        "text": "Твоя сестра - Джинкс? Нет!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:39,791 --> 00:15:41,125",
        "text": "Джинкс."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:41,208 --> 00:15:43,041",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:44,833 --> 00:15:47,250",
        "text": "Насколько я понимаю, это больно."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:47,333 --> 00:15:49,166",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:49,250 --> 00:15:52,416",
        "text": "Боюсь, будет еще больнее. Стой!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:15:53,083 --> 00:15:56,625",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:16:29,541 --> 00:16:31,041",
        "text": "Что ты сделал?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:16:32,375 --> 00:16:33,791",
        "text": "Я спас ей жизнь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:16:51,166 --> 00:16:52,833",
        "text": "С дороги, комок шерсти."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:16:52,916 --> 00:16:53,958",
        "text": "А ну, посторонись."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:17:39,041 --> 00:17:40,208",
        "text": "Гляди."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:17:42,166 --> 00:17:43,375",
        "text": "Оставь ее в покое."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:17:45,416 --> 00:17:46,416",
        "text": "Пока."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:07,208 --> 00:18:08,625",
        "text": "О, это гениально."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:08,708 --> 00:18:12,083",
        "text": "Хотя лопасти подогнаны неправильно."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:12,875 --> 00:18:14,041",
        "text": "Ошибаетесь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:15,166 --> 00:18:16,750",
        "text": "Это сделано для нижнего города."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:17,416 --> 00:18:18,541",
        "text": "Там воздух плотнее."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:20,625 --> 00:18:22,125",
        "text": "Юноша, у вас всё хорошо?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:22,208 --> 00:18:25,375",
        "text": "Да, нормально, просто лодыжку растянул."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:26,916 --> 00:18:29,291",
        "text": "Вы советник Хеймердингер?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:30,250 --> 00:18:32,750",
        "text": "Больше уже не советник."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:33,375 --> 00:18:35,208",
        "text": "Что вы делаете на этой стороне реки?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:36,375 --> 00:18:40,291",
        "text": "Хотел предложить помощь жителям нижнего города, но… Кажется, мне здесь не рады."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:46,250 --> 00:18:49,083",
        "text": "Почему вы смеетесь? И у меня сегодня та же проблема."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:51,041 --> 00:18:55,291",
        "text": "Это не простое растяжение. Вам нужна медицинская помощь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:55,375 --> 00:18:58,583",
        "text": "Мне нужно домой. Здесь небезопасно."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:18:59,583 --> 00:19:03,208",
        "text": "Не знаю только, как это сделать. Нога болит и, как видите, лететь мне не на чем."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:18,416 --> 00:19:21,458",
        "text": "В вашей академии преподают военную историю, господин Талис?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:22,125 --> 00:19:24,500",
        "text": "Советник Талис."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:25,375 --> 00:19:27,291",
        "text": "Я точно не знаю."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:27,375 --> 00:19:29,333",
        "text": "Алорнийский генерал Соннем Парлек встречал своих врагов с завязанными глазами."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:32,416 --> 00:19:35,041",
        "text": "Говорил: «Пока действует тело, разум молчит»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:35,750 --> 00:19:38,583",
        "text": "Но я сомневаюсь, что он пробовал встречать их вот так."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:39,333 --> 00:19:40,541",
        "text": "Вы мать Мэл."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:41,291 --> 00:19:42,625",
        "text": "Среди прочего."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:43,500 --> 00:19:46,375",
        "text": "Жми сильнее, мальчик. Не сломаешь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:47,750 --> 00:19:49,666",
        "text": "Прошу прощения, у меня очень много дел."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:49,750 --> 00:19:51,875",
        "text": "Нижний город - серьезная угроза."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:51,958 --> 00:19:53,666",
        "text": "Вы не в состоянии его контролировать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:55,333 --> 00:19:58,625",
        "text": "Здесь, конечно, не Ноксус, но Пилтовер не так слаб, как кажется."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:19:58,708 --> 00:20:02,083",
        "text": "А при чем тут Пилтовер? Проблема в совете."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:02,166 --> 00:20:04,666",
        "text": "Тело в движении, а разум молчит."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:04,750 --> 00:20:08,958",
        "text": "Чтобы преодолеть этот кризис, требуется опыт, которого у вас нет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:09,750 --> 00:20:13,083",
        "text": "Знаете, сколько проектов в академии оказываюся успешными?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:13,166 --> 00:20:14,250",
        "text": "Три процента."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:14,833 --> 00:20:16,708",
        "text": "Нам не привыкать к неудачам."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:16,791 --> 00:20:20,416",
        "text": "Но мы стали Городом прогресса, потому что не сдаемся, идем до конца."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:21,000 --> 00:20:24,750",
        "text": "Спасибо за совет, госпожа Медарда, но мне нужно заняться делами."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:26,041 --> 00:20:27,208",
        "text": "Стой."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:32,250 --> 00:20:35,291",
        "text": "Понятно, почему этот город и моя дочь от тебя без ума."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:35,916 --> 00:20:37,416",
        "text": "Ты полон юношеской страсти."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:38,333 --> 00:20:41,000",
        "text": "А у меня есть опыт."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:41,083 --> 00:20:44,958",
        "text": "Я желаю тебе успеха, Джейс: подари миру хекстек."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:45,041 --> 00:20:49,833",
        "text": "Но ты должен раскрыть глаза, иначе кончишь, как генерал Парлек."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:49,916 --> 00:20:53,291",
        "text": "Сдохнешь слепым."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:20:56,958 --> 00:21:00,958",
        "text": "Трое из моих поставщиков заявили, что придержат товары до осени, «пока всё не упокоится»."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:03,416 --> 00:21:05,708",
        "text": "Есть проблемы посерьезнее, чем снижение прибылей."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:05,791 --> 00:21:08,666",
        "text": "Шериф был в сговоре с преступниками. Надо разобраться… Надо что-то делать. Пока еще кто-нибудь не погиб."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:12,875 --> 00:21:15,375",
        "text": "Возможно, Маркус действовал сам по себе."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:15,458 --> 00:21:18,791",
        "text": "Что могли дать ему нижние, чего у него не было здесь?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:18,875 --> 00:21:22,666",
        "text": "Суть не в том, что ему дали, а в том, что могли отнять."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:24,833 --> 00:21:28,166",
        "text": "Советники, моя дочь изучила ситуацию изнутри."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:28,750 --> 00:21:29,666",
        "text": "Спасибо."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:31,041 --> 00:21:35,291",
        "text": "Советники, это Вай. Она из нижнего города."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:35,375 --> 00:21:38,291",
        "text": "Хотя мы во многом перед ней виноваты, она рискнула всем, чтобы показать мне, какова на самом деле жизнь внизу."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:42,875 --> 00:21:46,625",
        "text": "Люди голодают, болеют, их губит мерцание."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:47,541 --> 00:21:49,000",
        "text": "Они живут в постоянном страхе перед кучкой обнаглевших преступников."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:52,291 --> 00:21:54,041",
        "text": "И заправляет всем один человек - Силко."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:55,958 --> 00:21:58,458",
        "text": "Мы расследовали деятельность Силко."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:21:58,541 --> 00:22:01,666",
        "text": "Данные о нарушениях не подтвердились."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:01,750 --> 00:22:03,291",
        "text": "А кто вел это расследование?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:05,208 --> 00:22:06,791",
        "text": "Чего этот Силко от нас хочет?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:06,875 --> 00:22:09,625",
        "text": "Независимости для нижнего города."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:09,708 --> 00:22:11,791",
        "text": "Для всех жителей Зауна."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:14,458 --> 00:22:16,708",
        "text": "А эти штуки? Знаешь, кто их сделал?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:16,791 --> 00:22:18,416",
        "text": "Нет, то есть… Ее зовут Джинкс."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:21,708 --> 00:22:23,291",
        "text": "И самоцвет сейчас у нее?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:24,791 --> 00:22:27,333",
        "text": "Придется забрать его силой. И начать войну?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:27,416 --> 00:22:30,708",
        "text": "Там живут хорошие люди! И плохие тоже."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:30,791 --> 00:22:33,750",
        "text": "Предположим, мы решим напасть. У них есть мерцание."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:34,333 --> 00:22:35,750",
        "text": "А у нас - хекстек."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:36,375 --> 00:22:38,125",
        "text": "Да что с тобой?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:38,208 --> 00:22:40,375",
        "text": "Мы неделями ведем пустые разговоры."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:40,458 --> 00:22:42,666",
        "text": "А мост всё еще отмывают от крови."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:42,750 --> 00:22:44,291",
        "text": "Когда же мы дадим им отпор?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:44,375 --> 00:22:45,750",
        "text": "Джейс, ты не видел войны."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:46,333 --> 00:22:47,208",
        "text": "А я видела."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:47,291 --> 00:22:52,083",
        "text": "Война - крайняя мера. Найдем дипломатическое решение."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:22:53,750 --> 00:22:54,791",
        "text": "Она права."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:02,208 --> 00:23:04,625",
        "text": "Что? Хотите с ним договориться?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:04,708 --> 00:23:07,666",
        "text": "Только так можно избежать еще большего кровопролития."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:07,750 --> 00:23:10,958",
        "text": "Это безумие. Вы ничему не научились?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:11,041 --> 00:23:13,000",
        "text": "Вам нечего с ним обсуждать!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:13,083 --> 00:23:16,208",
        "text": "Он ненавидит вас и все ваши ценности."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:16,791 --> 00:23:18,833",
        "text": "Он никогда не отступит."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:21,791 --> 00:23:25,500",
        "text": "Миротворцы, проводите их на выход. Не надо."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:25,583 --> 00:23:27,916",
        "text": "Вашу пафосную дверь я и сама найду."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:40,333 --> 00:23:41,625",
        "text": "Вай! Подожди!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:42,375 --> 00:23:44,875",
        "text": "Стой! Куда ты?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:44,958 --> 00:23:47,041",
        "text": "Не знаю. Туда, откуда пришла?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:47,125 --> 00:23:49,416",
        "text": "Все здесь только этого и ждут."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:49,500 --> 00:23:51,625",
        "text": "Я могу всё исправить. Не можешь!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:51,708 --> 00:23:54,416",
        "text": "Вот она, наша жизнь. Так было всегда."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:54,500 --> 00:23:57,000",
        "text": "Глупо было думать, что она может измениться."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:23:57,083 --> 00:24:00,958",
        "text": "Наверняка можно придумать что-то еще. Найти другой способ."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:01,041 --> 00:24:03,291",
        "text": "Составим новый план. Мы должны попытаться."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:03,916 --> 00:24:06,541",
        "text": "Мы пытались. Ясно? Но всё без толку."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:06,625 --> 00:24:09,833",
        "text": "Верх и низ. Масло и вода. И третьего не дано."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:10,625 --> 00:24:11,833",
        "text": "А как же мы?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:14,375 --> 00:24:15,458",
        "text": "Масло и вода."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:16,000 --> 00:24:17,208",
        "text": "Не судьба."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:19,041 --> 00:24:22,208",
        "text": "Не говори так. Послушай совет, кексик."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:24:23,083 --> 00:24:26,625",
        "text": "Вернись в свой большой красивый дом и просто… …забудь меня. Ладно?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:25:32,458 --> 00:25:35,708",
        "text": "Виктор, я уже пару недель работаю над одним своим проектом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:25:38,916 --> 00:25:39,875",
        "text": "Не так."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:25:54,708 --> 00:25:58,333",
        "text": "Виктор, я работаю над этим уже год и… Виктор."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:26:13,916 --> 00:26:17,958",
        "text": "Виктор, ты не мог бы взглянуть на одну мою разработку?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:26:23,500 --> 00:26:26,625",
        "text": "Виктор, меня так вдохновил твой… Меня вдохновляет всё, что ты делаешь."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:26:38,750 --> 00:26:39,666",
        "text": "Виктор!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:27:00,708 --> 00:27:02,625",
        "text": "Виктор!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:27:28,041 --> 00:27:30,458",
        "text": "Скай? Нет. Нет!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:27:30,541 --> 00:27:32,958",
        "text": "Этого не может… Хочешь, чтобы Силко получил по заслугам?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:20,583 --> 00:28:22,000",
        "text": "Я могу тебя арестовать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:22,708 --> 00:28:24,750",
        "text": "А вы тут любите угрожать арестом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:25,458 --> 00:28:27,333",
        "text": "Ты хоть раз был в «Тихом омуте»?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:27,416 --> 00:28:28,416",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:29,333 --> 00:28:32,333",
        "text": "Значит, ты просто машешь ручкой, кого-то крутят, и тебе даже не интересно, что происходит с человеком, который гниет в каменном мешке неделями, месяцами, а может, годами."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:41,458 --> 00:28:45,375",
        "text": "Да, я хочу разобраться с Силко. Я тебе помогу."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:46,083 --> 00:28:47,166",
        "text": "Не с чем помогать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:47,250 --> 00:28:49,458",
        "text": "Ты слышала советников. Пошли они в жопу."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:50,000 --> 00:28:51,625",
        "text": "Ты сам сказал, что устал от бездействия."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:51,708 --> 00:28:54,916",
        "text": "Единственные разумные слова за сегодняшний вечер."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:55,500 --> 00:28:56,791",
        "text": "Я не линчеватель."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:28:56,875 --> 00:28:59,333",
        "text": "Нет, ты жертва."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:10,875 --> 00:29:13,958",
        "text": "Это чтобы на голосовании твою руку сразу заметили?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:15,000 --> 00:29:16,583",
        "text": "Мы делали ее для шахтеров."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:18,625 --> 00:29:20,458",
        "text": "У моего знакомого были такие."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:22,375 --> 00:29:25,750",
        "text": "Ты первый, о ком подумала Кейтлин, когда мы выбрались наверх."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:26,333 --> 00:29:28,208",
        "text": "Она верила, что из всех верхних именно ты решишься что-то сделать."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:35,250 --> 00:29:37,500",
        "text": "Что, например? Арестовать его?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:38,000 --> 00:29:40,375",
        "text": "Силко контролирует нижний город при помощи мерцания."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:40,458 --> 00:29:41,916",
        "text": "Останови поставки - и очень скоро сторонники Силко станут его врагами."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:45,208 --> 00:29:46,375",
        "text": "Как это сделать?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:46,458 --> 00:29:48,500",
        "text": "Ударь по заводам."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:48,583 --> 00:29:51,000",
        "text": "Сильно и быстро, чтобы не успел опомниться."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:29:55,833 --> 00:29:59,375",
        "text": "Ну что, по рукам, красавчик?"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:26,875 --> 00:30:28,583",
        "text": "Вперед."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:35,791 --> 00:30:37,375",
        "text": "Вперед. За мостом."
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:39,458 --> 00:30:40,375",
        "text": "Захвачено!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:44,583 --> 00:30:45,708",
        "text": "Назад!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:45,791 --> 00:30:47,000",
        "text": "Не рыпайся!"
    },
    {
        "season": 1,
        "episode": 8,
        "time_code": "00:30:52,750 --> 00:30:53,875",
        "text": "Эй!"
    }
]