[
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:00:47,833 --> 00:00:48,791",
        "text": "ДЖИНКС ПИЛТОВЕР РОЗЫСК СИНИЙ ДЖИНКС ПИЛТОВЕР РОЗЫСК РАСКРАСЬ ГОРОД В СИНИЙ АРКЕЙН Снова наверх?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:02:54,375 --> 00:02:56,332",
        "text": "Город никуда не денется."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:02:56,333 --> 00:02:59,666",
        "text": "У меня аудиенция в Гильдии каменщиков с самого утра."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:02,541 --> 00:03:03,915",
        "text": "Дай угадаю."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:03,916 --> 00:03:05,708",
        "text": "Жалобы на ноксианцев."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:06,250 --> 00:03:08,582",
        "text": "Они удвоили свои запросы на укрепления."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:08,583 --> 00:03:10,124",
        "text": "Снова. Чтобы..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:10,125 --> 00:03:11,541",
        "text": "Чтобы мы были в безопасности."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:15,916 --> 00:03:18,583",
        "text": "Я не ожидала, что это так затянется."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:19,458 --> 00:03:20,291",
        "text": "Я думала..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:21,500 --> 00:03:22,916",
        "text": "Не знаю, о чём я думала."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:23,458 --> 00:03:24,291",
        "text": "Просто... ...о другом."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:28,041 --> 00:03:31,374",
        "text": "Ты можешь всё бросить. Покинуть подземелье."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:31,375 --> 00:03:35,666",
        "text": "Восстановить Совет. Нужно лишь отдать приказ."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:37,750 --> 00:03:39,166",
        "text": "Только не без Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:40,750 --> 00:03:44,457",
        "text": "Кроме того, отступление может привести к худшей ситуации, чем та..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:44,458 --> 00:03:45,541",
        "text": "Хорошо, Амбесса."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:53,666 --> 00:03:55,249",
        "text": "Она предоставила нам Заун, как и обещала."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:03:56,916 --> 00:04:00,125",
        "text": "Кто знает, сколько миротворцев мы бы потеряли без нее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:00,708 --> 00:04:02,500",
        "text": "Я так многому у нее научилась."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:03,041 --> 00:04:04,624",
        "text": "Ты наш лидер."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:04,625 --> 00:04:08,125",
        "text": "Миротворцы, Пилтовер, все следуют за тобой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:11,458 --> 00:04:12,875",
        "text": "Я следую за тобой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:17,916 --> 00:04:19,250",
        "text": "Я скоро лягу."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:26,666 --> 00:04:29,124",
        "text": "Дамы и господа, вы не в том месте."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:31,166 --> 00:04:33,332",
        "text": "Отморозки и отщепенцы, соедините свои крюки и лапы для самого мерзкого, уродливого, отвратительного зрелища в вашей жизни."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:42,375 --> 00:04:44,249",
        "text": "В сером углу – наш непобедимый чемпион."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:46,291 --> 00:04:47,957",
        "text": "Его когти подобны кинжалам, а зубы даже еще острее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:50,208 --> 00:04:51,582",
        "text": "Дьявольский, ужасный Вонючка ВОНЮЧКА А в другом сером углу – претендент."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:04:59,833 --> 00:05:01,166",
        "text": "Восходящая звезда с отвратительной челюстью и лицом, которое заставило бы скривиться даже родную мать."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:06,541 --> 00:05:08,208",
        "text": "Жуткий, подлый, {\\an8}Шустряк."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:11,416 --> 00:05:13,666",
        "text": "{\\an8}ШУСТРЯК Двое выйдут."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:15,791 --> 00:05:19,625",
        "text": "А после этого, кто знает?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:20,208 --> 00:05:23,625",
        "text": "Укротители, выпускайте своих чудовищ."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:41,000 --> 00:05:44,040",
        "text": "Нет, нет. Что вы делаете?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:44,041 --> 00:05:45,666",
        "text": "Проявите немного усилий."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:56,416 --> 00:05:58,790",
        "text": "Поздравляю с победой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:05:58,791 --> 00:06:01,249",
        "text": "Ну, ты уже в расцвете сил, чемпион."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:01,250 --> 00:06:03,041",
        "text": "Остается только..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:06,291 --> 00:06:07,749",
        "text": "Реванш?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:07,750 --> 00:06:09,875",
        "text": "Возвращение титанов."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:10,708 --> 00:06:12,582",
        "text": "Месть. Искупление."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:12,583 --> 00:06:16,958",
        "text": "Необъяснимое выделение биологических газов."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:18,708 --> 00:06:20,166",
        "text": "ДЖИНКС Ладно, ладно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:23,208 --> 00:06:25,624",
        "text": "Я всё еще думаю, что это глупая идея."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:25,625 --> 00:06:28,666",
        "text": "Но, похоже, ты выиграла, а сделка есть сделка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:29,416 --> 00:06:30,416",
        "text": "Наверное."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:39,333 --> 00:06:40,416",
        "text": "Та-да."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:42,041 --> 00:06:43,041",
        "text": "Тебе нравится?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:45,333 --> 00:06:46,499",
        "text": "Тебе повезло."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:46,500 --> 00:06:49,958",
        "text": "Я не часто занималась этим со своей старшей сестрой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:50,500 --> 00:06:51,916",
        "text": "Она больше любила... ...наносить удары."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:06:56,625 --> 00:06:59,416",
        "text": "Тогда у меня было другое имя, знаешь ли."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:00,708 --> 00:07:01,791",
        "text": "Паудер."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:02,625 --> 00:07:03,750",
        "text": "Глупо, да?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:04,583 --> 00:07:06,708",
        "text": "Я думала, что избавилась от нее навсегда, но... ...ты чем-то напоминаешь мне ее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:21,916 --> 00:07:23,500",
        "text": "Это Сэйвика тебя подговорила?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:25,625 --> 00:07:27,499",
        "text": "Это прошлая жизнь, мелочь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:27,500 --> 00:07:29,791",
        "text": "И она была не слаще скисшего молока."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:07:30,458 --> 00:07:32,166",
        "text": "Джинкс мертва."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:08:38,833 --> 00:08:43,457",
        "text": "Как в городе, кишащем гениальными изобретателями, нам удалось найти такую потрясающую бездарность?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:08:50,000 --> 00:08:51,499",
        "text": "Это их рук дело."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:08:51,500 --> 00:08:53,040",
        "text": "Мы не можем знать, что Черная..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:08:53,041 --> 00:08:55,125",
        "text": "Не упоминай это имя."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:08:56,000 --> 00:09:00,290",
        "text": "Мы не можем быть уверены, что Орден стоит за исчезновением Джейса и Хаймердингера."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:02,375 --> 00:09:03,624",
        "text": "Кто же еще?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:03,625 --> 00:09:06,582",
        "text": "Как только мы захватим контроль над этим захолустьем, все, у кого есть хоть капля таланта, исчезнут."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:09,208 --> 00:09:11,082",
        "text": "Это не совпадение."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:11,083 --> 00:09:13,416",
        "text": "Наши инстинкты были верны."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:14,083 --> 00:09:15,458",
        "text": "Они боятся хекстека."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:16,208 --> 00:09:17,583",
        "text": "Но мы слишком медлили."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:18,583 --> 00:09:21,541",
        "text": "Как же я могла не защитить ученых?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:25,250 --> 00:09:27,708",
        "text": "У них моя дочь, Риктус."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:30,875 --> 00:09:32,458",
        "text": "Наш момент настанет."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:33,125 --> 00:09:34,916",
        "text": "Но вы должны быть готовы."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:38,708 --> 00:09:40,290",
        "text": "Чтобы ускорить процесс, все сумки должны быть открыты и готовы к осмотру."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:47,125 --> 00:09:49,915",
        "text": "Офицеры просят вас о сотрудничестве и соблюдении требований, поскольку предпринимаются все усилия для обеспечения безопасности Пилтовера."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:09:54,541 --> 00:09:56,000",
        "text": "Следующий. Двигайтесь дальше."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:12,083 --> 00:10:13,374",
        "text": "Чтобы ускорить процесс..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:13,375 --> 00:10:15,749",
        "text": "Вы должны поблагодарить за это Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:15,750 --> 00:10:17,916",
        "text": "Она вам не друг."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:18,458 --> 00:10:20,415",
        "text": "Она не ваш чемпион."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:20,416 --> 00:10:22,040",
        "text": "Она прячется, пока вы страдаете."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:23,500 --> 00:10:26,457",
        "text": "И всё же вы отказываетесь выдать ее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:26,458 --> 00:10:29,541",
        "text": "Безопасность всех граждан..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:10:54,250 --> 00:10:55,125",
        "text": "Вперед."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:06,000 --> 00:11:06,916",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:15,125 --> 00:11:15,958",
        "text": "Ты права."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:16,666 --> 00:11:17,500",
        "text": "Это ее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:18,083 --> 00:11:19,790",
        "text": "Я бы узнала это где угодно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:19,791 --> 00:11:21,915",
        "text": "На этом сходство заканчивается."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:21,916 --> 00:11:24,250",
        "text": "Никакого подсчета трупов. Никакого спектакля."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:25,083 --> 00:11:26,875",
        "text": "Думаешь, это подражатель?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:27,833 --> 00:11:30,833",
        "text": "Думаю, мы заставили их отчаянно искать что-то, во что можно верить."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:34,750 --> 00:11:37,957",
        "text": "Это не меняет того, о чём мы говорили сегодня утром. Ты всё еще можешь..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:37,958 --> 00:11:39,166",
        "text": "Офицер Нолен."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:40,291 --> 00:11:42,583",
        "text": "Довольно известное нынче лицо."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:43,333 --> 00:11:44,290",
        "text": "Генерал."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:44,291 --> 00:11:46,666",
        "text": "Я хотела бы поговорить с командиром Кирамман."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:47,208 --> 00:11:48,416",
        "text": "Наедине."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:11:56,250 --> 00:11:58,374",
        "text": "Полагаю, мне не нужно рассказывать вам об опасности служебных связей."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:01,250 --> 00:12:04,541",
        "text": "Вы ведь пришли не ради этого."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:05,541 --> 00:12:08,499",
        "text": "Несомненно, новость о возвращении Джинкс вызовет сопротивление заунитов."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:10,958 --> 00:12:12,957",
        "text": "Но это палка о двух концах."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:12,958 --> 00:12:14,332",
        "text": "Есть путь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:14,333 --> 00:12:15,541",
        "text": "Мы взяли ее след."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:18,666 --> 00:12:21,499",
        "text": "Я ожидала, что такое развитие событий тебя воодушевит."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:21,500 --> 00:12:26,000",
        "text": "Это ради моего воодушевления ваш Риктус подстрекал к насилию?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:26,958 --> 00:12:28,541",
        "text": "Ты мне не доверяешь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:29,375 --> 00:12:31,166",
        "text": "«Палка о двух концах»."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:32,458 --> 00:12:34,332",
        "text": "Бесстрашное дитя."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:34,333 --> 00:12:36,083",
        "text": "Ты никогда не робеешь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:38,833 --> 00:12:40,375",
        "text": "У вас есть совет?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:41,833 --> 00:12:44,915",
        "text": "Раз на пропускном пункте была не Джинкс, то кто-то из них знает, где она."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:47,041 --> 00:12:49,082",
        "text": "Для ареста нужна причина."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:49,083 --> 00:12:53,666",
        "text": "Какая причина важнее, чем вернуть мир в этот город?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:12:55,125 --> 00:12:58,416",
        "text": "Почему мир всегда служит оправданием насилия?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:12,208 --> 00:13:14,041",
        "text": "Мы потеряли многих."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:14,583 --> 00:13:16,791",
        "text": "Гнев, горе..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:17,541 --> 00:13:18,374",
        "text": "Это изматывает."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:18,375 --> 00:13:20,666",
        "text": "Боги, я знаю, как это утомительно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:21,541 --> 00:13:25,916",
        "text": "Но ты не сможешь обрести покой, зная, что она где-то рядом."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:27,708 --> 00:13:30,625",
        "text": "А может, я тебя недооценила."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:31,375 --> 00:13:33,666",
        "text": "Может, у тебя есть сила, которой нет у меня."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:34,416 --> 00:13:35,583",
        "text": "Чтобы простить и поверить в завтрашний день."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:39,958 --> 00:13:43,666",
        "text": "Решение за тобой, командир."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:50,541 --> 00:13:54,208",
        "text": "Я устраивал самые пышные торжества в городе."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:13:57,458 --> 00:14:00,790",
        "text": "Попасть в список моих гостей было показателем статуса."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:00,791 --> 00:14:02,333",
        "text": "Местная знаменитость."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:03,166 --> 00:14:07,124",
        "text": "Теперь люди отводят взгляд, когда я прохожу мимо."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:07,125 --> 00:14:08,415",
        "text": "Я не отвожу взгляд."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:08,416 --> 00:14:10,249",
        "text": "О, пощади меня."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:10,250 --> 00:14:11,665",
        "text": "Я нанял тебя, потому что ты мастерски умеешь потакать самолюбию своих клиентов."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:15,541 --> 00:14:19,332",
        "text": "К тому же ты один из немногих советников со старых времен, верно?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:19,333 --> 00:14:22,832",
        "text": "О младшей Медарде так ничего и не узнали?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:22,833 --> 00:14:26,207",
        "text": "Даже когда ее здесь нет, все только о ней и говорят."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:26,208 --> 00:14:27,332",
        "text": "Я понял."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:27,333 --> 00:14:30,249",
        "text": "Она – последняя наследница великих Медард."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:30,250 --> 00:14:32,124",
        "text": "Будущее предопределено."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:32,125 --> 00:14:35,750",
        "text": "Когда пропадаешь надолго, уже не вернешься."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:36,916 --> 00:14:38,499",
        "text": "В это же время на будущей неделе?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:38,500 --> 00:14:39,541",
        "text": "Завтра."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:40,541 --> 00:14:42,708",
        "text": "Действие ослабевает."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:44,875 --> 00:14:48,915",
        "text": "Я постоянно слышу об этом целителе в расщелинах, на задворках."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:51,125 --> 00:14:53,375",
        "text": "Говорят, он творит чудеса."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:54,000 --> 00:14:55,332",
        "text": "Я видела одно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:55,333 --> 00:14:57,790",
        "text": "Такого я еще не встречала."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:14:57,791 --> 00:15:00,291",
        "text": "Посмотреть не повредит, не так ли?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:14,833 --> 00:15:16,499",
        "text": "Могла бы предупредить меня."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:16,500 --> 00:15:19,040",
        "text": "Разбежался! О чём?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:19,041 --> 00:15:20,832",
        "text": "О твоей выходке на пропускном пункте."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:20,833 --> 00:15:22,750",
        "text": "Понятия не имею, о чём ты болтаешь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:23,333 --> 00:15:24,583",
        "text": "Это не ты?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:29,916 --> 00:15:31,290",
        "text": "Как бы то ни было, весь подземный город гудит, говоря, что ты вернулась."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:35,000 --> 00:15:37,082",
        "text": "Так что думаю... Это не твоя сильная сторона."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:37,083 --> 00:15:40,166",
        "text": "Если бы ты появилась, всё изменилось бы к лучшему."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:41,166 --> 00:15:42,166",
        "text": "Ты – символ."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:42,958 --> 00:15:44,166",
        "text": "Тебе нужен символ?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:48,916 --> 00:15:52,874",
        "text": "Силко всю жизнь пытался сплотить подземный город."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:52,875 --> 00:15:54,790",
        "text": "Как это ни смешно, но у тебя есть шанс это сделать."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:15:57,833 --> 00:16:01,375",
        "text": "Я же сказала, мне это неинтересно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:02,208 --> 00:16:05,165",
        "text": "Знаешь ли ты, скольким он пожертвовал, чтобы защитить тебя?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:05,166 --> 00:16:06,665",
        "text": "Он верил в твой потенциал."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:06,666 --> 00:16:08,583",
        "text": "Тогда он не должен был умирать."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:11,541 --> 00:16:13,582",
        "text": "Сегодня у нас будет сходка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:13,583 --> 00:16:14,915",
        "text": "У статуи Вандера."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:14,916 --> 00:16:17,415",
        "text": "Поджигатели, твои фанаты."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:17,416 --> 00:16:20,040",
        "text": "Все, кого я могу предложить."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:20,041 --> 00:16:22,165",
        "text": "Засунь голову в песок, если хочешь, но эта иллюзия, в которой ты здесь живешь, не будет длиться вечно."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:30,291 --> 00:16:32,208",
        "text": "Не споткнись на выходе."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:33,708 --> 00:16:35,625",
        "text": "Не знаю, как ты это терпишь, мелочь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:41,666 --> 00:16:43,458",
        "text": "Мне нужно кое-кого навестить."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:55,333 --> 00:16:57,833",
        "text": "Всё еще хранишь молчание?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:16:59,333 --> 00:17:01,124",
        "text": "Из-за тебя и Иши я теряю способность быстро реагировать."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:05,916 --> 00:17:07,750",
        "text": "Я, герой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:10,375 --> 00:17:12,375",
        "text": "Насколько здесь всё запущено?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:15,541 --> 00:17:17,207",
        "text": "Я знаю, что Сэйвика права."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:17,208 --> 00:17:20,125",
        "text": "И, возможно, я в долгу перед тобой из-за убийства и всего остального."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:23,541 --> 00:17:26,833",
        "text": "Но теперь у меня есть кое-кто."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:27,625 --> 00:17:30,415",
        "text": "Друг."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:30,416 --> 00:17:33,208",
        "text": "И я не хочу всё испортить."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:35,291 --> 00:17:37,500",
        "text": "Может, я была такой для тебя."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:43,208 --> 00:17:46,999",
        "text": "Если ты так хочешь, чтобы я играла в твою дурацкую революцию, скажи прямо сейчас или..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:50,708 --> 00:17:51,875",
        "text": "Я думаю, ты..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:53,250 --> 00:17:54,500",
        "text": "Тебя действительно нет."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:17:57,208 --> 00:17:59,708",
        "text": "И больше нет причин оставаться здесь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:10,750 --> 00:19:11,916",
        "text": "Статуя..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:25,666 --> 00:19:28,250",
        "text": "Статуя Вандера..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:49,291 --> 00:19:51,500",
        "text": "Не секрет, что у нас есть история."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:52,708 --> 00:19:54,833",
        "text": "Кровь пролилась со всех сторон."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:55,541 --> 00:19:57,916",
        "text": "Но мы выросли на одних и тех же улицах."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:19:58,791 --> 00:20:00,833",
        "text": "Ели одни и те же объедки."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:01,708 --> 00:20:04,874",
        "text": "Нравится нам это или нет, но мы вместе в этой передряге."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:04,875 --> 00:20:07,540",
        "text": "Миротворцы совершают набеги на наши дома."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:07,541 --> 00:20:10,040",
        "text": "Ноксианцы впиваются в наши глотки."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:10,041 --> 00:20:13,250",
        "text": "Невинных увозят в Тихий омут."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:14,416 --> 00:20:18,665",
        "text": "Нужно выбрать прямо сейчас: бросить ли всё на произвол судьбы или бороться вместе."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:21,375 --> 00:20:23,040",
        "text": "Не как Поджигатели или последователи Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:24,625 --> 00:20:26,499",
        "text": "Или отъявленные головорезы."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:26,500 --> 00:20:28,540",
        "text": "Как зауниты. Мы хотим видеть Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:28,541 --> 00:20:30,041",
        "text": "Где Джинкс?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:31,625 --> 00:20:32,665",
        "text": "Где она?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:32,666 --> 00:20:34,415",
        "text": "Мы хотим видеть Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:34,416 --> 00:20:35,665",
        "text": "Да, где она?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:20:35,666 --> 00:20:37,708",
        "text": "Да! Где Джинкс?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:21:17,583 --> 00:21:19,291",
        "text": "Вы все арестованы."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:21:58,541 --> 00:22:00,125",
        "text": "Опусти клинок. Брось его."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:00,958 --> 00:22:02,833",
        "text": "Брось клинок."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:37,500 --> 00:22:38,583",
        "text": "Я вернулась."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:39,125 --> 00:22:41,791",
        "text": "Пора выяснить, кто же станет новым обладателем «камешка»..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:43,416 --> 00:22:44,500",
        "text": "Иша?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:46,416 --> 00:22:49,207",
        "text": "Ладно, я поняла."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:49,208 --> 00:22:51,041",
        "text": "Мы играем в другую игру, да?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:57,750 --> 00:22:58,625",
        "text": "Иша?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:22:59,208 --> 00:23:00,208",
        "text": "Они схватили ее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:01,083 --> 00:23:02,207",
        "text": "Что?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:02,208 --> 00:23:03,791",
        "text": "Она пришла на сходку."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:04,333 --> 00:23:06,124",
        "text": "Верхние устроили облаву."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:06,125 --> 00:23:07,958",
        "text": "Забрали всех."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:10,458 --> 00:23:11,832",
        "text": "Ты знаешь, кто ты."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:11,833 --> 00:23:12,999",
        "text": "Черт возьми, Паудер."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:13,000 --> 00:23:16,625",
        "text": "Заткнись. Заткнись."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:17,250 --> 00:23:18,750",
        "text": "Перестань меня так называть."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:20,375 --> 00:23:22,374",
        "text": "Ее зовут Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:22,375 --> 00:23:23,666",
        "text": "Она моя сестра."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:24,541 --> 00:23:27,207",
        "text": "Джинкс. Ты должна быть кем-то другим."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:27,208 --> 00:23:28,333",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:29,291 --> 00:23:31,291",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:55,750 --> 00:23:57,291",
        "text": "Подними голову, малютка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:23:58,250 --> 00:23:59,625",
        "text": "Я открою тебе секрет."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:24:00,791 --> 00:24:02,416",
        "text": "Мы не останемся надолго."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:24:38,708 --> 00:24:42,000",
        "text": "Левша, полагаю, плавать ты не умеешь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:24:43,166 --> 00:24:46,125",
        "text": "Что ж, остается только веселый вариант."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:24:47,666 --> 00:24:49,541",
        "text": "Мне это не понравится, да?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:03,000 --> 00:25:03,832",
        "text": "Это я."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:03,833 --> 00:25:05,207",
        "text": "Ваша мерзкая злодейка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:05,208 --> 00:25:07,290",
        "text": "Создатель ваших кошмаров."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:07,291 --> 00:25:08,874",
        "text": "Ужас ваших..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:08,875 --> 00:25:10,333",
        "text": "Кто вы?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:14,083 --> 00:25:15,124",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:15,125 --> 00:25:17,707",
        "text": "Первый раз слышу."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:17,708 --> 00:25:20,082",
        "text": "Ты не схватишь меня?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:20,083 --> 00:25:22,124",
        "text": "Чтобы получить награду, стать героем."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:22,125 --> 00:25:25,915",
        "text": "Думаешь, я поверю, что Джинкс, главная преступница, носит такие штаны?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:28,291 --> 00:25:29,790",
        "text": "Что не так с моими штанами?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:29,791 --> 00:25:32,208",
        "text": "Ты похожа на полуразрушенный цирковой шатер."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:35,291 --> 00:25:37,000",
        "text": "Я – Джинкс."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:53,666 --> 00:25:54,625",
        "text": "«Полуразрушенный»."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:25:55,916 --> 00:25:57,333",
        "text": "Мы можем сосредоточиться?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:26:13,708 --> 00:26:14,541",
        "text": "Пошли."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:26:16,375 --> 00:26:17,999",
        "text": "Большая мамочка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:26:18,000 --> 00:26:19,540",
        "text": "Как ты ее взял?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:26:19,541 --> 00:26:23,375",
        "text": "Я дал ей выбор между этим и купанием в гавани."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:27:02,750 --> 00:27:04,708",
        "text": "Блок «С». Продолжайте, офицер."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:27:06,583 --> 00:27:07,915",
        "text": "Да, сэр."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:27:07,916 --> 00:27:08,833",
        "text": "Вперед."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:28:06,083 --> 00:28:07,875",
        "text": "Давай же. У меня ребенок."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:28:08,416 --> 00:28:09,958",
        "text": "Вы не можете держать нас здесь."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:28:42,958 --> 00:28:44,582",
        "text": "А вот и я, главный герой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:31:12,875 --> 00:31:15,833",
        "text": "Ты опоздала на великое возмездие Вонючки."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:32:08,708 --> 00:32:10,333",
        "text": "Что это было, черт возьми?"
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:32:11,250 --> 00:32:12,083",
        "text": "Шевелись."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:32:17,916 --> 00:32:18,875",
        "text": "Стоять."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:33:20,041 --> 00:33:21,041",
        "text": "Уведи ее."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:33:25,833 --> 00:33:26,707",
        "text": "Ты действительно..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:33:26,708 --> 00:33:28,958",
        "text": "Главный герой."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:34:54,166 --> 00:34:56,458",
        "text": "Ты меня поймал, волосатик."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:34:57,333 --> 00:34:59,500",
        "text": "Но запомни..."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:35:00,708 --> 00:35:02,416",
        "text": "ты не Вонючка."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:35:03,875 --> 00:35:04,916",
        "text": "Улыбнись."
    },
    {
        "season": 2,
        "episode": 4,
        "time_code": "00:35:51,500 --> 00:35:52,875",
        "text": "Паудер?"
    }
]