[
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:08,541 --> 00:01:10,583",
        "text": "Так и знала, что нельзя было тебе доверять."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:10,666 --> 00:01:12,250",
        "text": "Ты сама не подарок, знаешь ли."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:12,333 --> 00:01:15,083",
        "text": "Не по моей вине мы дважды угодили в ловушки Силко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:17,000 --> 00:01:19,416",
        "text": "Это не Силко, а кто-то другой."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:19,500 --> 00:01:22,041",
        "text": "С чего ты взяла? С того, что мы еще живы."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:22,125 --> 00:01:23,416",
        "text": "Отлично."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:23,500 --> 00:01:26,125",
        "text": "А когда ты собиралась сказать, что твоя чокнутая сестрица работает на него?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:26,208 --> 00:01:27,500",
        "text": "Как только ты призналась бы, что на самом деле здесь ищешь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:29,041 --> 00:01:32,166",
        "text": "Я сказала правду. Чушь. Что это за светящийся камень?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:34,333 --> 00:01:35,708",
        "text": "Так я и думала."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:39,625 --> 00:01:42,166",
        "text": "Что происходит? Эй, а ну, уберите руки!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:42,250 --> 00:01:43,750",
        "text": "Не трогайте ее! Отпустите!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:43,833 --> 00:01:46,291",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:47,291 --> 00:01:48,291",
        "text": "Вай!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:01:54,875 --> 00:01:57,208",
        "text": "ВАЙ Стесняешься? Или просто рожа страшная?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:02:37,291 --> 00:02:38,916",
        "text": "Неплохо выглядишь для покойницы."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:03:48,500 --> 00:03:49,583",
        "text": "Экко?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:03:53,416 --> 00:03:54,916",
        "text": "Что ты знаешь об этой штуке?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:03:57,000 --> 00:03:59,541",
        "text": "Ничего. Что происходит?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:00,458 --> 00:04:02,208",
        "text": "Что ты делала с Джинкс?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:02,291 --> 00:04:03,541",
        "text": "Ее зовут Паудер."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:03,625 --> 00:04:06,500",
        "text": "И я только нашла ее, когда явился ты со своими головорезами."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:07,500 --> 00:04:09,458",
        "text": "Это же я. Вай."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:09,541 --> 00:04:11,166",
        "text": "Мы шатались вместе по свалкам, а потом я отмывала тебя из шланга."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:15,291 --> 00:04:16,750",
        "text": "Это было давно."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:17,625 --> 00:04:18,708",
        "text": "Люди меняются."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:18,791 --> 00:04:20,708",
        "text": "Да уж. Я заметила."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:22,125 --> 00:04:23,750",
        "text": "Ты работаешь на Силко?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:25,083 --> 00:04:26,583",
        "text": "Да пошел ты."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:26,666 --> 00:04:28,125",
        "text": "Я думал, ты умерла."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:28,208 --> 00:04:31,041",
        "text": "И вдруг вижу, как ты гуляешь по Линиям с пилтошкой."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:31,125 --> 00:04:33,916",
        "text": "Ты следил за нами? Почему ничего не сказал?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:34,000 --> 00:04:35,416",
        "text": "Не знал, могу ли тебе доверять."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:35,500 --> 00:04:38,541",
        "text": "Поэтому решил просто напасть?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:39,125 --> 00:04:40,916",
        "text": "Как думаешь, у кого я этому научился?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:41,000 --> 00:04:44,083",
        "text": "Мог бы учиться получше. Так и не можешь нормально ударить."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:44,166 --> 00:04:46,125",
        "text": "А ты так и не защищаешь лицо."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:49,041 --> 00:04:51,125",
        "text": "Раньше ты боялся со мной спорить."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:54,791 --> 00:04:56,416",
        "text": "Я скучала по тебе, Коротышка."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:04:58,541 --> 00:05:00,166",
        "text": "И давно у тебя руки свободны?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:01,166 --> 00:05:02,750",
        "text": "А ты давно такой нытик?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:10,166 --> 00:05:11,250",
        "text": "Как интересно."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:14,625 --> 00:05:16,916",
        "text": "Я бы очень хотел увидеть это устройство."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:18,458 --> 00:05:20,458",
        "text": "Это хекстековое ядро."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:21,041 --> 00:05:23,750",
        "text": "Это не так просто."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:26,250 --> 00:05:28,916",
        "text": "Я перепробовал все комбинации рун, но… Результат всегда один."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:31,291 --> 00:05:35,166",
        "text": "Объект чахнет и погибает."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:35,250 --> 00:05:38,583",
        "text": "Тогда, может, проблема не в рассчетах, а в объектах."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:41,541 --> 00:05:44,041",
        "text": "Природа сделала нас нетерпимыми к изменениям."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:44,125 --> 00:05:48,666",
        "text": "Но, к счастью, мы можем изменить свою природу."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:49,333 --> 00:05:51,625",
        "text": "Это мерцание?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:51,708 --> 00:05:53,041",
        "text": "Его разновидность."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:53,125 --> 00:05:56,916",
        "text": "С ней можно пережить радикальное преобразование."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:57,458 --> 00:05:58,875",
        "text": "Оно подействует на растения?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:05:59,500 --> 00:06:02,250",
        "text": "Тебя ведь не растения интересуют, правда?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:03,250 --> 00:06:05,625",
        "text": "Я знаю этот взгляд обреченного."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:06,833 --> 00:06:08,291",
        "text": "Должен тебя предупредить."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:09,166 --> 00:06:12,250",
        "text": "Если выберешь этот путь, все от тебя отвернутся."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:13,250 --> 00:06:17,500",
        "text": "Любовь и признание придется принести в жертву прогрессу."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:18,750 --> 00:06:21,458",
        "text": "Поэтому наши с Хеймердингером пути разошлись."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:06:26,166 --> 00:06:29,625",
        "text": "Джейс поймет. Наверное."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:03,666 --> 00:07:06,166",
        "text": "Работа молотом - тонкое искусство."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:06,250 --> 00:07:07,416",
        "text": "Как ты меня нашла?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:07,500 --> 00:07:10,916",
        "text": "Ты фактически глава совета, а значит, всегда на виду."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:11,750 --> 00:07:13,125",
        "text": "Не напоминай."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:13,208 --> 00:07:15,625",
        "text": "Закрытие границ взволновало людей."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:15,708 --> 00:07:17,083",
        "text": "И правильно."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:19,125 --> 00:07:21,875",
        "text": "Маркус мне принес. Это взрывчатка."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:22,416 --> 00:07:24,333",
        "text": "Я попытался ее разобрать и чуть не погиб."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:24,416 --> 00:07:26,583",
        "text": "Ее сделал настоящий мастер."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:27,416 --> 00:07:29,125",
        "text": "Так же как и мерцание."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:29,208 --> 00:07:31,041",
        "text": "Невероятно, на что они способны."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:35,958 --> 00:07:38,000",
        "text": "Тебя только это беспокоит?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:39,958 --> 00:07:43,250",
        "text": "Он был моим наставником, Мэл. А я его предал."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:45,958 --> 00:07:48,916",
        "text": "Всё, что ты сказал о нём, правда."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:49,000 --> 00:07:52,750",
        "text": "Родные от меня отреклись, но в глубине души я всё равно их люблю."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:53,750 --> 00:07:56,166",
        "text": "Хеймердингер рано или поздно поймет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:07:56,916 --> 00:08:00,333",
        "text": "Твое время пришло, Джейс. Хватит бюрократии."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:00,416 --> 00:08:04,250",
        "text": "Ты можешь подарить хекстек народу, как всегда мечтал."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:08,000 --> 00:08:09,791",
        "text": "Сначала я должен спасти Виктора."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:09,875 --> 00:08:11,791",
        "text": "Где он? Я не знаю."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:13,083 --> 00:08:15,458",
        "text": "Пропадает где-то. Он иногда так делает."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:16,291 --> 00:08:18,541",
        "text": "И Кейтлин нигде нет. Дочери Кирамманов?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:18,625 --> 00:08:19,708",
        "text": "Просто… Неважно."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:22,208 --> 00:08:24,541",
        "text": "Послушай. Мы справимся."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:25,875 --> 00:08:28,125",
        "text": "Я успокою совет, но скоро ты им понадобишься."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:28,750 --> 00:08:30,125",
        "text": "А пока постарайся не терять голову."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:46,291 --> 00:08:48,041",
        "text": "Весь бизнес встал."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:48,125 --> 00:08:51,500",
        "text": "Миротворцы обыскивают всех, кто пересекает мост."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:51,583 --> 00:08:55,833",
        "text": "Маркус делает, что я ему велел: следит, чтобы Вай и Кейтлин не вернулись."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:08:55,916 --> 00:08:57,458",
        "text": "Или он сорвался с крючка."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:03,333 --> 00:09:05,583",
        "text": "Химбароны созывают собрание."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:08,541 --> 00:09:12,041",
        "text": "Мне и так проблем хватает. Не думаю, что у нас есть выбор."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:17,916 --> 00:09:20,166",
        "text": "Куда вы? Мне надо найти Джинкс."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:20,250 --> 00:09:22,291",
        "text": "Постойте. Что еще?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:22,375 --> 00:09:24,833",
        "text": "Я быстрее найду общий язык с блохами, чем с Джинкс."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:26,250 --> 00:09:31,250",
        "text": "Просто… Мы с отцом тоже не всегда ладили."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:33,125 --> 00:09:34,250",
        "text": "И?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:35,458 --> 00:09:38,208",
        "text": "Она сама придет к вам, когда будет готова."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:09:58,083 --> 00:10:00,125",
        "text": "Ты ее потеряла."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:00,750 --> 00:10:03,583",
        "text": "Я ее не теряла! Они ее забрали."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:03,666 --> 00:10:06,666",
        "text": "Ей важнее эта миротворица, ты сама видела."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:08,583 --> 00:10:11,958",
        "text": "Она пришла за мной! Не за ней!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:12,041 --> 00:10:13,541",
        "text": "- Вспомни. Помнишь ее имя?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:13,625 --> 00:10:15,625",
        "text": "Зачем мне его помнить?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:18,291 --> 00:10:20,458",
        "text": "Это просто какая-то дура из верхнего города."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:10:34,458 --> 00:10:35,833",
        "text": "Кейтлин."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:04,500 --> 00:11:06,208",
        "text": "Давай. Погнали!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:08,416 --> 00:11:09,666",
        "text": "Попался."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:12,000 --> 00:11:15,041",
        "text": "Это настоящее дерево? Круто, да?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:15,125 --> 00:11:17,500",
        "text": "Увидел его - и сразу понял, что это подходящее место."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:18,000 --> 00:11:20,958",
        "text": "Если одно семечко смогло здесь выжить, то и мы сможем."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:21,833 --> 00:11:23,083",
        "text": "Ты всё это построил?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:23,750 --> 00:11:24,750",
        "text": "Не в одиночку."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:25,333 --> 00:11:26,500",
        "text": "Когда Вандер… …умер, Силко все Линии заполнил мерцанием."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:32,541 --> 00:11:34,500",
        "text": "Ему было плевать, что оно делало с людьми."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:35,166 --> 00:11:37,041",
        "text": "Все здесь или пострадали из-за него, или подсели на дурь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:38,041 --> 00:11:39,333",
        "text": "Привет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:39,416 --> 00:11:41,500",
        "text": "Им нужно было место, чтобы начать жизнь заново."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:42,500 --> 00:11:44,000",
        "text": "Да ладно вам!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:44,083 --> 00:11:48,125",
        "text": "А меня не было рядом, чтобы помочь тебе. Всем."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:48,208 --> 00:11:50,250",
        "text": "Если так себя изводить - можно сойти с ума."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:51,458 --> 00:11:55,750",
        "text": "Может, если б я тогда пошел с вами, ничего бы не случилось."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:11:55,833 --> 00:12:00,208",
        "text": "А может, ты бы умер. Или изменился."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:00,291 --> 00:12:02,875",
        "text": "Паудер больше нет, Вай. Осталась только Джинкс."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:02,958 --> 00:12:04,875",
        "text": "И она на стороне Силко. Ошибаешься!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:04,958 --> 00:12:07,333",
        "text": "Она всё еще Паудер. Я до нее достучусь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:07,416 --> 00:12:08,583",
        "text": "Не можешь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:11,416 --> 00:12:12,916",
        "text": "Я знаю свою сестру."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:16,125 --> 00:12:17,833",
        "text": "Я хочу еще кое-что тебе показать."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:29,833 --> 00:12:32,500",
        "text": "Здесь все, кого мы потеряли."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:34,833 --> 00:12:36,375",
        "text": "Цена нашей свободы."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:37,291 --> 00:12:38,791",
        "text": "Кто-то погиб от рук миротворцев."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:39,583 --> 00:12:41,041",
        "text": "Большинство убил Силко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:42,708 --> 00:12:45,291",
        "text": "Твоя сестра работает на него не потому, что должна, а потому, что хочет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:12:47,750 --> 00:12:49,666",
        "text": "Мне жаль, но она уже не та."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:05,250 --> 00:13:06,083",
        "text": "Спокойно!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:06,166 --> 00:13:08,208",
        "text": "Пропустите! Скорее!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:16,208 --> 00:13:17,666",
        "text": "Мы поняли."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:17,750 --> 00:13:18,958",
        "text": "Не наседайте!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:20,166 --> 00:13:23,416",
        "text": "Спасибо, что сообщили, шериф. Не за что, советник."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:24,625 --> 00:13:26,416",
        "text": "Джейс, что происходит?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:28,458 --> 00:13:30,541",
        "text": "Ты хоть понимаешь, как это выглядит?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:30,625 --> 00:13:33,125",
        "text": "Я приказал перекрыть мост, а моему партнеру наплевать."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:34,541 --> 00:13:37,416",
        "text": "Это ты приказал? Зачем?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:37,500 --> 00:13:40,750",
        "text": "Кто-то там, внизу, одержим идеей уничтожить нас."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:40,833 --> 00:13:41,916",
        "text": "Что ты там делал?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:42,541 --> 00:13:45,333",
        "text": "Я ходил посоветоваться с другом по поводу нашей проблемы."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:45,416 --> 00:13:47,041",
        "text": "Я же говорил, что знаю подходящего человека."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:47,125 --> 00:13:49,250",
        "text": "Но ты не говорил, что он из нижнего города!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:49,333 --> 00:13:51,000",
        "text": "Какая разница?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:51,083 --> 00:13:53,250",
        "text": "Разница? Да там одни отморозки!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:13:54,375 --> 00:13:57,166",
        "text": "Я тоже из нижнего города. Точно… Прости. На меня столько свалилось."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:02,583 --> 00:14:04,000",
        "text": "Твой друг смог тебе помочь?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:05,583 --> 00:14:06,791",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:06,875 --> 00:14:10,625",
        "text": "Он сказал: «Природа не приемлет такого вмешательства»."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:11,375 --> 00:14:13,041",
        "text": "Ладно, будем искать другие решения."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:17,583 --> 00:14:20,500",
        "text": "Вперед! Давайте, парни! Покажем им!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:21,375 --> 00:14:22,833",
        "text": "Получай, засранец!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:34,250 --> 00:14:38,000",
        "text": "Сначала эта бойня прямо в центре Пилтовера."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:38,083 --> 00:14:39,958",
        "text": "Теперь закрытие границ."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:40,708 --> 00:14:43,208",
        "text": "Мы теряем деньги, и ради чего?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:43,291 --> 00:14:48,000",
        "text": "Ради его мечты о восстании? Он теряет хватку."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:48,083 --> 00:14:49,416",
        "text": "Если мы объединимся… Мы не планировали собрание."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:56,875 --> 00:14:58,666",
        "text": "А стоило бы."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:14:58,750 --> 00:15:02,416",
        "text": "После твоей выходки в верхнем городе прибыль стала падать."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:02,500 --> 00:15:03,416",
        "text": "Это правда."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:03,500 --> 00:15:07,833",
        "text": "Товар застрял на границе. Верхние боятся переходить мост."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:07,916 --> 00:15:11,791",
        "text": "Нам всем интересно: что ты собираешься с этим делать?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:13,875 --> 00:15:16,083",
        "text": "Всем интересно, значит?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:18,958 --> 00:15:22,500",
        "text": "По мне - надо договориться с ними и вернуть самоцвет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:23,083 --> 00:15:25,708",
        "text": "Лучше торговать хоть как-то, чем никак."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:27,708 --> 00:15:31,083",
        "text": "Проблема с границей временная. Джинкс ее решит."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:33,416 --> 00:15:36,000",
        "text": "Говорят, она сорвалась с цепи."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:36,750 --> 00:15:40,875",
        "text": "Как ты намерен подчинить себе Пилтовер, если не контролируешь своих же людей?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:54,875 --> 00:15:55,833",
        "text": "Что это?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:15:58,625 --> 00:16:01,583",
        "text": "Как, не узнаёте?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:03,916 --> 00:16:05,875",
        "text": "Забыли, откуда мы все пришли?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:07,083 --> 00:16:08,833",
        "text": "Шахты, в которых они нас держали."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:10,833 --> 00:16:13,125",
        "text": "Где густой смог забивает горло."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:15,125 --> 00:16:16,791",
        "text": "Слепит глаза."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:18,583 --> 00:16:21,833",
        "text": "Но я вытащил вас всех оттуда."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:21,916 --> 00:16:24,583",
        "text": "Подарил свободу верхнего города."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:26,541 --> 00:16:27,791",
        "text": "И свежий воздух."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:30,916 --> 00:16:32,666",
        "text": "Я дал вам жизнь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:33,250 --> 00:16:34,291",
        "text": "Цель."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:37,958 --> 00:16:40,666",
        "text": "А вы отожрались и обнаглели."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:42,708 --> 00:16:44,958",
        "text": "Слишком долго пробыли на солнце."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:16:55,708 --> 00:17:00,833",
        "text": "Мы пришли оттуда, где на всех не хватало ничего, Финн."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:04,416 --> 00:17:05,958",
        "text": "Поэтому мы боремся."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:06,583 --> 00:17:08,208",
        "text": "Помнишь?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:09,208 --> 00:17:13,750",
        "text": "Ладно. Прости. Пожалуйста!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:16,166 --> 00:17:17,500",
        "text": "Пожалуйста!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:24,458 --> 00:17:25,833",
        "text": "Больше не забывай."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:17:39,125 --> 00:17:40,625",
        "text": "Всем спасибо."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:03,375 --> 00:18:05,375",
        "text": "Я получила сообщение от друзей за границей."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:06,416 --> 00:18:09,166",
        "text": "Проблемы с нижним городом привлекают внимание."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:11,666 --> 00:18:13,375",
        "text": "Пилтовер выглядит уязвимым."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:15,916 --> 00:18:18,916",
        "text": "Слишком рано. Джейс еще не готов."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:23,708 --> 00:18:26,041",
        "text": "Еще кое-что."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:18:27,166 --> 00:18:28,791",
        "text": "Тебе пришло это."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:07,333 --> 00:19:09,208",
        "text": "Что вы сделали с Вай?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:12,375 --> 00:19:17,000",
        "text": "Слушай, отпусти ее. Это я ее привела. Вам нужна я."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:18,208 --> 00:19:20,000",
        "text": "Моя спасительница. Ты… Я думала, ты… Я думала, они тебя пытают!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:24,958 --> 00:19:26,833",
        "text": "Вай говорит, тебе можно доверять."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:27,708 --> 00:19:30,875",
        "text": "Я отпущу тебя обратно наверх, и всё. Пошли."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:43,083 --> 00:19:44,958",
        "text": "Давай помогу."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:46,375 --> 00:19:47,750",
        "text": "Где ты была, Джинкс?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:48,750 --> 00:19:54,541",
        "text": "Да так. То тут, то там. Гонялась за призраками."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:54,625 --> 00:19:58,916",
        "text": "Но представляешь! Оказывается, кое-кто из них живой!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:19:59,000 --> 00:20:00,333",
        "text": "Я всё объясню."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:01,166 --> 00:20:04,833",
        "text": "Не шевелись, дурачок. Я же могу тебя поранить."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:05,583 --> 00:20:06,958",
        "text": "Я не знал."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:07,041 --> 00:20:09,666",
        "text": "Маркус не говорил, что она в тюрьме."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:10,708 --> 00:20:13,250",
        "text": "Но ты знал, что она вернулась."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:13,333 --> 00:20:14,875",
        "text": "Ты мне соврал."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:17,000 --> 00:20:19,708",
        "text": "Я хотел тебя защитить! От чего?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:19,791 --> 00:20:22,791",
        "text": "Она и эта миротворица вернулись за кристаллом."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:23,416 --> 00:20:25,000",
        "text": "Не за тобой."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:26,791 --> 00:20:28,791",
        "text": "Ты забыла, что она тебя бросила?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:29,416 --> 00:20:33,500",
        "text": "Кто тебя нашел? Кто заботился о тебе? Дал тебе дом?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:34,125 --> 00:20:38,750",
        "text": "Мы с тобой - семья. Остальные нас предали."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:41,708 --> 00:20:42,916",
        "text": "Ты мне нужна."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:44,125 --> 00:20:45,666",
        "text": "Больше, чем когда-либо."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:20:49,291 --> 00:20:51,333",
        "text": "Ты должна доделать оружие."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:14,083 --> 00:21:15,375",
        "text": "Здесь так красиво."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:16,041 --> 00:21:19,000",
        "text": "Если пустить сюда ваших, они камня на камне не оставят."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:19,708 --> 00:21:21,083",
        "text": "Это недоразумение."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:22,000 --> 00:21:23,666",
        "text": "Они думают, вы работаете на Силко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:23,750 --> 00:21:28,625",
        "text": "Ваши люди охотятся на нас, как на зверей. Силко им за это платит."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:29,625 --> 00:21:31,916",
        "text": "Не может быть. Ты ошибаешься."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:32,541 --> 00:21:34,750",
        "text": "Ну-ка повтори! Экко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:34,833 --> 00:21:37,916",
        "text": "Они верит в то, что говорит. Она тебе не враг."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:38,000 --> 00:21:40,000",
        "text": "Да? А это что?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:42,166 --> 00:21:44,958",
        "text": "Он у тебя. Нам нужно его вернуть."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:47,250 --> 00:21:50,458",
        "text": "Что это? Это самоцвет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:50,541 --> 00:21:53,666",
        "text": "Во время того происшествия его украли. Украла… твоя сестра."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:54,250 --> 00:21:56,458",
        "text": "И ты просто забыла мне об этом сказать?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:21:56,541 --> 00:21:59,791",
        "text": "С его помощью можно создать любое хекстековое устройство."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:02,958 --> 00:22:07,166",
        "text": "Именно поэтому миротворцы ведут себя так жестко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:08,791 --> 00:22:12,833",
        "text": "С ним мы могли бы победить Силко. Это ничего не решит."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:12,916 --> 00:22:16,375",
        "text": "Тебе легко говорить. Твои друзья не умирают у тебя на глазах."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:18,083 --> 00:22:21,416",
        "text": "Экко, с вами поступили ужасно."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:22,125 --> 00:22:24,500",
        "text": "Ты имеешь полное право оставить его себе."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:24,583 --> 00:22:26,166",
        "text": "Я тебя понимаю."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:28,166 --> 00:22:30,208",
        "text": "Но тогда насилие так и будет продолжаться, снова и снова."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:34,250 --> 00:22:37,083",
        "text": "Это наш шанс восстановить справедливость."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:37,666 --> 00:22:41,625",
        "text": "Этому городу нужен мир. Я даже не подозревала насколько."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:42,333 --> 00:22:44,625",
        "text": "Пожалуйста, позволь мне вам помочь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:47,708 --> 00:22:48,875",
        "text": "У тебя есть план?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:49,791 --> 00:22:54,000",
        "text": "У меня есть друг в совете. Позволь отнести самоцвет ему."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:22:55,875 --> 00:22:59,041",
        "text": "Он меня послушает. Вам больше не придется прятаться."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:01,291 --> 00:23:04,000",
        "text": "При одном условии. Я отнесу самоцвет сам."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:08,375 --> 00:23:10,333",
        "text": "Форма грубовата."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:10,416 --> 00:23:14,708",
        "text": "Но конструкция очень хитроумная."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:14,791 --> 00:23:16,541",
        "text": "Они смогут разобраться в хекстеке?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:18,500 --> 00:23:19,666",
        "text": "Не уверен."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:19,750 --> 00:23:24,541",
        "text": "Есть мнение, что они нашли способ использовать самоцвет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:24,625 --> 00:23:26,458",
        "text": "Если предположить худшее - они сделали из него оружие."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:28,541 --> 00:23:30,250",
        "text": "Но мы не знаем этого наверняка?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:30,958 --> 00:23:32,833",
        "text": "Мы не можем ждать, пока они нападут."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:33,750 --> 00:23:35,958",
        "text": "Подождите. Что вы предлагаете?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:38,166 --> 00:23:40,708",
        "text": "Мы должны подготовить ответные меры."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:41,291 --> 00:23:42,958",
        "text": "Хочешь, чтобы мы создали оружие?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:43,041 --> 00:23:47,041",
        "text": "Ни в коем случае. Мы изобрели хекстек не для этого."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:47,666 --> 00:23:50,750",
        "text": "Мы потеряем надежду на мирный исход. Хеймредингер бы не согласился."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:50,833 --> 00:23:53,125",
        "text": "Его бездействие и привело к кризису."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:53,208 --> 00:23:54,625",
        "text": "Ты сам говорил."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:55,750 --> 00:23:58,833",
        "text": "Мир уже невозможен, Джейс."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:23:58,916 --> 00:24:01,416",
        "text": "Я лишь прошу тебя защитить горожан."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:02,083 --> 00:24:04,291",
        "text": "Если повезет, твое оружие не понадобится."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:09,083 --> 00:24:10,500",
        "text": "Решать тебе."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:19,333 --> 00:24:22,791",
        "text": "Это безумие. Тут и думать нечего."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:23,708 --> 00:24:24,833",
        "text": "А если она права?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:24,916 --> 00:24:26,833",
        "text": "Будем сидеть и ждать нападения?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:26,916 --> 00:24:29,250",
        "text": "Мы ученые, а не солдаты."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:30,000 --> 00:24:32,125",
        "text": "Наши знания позволяют нам защищаться."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:32,208 --> 00:24:36,041",
        "text": "Мы создавали хекстек, чтобы улучшать жизни, а не отнимать их."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:36,125 --> 00:24:37,583",
        "text": "А если у нас нет выбора?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:54,208 --> 00:24:56,791",
        "text": "Выбор есть всегда."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:24:59,666 --> 00:25:00,958",
        "text": "Мне надо подумать."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:25:57,125 --> 00:25:58,458",
        "text": "Что это?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:25:58,541 --> 00:26:02,250",
        "text": "Жуки-поджигатели. Никогда раньше столько не видела."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:26:33,333 --> 00:26:36,208",
        "text": "Я боюсь, что мне придется сделать нечто немыслимое."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:03,541 --> 00:28:04,375",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:08,166 --> 00:28:09,708",
        "text": "Я не могу опять ее бросить."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:11,083 --> 00:28:12,291",
        "text": "Ты ее не изменишь."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:12,958 --> 00:28:14,416",
        "text": "Я должна попытаться."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:17,291 --> 00:28:19,041",
        "text": "Постарайся не умереть."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:20,833 --> 00:28:22,250",
        "text": "Как получится."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:29,708 --> 00:28:34,333",
        "text": "Было круто, кексик. Спасибо. За всё."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:43,000 --> 00:28:46,208",
        "text": "Заткнись. Они просто прощаются."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:28:47,458 --> 00:28:50,458",
        "text": "Она так не сделает. Только не опять."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:15,791 --> 00:29:17,041",
        "text": "Стоять."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:17,875 --> 00:29:19,291",
        "text": "Это что еще такое?"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:22,541 --> 00:29:26,583",
        "text": "Офицер! У меня есть доказательства. За всем стоит Силко."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:32,833 --> 00:29:33,916",
        "text": "Покажи."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:37,958 --> 00:29:38,958",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:29:42,541 --> 00:29:43,416",
        "text": "Проклятье!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:30:05,166 --> 00:30:06,041",
        "text": "Кейтлин!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:30:15,750 --> 00:30:16,791",
        "text": "Лгунья."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:30:18,958 --> 00:30:21,083",
        "text": "Я говорил тебе не лезть в это."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:32:02,791 --> 00:32:04,291",
        "text": "Скажи моей… Скажи… Скажи моей дочери, я… Уходите!"
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:33:38,583 --> 00:33:42,541",
        "text": "Смотрите, кто тут у нас. Мальчик-спаситель."
    },
    {
        "season": 1,
        "episode": 7,
        "time_code": "00:35:00,166 --> 00:35:01,625",
        "text": "Да!"
    }
]