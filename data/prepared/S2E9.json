[
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:38,041 --> 00:01:38,958",
        "text": "Подожди."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:41,958 --> 00:01:43,999",
        "text": "Я просто хочу поговорить с тобой."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:44,000 --> 00:01:45,457",
        "text": "Убирайся отсюда, Экко."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:45,458 --> 00:01:46,791",
        "text": "Я просто..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:51,458 --> 00:01:53,375",
        "text": "Я лишь хочу поговорить, Пау..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:01:54,166 --> 00:01:55,208",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:04,333 --> 00:02:06,250",
        "text": "Ты опоздал, Экко. Подожди."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:11,166 --> 00:02:12,583",
        "text": "С тобой всегда непросто."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:14,750 --> 00:02:17,208",
        "text": "Пожалуй, я просто посижу здесь минутку."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:18,208 --> 00:02:19,750",
        "text": "Переведу дух."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:21,333 --> 00:02:24,666",
        "text": "Попробую уговорить подругу не взрывать нас."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:31,708 --> 00:02:33,666",
        "text": "Я устала от разговоров. Нет."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:39,125 --> 00:02:40,958",
        "text": "Знаешь, кое-кто... очень особенный... научил меня, что независимо от прошлого никогда не поздно построить что-то новое."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:02:58,583 --> 00:03:00,375",
        "text": "Ради кого-то стоит это строить."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:04:14,458 --> 00:04:16,458",
        "text": "Аркейн Вы с Миротворцами должны выиграть как можно больше времени, чтобы я мог отключить Хексврата."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:04:55,500 --> 00:04:56,750",
        "text": "Это наш единственный шанс."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:05:02,166 --> 00:05:05,958",
        "text": "Виктор в центре всего этого, не так ли?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:05:18,250 --> 00:05:20,166",
        "text": "Нам суждено проиграть эту битву."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:05:22,291 --> 00:05:24,416",
        "text": "Если он доберется до Хексврат..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:05:43,125 --> 00:05:44,791",
        "text": "Тогда нам нужно остановить его."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:05:58,708 --> 00:05:59,708",
        "text": "Вперед, вперед."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:17,208 --> 00:06:20,582",
        "text": "Усильте артиллерию на передовой. Мы не можем позволить им прорваться."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:20,583 --> 00:06:21,791",
        "text": "Идите. Пошли."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:32,791 --> 00:06:34,000",
        "text": "Стоять. Вперед."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:45,000 --> 00:06:45,875",
        "text": "Перезаряжай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:47,541 --> 00:06:49,083",
        "text": "Дайте воздух! Ты как?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:06:59,291 --> 00:07:00,125",
        "text": "Лежать."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:07:12,000 --> 00:07:12,833",
        "text": "Назад."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:07:13,750 --> 00:07:14,583",
        "text": "Сюда."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:07:16,208 --> 00:07:17,041",
        "text": "Пошли."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:07:34,500 --> 00:07:35,750",
        "text": "Окружить ворота."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:08:07,333 --> 00:08:09,166",
        "text": "Смелее, детка."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:08:49,541 --> 00:08:52,000",
        "text": "Передислоцируй отряды и ждите там. Останься."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:09:37,291 --> 00:09:38,125",
        "text": "Давай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:11:39,625 --> 00:11:41,333",
        "text": "Пошли, пошли!"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:13:42,333 --> 00:13:45,666",
        "text": "Я предупреждала вас об опасностях, связанных с работой."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:14:00,208 --> 00:14:04,541",
        "text": "Отчаяние – это путь в небытие, дитя."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:14:08,375 --> 00:14:10,000",
        "text": "Покончим с этим."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:14:19,916 --> 00:14:21,625",
        "text": "Я очень ценила твою теплоту."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:14:51,666 --> 00:14:55,207",
        "text": "Если я тебе дорога, пощади их жизни."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:14:55,208 --> 00:14:59,291",
        "text": "Бессмысленное кровопролитие ничего не даст."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:15:03,750 --> 00:15:05,875",
        "text": "Лисица."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:15:07,250 --> 00:15:08,250",
        "text": "Солдаты."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:15:43,125 --> 00:15:44,541",
        "text": "Встаньте в строй."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:15:56,208 --> 00:15:57,041",
        "text": "Огонь."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:16:08,958 --> 00:16:10,125",
        "text": "Бежим."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:17:55,708 --> 00:17:56,791",
        "text": "Где Виктор?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:18:26,083 --> 00:18:28,666",
        "text": "Несмотря на обстоятельства, Джейс... ...я рад тебя видеть."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:18:36,333 --> 00:18:39,000",
        "text": "Часть тебя всё еще должна быть там."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:18:40,375 --> 00:18:42,875",
        "text": "Теперь меня больше, чем когда-либо."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:18:52,666 --> 00:18:54,500",
        "text": "Какой у нас еще выбор?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:30,458 --> 00:19:34,125",
        "text": "Мама, посмотри, какова цена твоих амбиций."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:34,875 --> 00:19:37,374",
        "text": "Ты пожертвовала всем."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:37,375 --> 00:19:38,416",
        "text": "Риктус."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:38,958 --> 00:19:40,000",
        "text": "Кино."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:40,708 --> 00:19:42,958",
        "text": "Я построила этот город для нашей семьи."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:44,916 --> 00:19:47,583",
        "text": "Если бы это было ради нас, ты бы не стала со мной драться."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:50,166 --> 00:19:51,958",
        "text": "Ты не Медарда."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:53,875 --> 00:19:55,000",
        "text": "Ты помнишь свою..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:19:56,291 --> 00:19:57,625",
        "text": "Заткнись и сражайся."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:20:45,208 --> 00:20:46,750",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:20:48,000 --> 00:20:49,250",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:21:51,875 --> 00:21:53,208",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:11,750 --> 00:22:16,208",
        "text": "Это решение, к которому мы с тобой стремились всю жизнь."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:17,333 --> 00:22:21,374",
        "text": "Конец жестокости и несправедливости."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:21,375 --> 00:22:23,457",
        "text": "Каждый из нас – автор непрерывной саги прогресса."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:27,583 --> 00:22:30,458",
        "text": "На благо всех."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:31,125 --> 00:22:33,874",
        "text": "Люди достойны сами выбирать свою судьбу."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:33,875 --> 00:22:36,790",
        "text": "Выбор ошибочен."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:36,791 --> 00:22:39,707",
        "text": "Это то, как мы облекаем в форму и прощаем низменные инстинкты, которые подталкивают нас к раздору."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:44,125 --> 00:22:47,582",
        "text": "Смерть, война, предрассудки."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:47,583 --> 00:22:51,915",
        "text": "Энергия расходуется лишь на себя."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:51,916 --> 00:22:57,000",
        "text": "Но мы можем быть едины духом."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:22:58,083 --> 00:22:59,791",
        "text": "Объединенные."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:00,666 --> 00:24:02,333",
        "text": "Ты хорошо сражалась, дитя."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:07,791 --> 00:24:09,166",
        "text": "Сейчас."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:17,625 --> 00:24:19,416",
        "text": "Волк не знает пощады."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:27,333 --> 00:24:30,000",
        "text": "Твоя дочь мудрее, чем ты думаешь."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:30,541 --> 00:24:32,375",
        "text": "Я приветствую тебя, Амбесса."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:33,958 --> 00:24:35,791",
        "text": "Для того, кто не обладает даром, ты была настоящим шипом."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:24:51,416 --> 00:24:53,875",
        "text": "Что ты делаешь, сестра?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:25:11,041 --> 00:25:13,624",
        "text": "Я вижу твое лицо, обманщица."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:25:13,625 --> 00:25:15,875",
        "text": "Хитрая девчонка."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:25:46,541 --> 00:25:48,458",
        "text": "Ты – волк."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:26:51,708 --> 00:26:53,833",
        "text": "Похоже, тебе не стоило возвращаться."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:26:55,333 --> 00:26:57,374",
        "text": "Всё еще не поняла, да, сестренка?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:26:57,375 --> 00:27:00,166",
        "text": "Я всегда с тобой."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:00,875 --> 00:27:02,750",
        "text": "Даже когда мы на разных концах света."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:08,833 --> 00:27:11,374",
        "text": "Прекрати это безумие, Виктор."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:11,375 --> 00:27:14,458",
        "text": "Именно это я и собираюсь сделать."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:21,416 --> 00:27:23,750",
        "text": "Твои глаза не лгут... когда твой разум..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:31,291 --> 00:27:33,791",
        "text": "...открыт, Джейс."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:52,916 --> 00:27:53,750",
        "text": "Вандер."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:27:59,583 --> 00:28:00,416",
        "text": "Папа?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:29:52,916 --> 00:29:53,916",
        "text": "Видишь?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:29:54,625 --> 00:29:59,916",
        "text": "Восхитительное сочетание порядка и хаоса."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:31:36,166 --> 00:31:38,875",
        "text": "Это то, что ты видишь?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:31:44,291 --> 00:31:46,958",
        "text": "Этот конфликт."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:31:50,208 --> 00:31:53,208",
        "text": "Это бессмысленное расточительство."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:31:56,416 --> 00:31:59,541",
        "text": "Я знаю их мысли, Джейс."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:00,916 --> 00:32:03,207",
        "text": "Они хотят жить лучше, но эмоции вступают в противоречие с разумом."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:07,083 --> 00:32:11,000",
        "text": "Саморазрушающее противоречие человечества."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:12,458 --> 00:32:15,791",
        "text": "Ты всегда хотел избавиться от своих слабостей."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:16,333 --> 00:32:17,166",
        "text": "Твоя нога."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:19,291 --> 00:32:20,416",
        "text": "Твоя болезнь."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:21,541 --> 00:32:23,541",
        "text": "Но ты никогда не был сломлен, Виктор."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:24,583 --> 00:32:26,916",
        "text": "В несовершенстве есть своя красота."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:28,000 --> 00:32:30,166",
        "text": "Оно сделало тебя тем, кто ты есть."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:31,500 --> 00:32:34,666",
        "text": "Это неотъемлемая часть всего..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:32:36,541 --> 00:32:38,250",
        "text": "Я восхищался тобой."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:34:26,666 --> 00:34:29,875",
        "text": "Этого не может быть."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:03,000 --> 00:35:05,833",
        "text": "Я думал, что хочу, чтобы мы дали миру волшебство."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:06,958 --> 00:35:07,791",
        "text": "Теперь... ...всё, чего я хочу... ...чтобы мой партнер вернулся."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:17,208 --> 00:35:19,416",
        "text": "Почему ты настаиваешь?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:20,125 --> 00:35:22,958",
        "text": "После всего, что я сделал?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:24,666 --> 00:35:26,625",
        "text": "Потому что я обещал тебе."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:33,041 --> 00:35:34,833",
        "text": "Зачем ты мне это дал?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:36,125 --> 00:35:36,958",
        "text": "Для чего?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:51,916 --> 00:35:55,333",
        "text": "Я думал, что смогу положить конец страданиям в мире."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:35:56,250 --> 00:35:58,833",
        "text": "Но когда все задачи были решены... ...всё, что осталось... ...были поля безмятежного одиночества."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:36:11,291 --> 00:36:13,375",
        "text": "Не существует награды за совершенство."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:36:14,458 --> 00:36:16,583",
        "text": "Только конец преследования."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:36:17,791 --> 00:36:19,541",
        "text": "Во всех временных отрезках, во всех возможных вариантах... ...только ты... ...можешь показать мне это."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:37:11,541 --> 00:37:13,583",
        "text": "Ты должен уйти, Джейс."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:37:32,166 --> 00:37:33,916",
        "text": "Мы закончим это вместе."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:39:09,541 --> 00:39:11,291",
        "text": "ТАМОЖНЯ Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:39:52,666 --> 00:39:55,416",
        "text": "Вай, поторопись, ты можешь добраться до другого выступа."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:39:58,833 --> 00:39:59,999",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:40:00,000 --> 00:40:01,208",
        "text": "Что ты..."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:40:08,500 --> 00:40:09,333",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:40:15,125 --> 00:40:15,958",
        "text": "Вай?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:40:20,250 --> 00:40:21,708",
        "text": "Ты не можешь его спасти."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:40:33,708 --> 00:40:34,541",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:41:06,500 --> 00:41:08,000",
        "text": "Всегда с тобой, сестренка."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:43:24,083 --> 00:43:26,458",
        "text": "Вы можете прочитать о войне в Пилтовере."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:43:28,333 --> 00:43:31,666",
        "text": "Но история получается очень абстрактной."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:43:32,250 --> 00:43:33,625",
        "text": "За свою правду... агония каждой жертвы... ...и возвышение каждой победы – это больше, чем человек может вынести."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:44:01,666 --> 00:44:02,666",
        "text": "Это мы... ...принимали решения и будем за них отвечать."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:44:15,375 --> 00:44:18,208",
        "text": "Единственное утешение, что вместе с потерями мы нашли и хорошее, светлое, стоящее."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:44:25,041 --> 00:44:26,416",
        "text": "То, за что стоит бороться."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:44:37,333 --> 00:44:40,833",
        "text": "И хотя мы обречены на повторение наших ошибок... разжигание всё новых конфликтов... ...наша история еще не закончена."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:45:28,833 --> 00:45:30,208",
        "text": "ХЕКСВРАТА Это... ...пение?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:46:05,250 --> 00:46:07,583",
        "text": "Эту мелодию напевала моя мама."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:46:16,458 --> 00:46:18,875",
        "text": "Ты всё еще сражаешься, Вайолет?"
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:46:25,333 --> 00:46:27,708",
        "text": "Я – грязь под твоими ногтями, кексик."
    },
    {
        "season": 2,
        "episode": 9,
        "time_code": "00:46:30,458 --> 00:46:32,166",
        "text": "Ничто меня не отмоет."
    }
]