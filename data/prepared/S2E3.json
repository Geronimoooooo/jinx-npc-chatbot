[
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:18,583 --> 00:00:19,500",
        "text": "Но помни."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:20,250 --> 00:00:21,583",
        "text": "Ты Кирамман."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:22,916 --> 00:00:25,957",
        "text": "Я поведу отряд в Заун с тремя целями: найти Джинкс, ликвидировать Мерцание и обезвредить всех агентов, которые всё еще преданы Силко."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:33,916 --> 00:00:35,582",
        "text": "Развитие промышленности в расщелинах привело к тому, что воздух стал токсичнее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:38,958 --> 00:00:40,541",
        "text": "Они называют это Серым небом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:41,541 --> 00:00:45,166",
        "text": "Я поручила нашим архитекторам разработать систему вентиляции."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:00:45,833 --> 00:00:48,666",
        "text": "Жители подземелья заслуживают того, чтобы дышать."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:02:01,416 --> 00:02:03,250",
        "text": "Они называют его Серым небом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:02:13,791 --> 00:02:14,625",
        "text": "Я убью тебя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:03:34,458 --> 00:03:37,375",
        "text": "АРКЕЙН Спасибо. Я думал, что мне конец."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:03:54,041 --> 00:03:55,540",
        "text": "Ты человек Смича."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:03:55,541 --> 00:03:56,790",
        "text": "Был."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:03:56,791 --> 00:03:58,707",
        "text": "Больше нет. Меня зовут Хинот."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:03:58,708 --> 00:03:59,625",
        "text": "Я..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:01,125 --> 00:04:03,999",
        "text": "Я решил, что мне пора в отставку."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:04,000 --> 00:04:06,374",
        "text": "Скорее тебя отправили в отставку."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:06,375 --> 00:04:09,125",
        "text": "Да, мне никогда не удавалось выбрать момент."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:10,166 --> 00:04:10,999",
        "text": "Простите."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:11,000 --> 00:04:13,874",
        "text": "Простите, это... Это Серое небо. Из-за него..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:13,875 --> 00:04:15,332",
        "text": "Как ты здесь оказался?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:15,333 --> 00:04:16,624",
        "text": "Эй, подождите."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:16,625 --> 00:04:19,874",
        "text": "Джинкс перешла границу, даже для нее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:19,875 --> 00:04:22,249",
        "text": "У нее под задницей настоящий пожар."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:22,250 --> 00:04:24,040",
        "text": "Она планирует что-то грандиозное, прямо здесь, среди труб."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:26,125 --> 00:04:28,083",
        "text": "Это довольно большое место."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:28,625 --> 00:04:33,291",
        "text": "Она направилась к старым туннелям. Что-то связанное с вентиляцией."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:33,958 --> 00:04:34,790",
        "text": "Вот и всё."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:34,791 --> 00:04:37,374",
        "text": "Надень на него наручники. Я всё сказал."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:37,375 --> 00:04:40,499",
        "text": "Ты преступник. Отставку проведешь в камере."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:40,500 --> 00:04:41,540",
        "text": "Проверь снаряжение."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:41,541 --> 00:04:43,291",
        "text": "Этому нас готовили."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:44,416 --> 00:04:45,541",
        "text": "Можно минутку?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:52,958 --> 00:04:55,875",
        "text": "Первая просьба об аудиенции была неинтересной."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:04:56,708 --> 00:04:59,833",
        "text": "Вторая – неуместной для человека твоего положения."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:00,375 --> 00:05:01,208",
        "text": "Третья... попросту назойливой."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:05,666 --> 00:05:07,916",
        "text": "Люди теряли головы и за меньшее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:12,000 --> 00:05:13,458",
        "text": "Расскажи мне, Амара, что от меня нужно члену торговой гильдии Пилтовера?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:20,125 --> 00:05:22,624",
        "text": "Сейчас я не представляю гильдию."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:22,625 --> 00:05:24,791",
        "text": "Я пришла сюда, чтобы рассчитаться с долгом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:26,916 --> 00:05:29,375",
        "text": "Мой бухгалтер в коридоре."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:31,416 --> 00:05:35,625",
        "text": "То, что вы украли, дороже любого золота."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:43,125 --> 00:05:47,125",
        "text": "Вы действительно верили, что Пилтовер недосягаем для нас?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:53,375 --> 00:05:55,375",
        "text": "Мой сын мертв."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:56,291 --> 00:05:59,000",
        "text": "Неужели этого недостаточно, чтобы утолить вашу жажду крови?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:05:59,708 --> 00:06:02,665",
        "text": "Я не оскорбляла твой разум, Амбесса."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:02,666 --> 00:06:04,750",
        "text": "Не оскорбляй мой."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:07,375 --> 00:06:09,957",
        "text": "Мы знаем, что вы ищете в Пилтовере."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:09,958 --> 00:06:11,750",
        "text": "Мы этого не допустим."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:12,500 --> 00:06:13,458",
        "text": "Не допустите?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:15,083 --> 00:06:15,999",
        "text": "Спасибо."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:16,000 --> 00:06:18,958",
        "text": "Твой визит лишь подтверждает мои подозрения."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:24,125 --> 00:06:27,125",
        "text": "Попробуй остановить меня, наглая ведьма."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:31,958 --> 00:06:34,208",
        "text": "Моя смерть ничего не значит."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:35,333 --> 00:06:38,333",
        "text": "Тебе следовало отказаться от вражды."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:40,041 --> 00:06:44,333",
        "text": "Ты даже не представляешь, что для меня значит семья."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:55,708 --> 00:06:56,833",
        "text": "Утроить охрану."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:06:57,750 --> 00:06:59,875",
        "text": "Это будет иметь последствия."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:00,666 --> 00:07:02,957",
        "text": "Нам нужен контроль."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:02,958 --> 00:07:04,540",
        "text": "Сейло еще не готов."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:04,541 --> 00:07:07,249",
        "text": "Возможно, пришло время привлечь Мэл."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:07,250 --> 00:07:10,457",
        "text": "Нет, мы должны дистанцироваться."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:10,458 --> 00:07:12,415",
        "text": "Она безопаснее как наш враг."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:12,416 --> 00:07:13,666",
        "text": "Я разберусь с Сейло."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:15,125 --> 00:07:18,291",
        "text": "Ее исчезновение недолго останется незамеченным."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:19,208 --> 00:07:20,875",
        "text": "Это еще хуже."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:35,750 --> 00:07:37,375",
        "text": "Надо отпустить остальных."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:38,833 --> 00:07:42,290",
        "text": "Слушай, если этот идиот Хинот говорит правду, у Джинкс будут для нас сюрпризы."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:45,208 --> 00:07:46,999",
        "text": "Еще одна причина взять подмогу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:47,000 --> 00:07:50,583",
        "text": "Она учует их нервозность и найдет способ использовать ее против нас."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:51,125 --> 00:07:52,416",
        "text": "Скажи, что я ошибаюсь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:53,333 --> 00:07:57,249",
        "text": "Я не могу позволить ей снова уйти. Ты уверена, что готова..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:57,250 --> 00:07:59,291",
        "text": "Моей сестры больше нет."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:07:59,958 --> 00:08:01,583",
        "text": "Теперь есть только Джинкс."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:08:03,291 --> 00:08:04,666",
        "text": "Пора закончить это."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:08:06,250 --> 00:08:08,583",
        "text": "Мне жаль твою маму."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:08:09,750 --> 00:08:13,125",
        "text": "Мне жаль, что я не могу вернуть ее, но прошу..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:08:14,875 --> 00:08:18,541",
        "text": "Всё в моей жизни изменилось. Обещай, что ты не изменишься."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:08:39,291 --> 00:08:40,125",
        "text": "Не изменюсь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:09:38,083 --> 00:09:39,166",
        "text": "Вон."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:09:49,875 --> 00:09:52,916",
        "text": "Ты понимаешь, как легко я нашла тебя здесь?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:09:54,125 --> 00:09:55,915",
        "text": "Ну, это место принадлежит мне."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:09:55,916 --> 00:09:57,624",
        "text": "Этого хватит, чтобы поддержать тебя и не разрушить то немногое, что осталось."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:01,666 --> 00:10:04,624",
        "text": "Если бы ты поддерживала так же хорошо, как раздражаешь, может, у меня нашлось бы лучшее применение времени, чем сидеть и ждать новостей о подземных похождениях принцессы Кирамман."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:13,833 --> 00:10:15,541",
        "text": "Она не приблизилась к Джинкс."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:16,458 --> 00:10:19,750",
        "text": "Но это, кажется, не мешает никому видеть чудеса."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:20,291 --> 00:10:24,250",
        "text": "Не следовало позволять ребенку одолеть тебя в твоих же покоях."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:24,791 --> 00:10:25,916",
        "text": "Дело не в девчонке."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:26,625 --> 00:10:28,124",
        "text": "Это имя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:28,125 --> 00:10:29,791",
        "text": "Оно завораживает людей."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:30,625 --> 00:10:31,582",
        "text": "Ты должна знать."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:31,583 --> 00:10:34,166",
        "text": "Как ты думаешь, Мэл могла бы преуспеть..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:35,708 --> 00:10:37,750",
        "text": "Никогда не говори плохо о моей семье."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:45,791 --> 00:10:47,375",
        "text": "Зачем ты здесь?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:48,083 --> 00:10:49,541",
        "text": "Чтобы взбодрить тебя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:50,708 --> 00:10:52,250",
        "text": "Миссия выполнена."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:56,500 --> 00:10:57,624",
        "text": "Пришло время."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:10:57,625 --> 00:11:01,332",
        "text": "Объединить все дома и семьи, обладающие хоть малой толикой влияния."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:01,333 --> 00:11:02,540",
        "text": "Справишься с этим?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:02,541 --> 00:11:04,790",
        "text": "Подожди. Серьезно?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:04,791 --> 00:11:06,124",
        "text": "Да, конечно."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:06,125 --> 00:11:07,291",
        "text": "Всё, что нужно."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:07,958 --> 00:11:12,250",
        "text": "Есть еще один вопрос, касающийся члена торговой гильдии Амары."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:22,750 --> 00:11:24,374",
        "text": "И, да."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:24,375 --> 00:11:25,291",
        "text": "Подъем."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:26,541 --> 00:11:27,541",
        "text": "Фантастика."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:36,083 --> 00:11:37,416",
        "text": "Рада снова видеть тебя, Лест."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:37,958 --> 00:11:38,791",
        "text": "Я ухожу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:39,458 --> 00:11:43,083",
        "text": "Присматривать за советником с особыми вкусами меня не смущает."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:43,625 --> 00:11:44,665",
        "text": "Но эта женщина..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:44,666 --> 00:11:47,207",
        "text": "Моя мать? Что она хотела?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:47,208 --> 00:11:50,166",
        "text": "Не знаю. Меня выставили раньше, чем что-либо сказали."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:50,916 --> 00:11:53,208",
        "text": "Всё тебе было слышно."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:54,708 --> 00:11:56,290",
        "text": "Мне жаль, но я не могу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:56,291 --> 00:11:58,290",
        "text": "Лест, это жизненно важно."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:58,291 --> 00:11:59,540",
        "text": "Мне нужно знать."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:11:59,541 --> 00:12:01,458",
        "text": "Дело не в Сейло."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:02,250 --> 00:12:04,290",
        "text": "Ты используешь меня, чтобы добраться до нее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:04,291 --> 00:12:05,415",
        "text": "И что потом?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:05,416 --> 00:12:08,207",
        "text": "Получишь, что тебе нужно, а меня бросишь на произвол судьбы?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:08,208 --> 00:12:09,332",
        "text": "Я расходный материал?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:09,333 --> 00:12:11,332",
        "text": "Нет, никто не будет расходным материалом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:11,333 --> 00:12:13,374",
        "text": "В этом всё дело."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:13,375 --> 00:12:16,291",
        "text": "Всё, что связано с моей матерью, – это просчитанный риск."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:16,916 --> 00:12:18,374",
        "text": "Я бы пообещала безопасность, но я не могу дать никаких гарантий, кроме одной."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:21,041 --> 00:12:25,040",
        "text": "Если моя мать получит то, что хочет, пострадает весь город."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:25,041 --> 00:12:28,916",
        "text": "И сейчас только ты можешь встать у нее на пути."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:30,958 --> 00:12:33,207",
        "text": "Они готовят какое-то объявление."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:33,208 --> 00:12:34,540",
        "text": "О том, кто есть кто."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:34,541 --> 00:12:37,500",
        "text": "Стремятся захватить власть, посадить Сейло на теплое место, но... ...мы же знаем, кто на самом деле дергает за веревочки."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:42,416 --> 00:12:43,915",
        "text": "Мне запомнилось имя. Амара."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:43,916 --> 00:12:45,916",
        "text": "Не знаю, что ты об этом знаешь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:46,458 --> 00:12:49,083",
        "text": "Вот, совершенно новый коктейль. Полный восторг."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:50,375 --> 00:12:51,457",
        "text": "С мерцанием."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:51,458 --> 00:12:52,999",
        "text": "Оставляет следы на теле."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:53,000 --> 00:12:56,291",
        "text": "Это всё, что тебе нужно, чтобы закрыть Сейло."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:58,125 --> 00:12:59,165",
        "text": "Спасибо."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:12:59,166 --> 00:13:00,416",
        "text": "Если уж на то пошло... ...какой бы опасной она ни была, твоя мать была напугана."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:05,333 --> 00:13:06,416",
        "text": "Это чувствовалось."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:07,083 --> 00:13:09,291",
        "text": "Как кошка, забившаяся в угол."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:38,166 --> 00:13:41,999",
        "text": "Виктор предположил, что здесь может быть то, что он назвал «дикими рунами»."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:42,000 --> 00:13:43,790",
        "text": "Узоры, естественно возникающие там, где граница между нашим миром и Аркейном тонка."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:46,791 --> 00:13:49,124",
        "text": "Руны, подобные тем, что используются в хекстеках."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:49,125 --> 00:13:52,290",
        "text": "В чём разница между ними и дикими рунами?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:52,291 --> 00:13:53,458",
        "text": "Передай мне книгу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:56,333 --> 00:13:59,749",
        "text": "Я использовал понятные тебе слова, чтобы побудить тебя к действию."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:13:59,750 --> 00:14:01,583",
        "text": "Это и есть руны хекстека."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:02,500 --> 00:14:03,500",
        "text": "Передай мне книгу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:06,333 --> 00:14:07,250",
        "text": "Передай мне книгу."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:07,958 --> 00:14:11,165",
        "text": "Ну вот, ты вздохнул. Это тоже разновидность языка."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:11,166 --> 00:14:12,957",
        "text": "Звук, но не слова."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:12,958 --> 00:14:14,790",
        "text": "Что-то дикое. Естественное."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:14,791 --> 00:14:16,415",
        "text": "Это дикие руны."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:16,416 --> 00:14:19,749",
        "text": "Обычно Аркейн находится в спящем состоянии, но кое-где он более активен."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:19,750 --> 00:14:22,124",
        "text": "Дикие руны... Что-то вроде отпечатков пальцев."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:22,125 --> 00:14:23,415",
        "text": "Именно."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:23,416 --> 00:14:26,457",
        "text": "То есть ты хочешь сказать, что этот узор появился на моем дереве, потому что ты разозлил Аркейна своими требованиями?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:29,791 --> 00:14:31,207",
        "text": "Это не то, что я..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:31,208 --> 00:14:33,457",
        "text": "Возможно, парень что-то понял."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:33,458 --> 00:14:36,457",
        "text": "Каждое действие вызывает ответную реакцию."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:36,458 --> 00:14:38,208",
        "text": "Шаровые опоры."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:38,750 --> 00:14:41,625",
        "text": "Думаешь, это из-за чрезмерного использования хекстека?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:42,208 --> 00:14:47,249",
        "text": "Я много раз видел, как в руках магов рождались чудеса, но очень часто они превращались в ужасы."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:51,666 --> 00:14:55,291",
        "text": "Я всегда полагал, что это связано с тем, что у людей... сложные отношения с властью."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:14:59,000 --> 00:15:04,916",
        "text": "Но, возможно, это свойство Аркейна."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:15:05,708 --> 00:15:09,540",
        "text": "В течение многих лет мы тестировали наш хекстек во всех мыслимых условиях."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:15:09,541 --> 00:15:11,374",
        "text": "Если существует какая-то реакция, почему до сих пор мы не видели ее признаков?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:15:14,041 --> 00:15:19,291",
        "text": "И почему она проявилась на дереве, глубоко под землей?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:15:58,541 --> 00:15:59,915",
        "text": "Ваш источник оказался прав."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:15:59,916 --> 00:16:04,125",
        "text": "Я убедилась, что Сейло встречался с членами нескольких домов сегодня."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:04,708 --> 00:16:07,250",
        "text": "Я должна была первой сообщить вам об этом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:07,791 --> 00:16:09,624",
        "text": "Уверяю, я бы не пропустила."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:09,625 --> 00:16:12,040",
        "text": "Это такой смелый шаг."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:12,041 --> 00:16:13,874",
        "text": "И в данный момент это..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:13,875 --> 00:16:15,041",
        "text": "Глупо."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:16,208 --> 00:16:18,666",
        "text": "Конечно, ваша мать не глупа."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:19,208 --> 00:16:21,291",
        "text": "Должно быть, я что-то упускаю."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:23,708 --> 00:16:25,790",
        "text": "А что по другому вопросу?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:25,791 --> 00:16:29,791",
        "text": "Вокруг смерти вашего брата свито целое гнездо лжи."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:30,375 --> 00:16:32,958",
        "text": "Тот, кому он перешел дорогу, знает, как замести следы."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:33,500 --> 00:16:37,833",
        "text": "Более того, им удалось лишить вашу мать большей части ее имущества."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:40,375 --> 00:16:41,541",
        "text": "Она в отчаянии."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:42,125 --> 00:16:44,500",
        "text": "Это делает ее еще более опасной."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:45,958 --> 00:16:47,375",
        "text": "Что мы будем делать?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:50,500 --> 00:16:53,999",
        "text": "Вызови аптекаря. Я хочу узнать его мнение об этом."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:16:54,000 --> 00:16:55,583",
        "text": "И проверь, как там Амара."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:04,166 --> 00:17:06,250",
        "text": "Это всё еще часть Хексврат?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:07,291 --> 00:17:10,291",
        "text": "Мы должны находиться на глубине не менее 60 метров."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:10,833 --> 00:17:12,874",
        "text": "Вся структура представляет собой канал, фокусирующий энергию хекстека в точный луч."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:39,458 --> 00:17:40,416",
        "text": "Кейт."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:41,375 --> 00:17:42,791",
        "text": "Если увидишь возможность... стреляй."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:17:46,625 --> 00:17:47,833",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:04,125 --> 00:18:06,124",
        "text": "Откуда ты так много знаешь о его конструкции?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:06,125 --> 00:18:08,707",
        "text": "Прочитал всё, что смог. Об остальном догадался."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:08,708 --> 00:18:11,957",
        "text": "К тому же я не думал, что Наверху допустят, чтобы что-то важное было под поверхностью."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:24,958 --> 00:18:27,874",
        "text": "Я думал, что сетка с драгоценными камнями установлена над землей."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:27,875 --> 00:18:29,082",
        "text": "Сетка над землей, но мы не знали, что произойдет, если ворота перегрузятся, поэтому установили предохранитель."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:34,000 --> 00:18:38,415",
        "text": "И вместо того, чтобы взорваться у вас, она взорвется у нас."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:38,416 --> 00:18:40,415",
        "text": "Мы далеко от основных расщелин."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:40,416 --> 00:18:43,207",
        "text": "Это те самые каналы, по которым нам подается вода и осуществляется вентиляция."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:45,125 --> 00:18:47,790",
        "text": "Это объясняет воздействие на дерево."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:47,791 --> 00:18:49,707",
        "text": "Непостижимо."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:49,708 --> 00:18:53,250",
        "text": "Знаешь, ты говоришь, что мы должны чувствовать, что мы все – один народ."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:54,375 --> 00:18:57,500",
        "text": "Но всякий раз, когда идет дождь, мокнем только мы..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:18:58,041 --> 00:18:59,166",
        "text": "Что за..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:04,125 --> 00:19:05,125",
        "text": "Джинкс."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:06,708 --> 00:19:08,208",
        "text": "Наконец-то правильно назвала имя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:11,041 --> 00:19:13,790",
        "text": "Похоже, нет такой расщелины, где бы ты меня не нашла."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:16,000 --> 00:19:17,540",
        "text": "Что это за место?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:17,541 --> 00:19:20,957",
        "text": "Разве ты не помнишь старые сказки Жанны на ночь, которые рассказывал Вандер?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:23,375 --> 00:19:25,749",
        "text": "Шахтеры в ловушке под землей."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:25,750 --> 00:19:27,665",
        "text": "Воздух на исходе."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:27,666 --> 00:19:33,041",
        "text": "Но тут им на помощь приходит женщина-ветер."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:34,958 --> 00:19:38,458",
        "text": "Удивительно, на какие только глупости не идут люди, когда ты их душишь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:39,375 --> 00:19:43,082",
        "text": "Мы использовали Серое небо, чтобы очистить улицы, обезопасить всех."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:43,083 --> 00:19:44,250",
        "text": "«Мы»."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:44,791 --> 00:19:48,333",
        "text": "Никогда не думала, что моя сестра посинеет."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:48,916 --> 00:19:51,166",
        "text": "Никогда не думала, что моя станет сиротой."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:52,166 --> 00:19:55,540",
        "text": "Почему бы и нет? Я уже достаточно натворила."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:19:55,541 --> 00:19:57,874",
        "text": "Но раскрашивать свое лицо, чтобы кто-то другой делал твою грязную работу?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:01,833 --> 00:20:03,916",
        "text": "Отравлять наш воздух?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:05,208 --> 00:20:08,207",
        "text": "Ты изменилась, сестра."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:08,208 --> 00:20:11,540",
        "text": "Мне надоело винить себя за твои ошибки."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:11,541 --> 00:20:14,957",
        "text": "Хватит притворяться, что ты моя сестра. Это неправда."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:14,958 --> 00:20:16,582",
        "text": "Ты убила ее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:16,583 --> 00:20:19,416",
        "text": "Я не позволю тебе запятнать ее память."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:21,125 --> 00:20:22,833",
        "text": "Тогда останови меня."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:24,916 --> 00:20:27,333",
        "text": "Потому что, что бы я ни делала, я просто не могу умереть."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:30,500 --> 00:20:31,333",
        "text": "Мне очень жаль."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:20:32,791 --> 00:20:33,958",
        "text": "Мне тоже жаль."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:01,041 --> 00:21:02,750",
        "text": "Я знаю, что ты неравнодушна к ней."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:04,333 --> 00:21:07,165",
        "text": "Надеюсь, у вас есть шанс..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:07,166 --> 00:21:08,416",
        "text": "До..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:10,625 --> 00:21:11,666",
        "text": "Я готова."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:21,333 --> 00:21:24,250",
        "text": "Это дикая руна?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:21:25,166 --> 00:21:27,208",
        "text": "Я понятия не имею, что это такое."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:24:09,708 --> 00:24:11,625",
        "text": "Что мы наделали?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:25:27,458 --> 00:25:29,541",
        "text": "Продолжай. Я готова."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:25:32,083 --> 00:25:33,416",
        "text": "Я рада, что это ты."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:25:34,750 --> 00:25:36,208",
        "text": "Это должна быть ты."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:25:44,708 --> 00:25:45,583",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:24,166 --> 00:26:25,125",
        "text": "Что ты..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:26,166 --> 00:26:27,333",
        "text": "Отстань от меня."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:30,666 --> 00:26:31,749",
        "text": "Отойди от нее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:31,750 --> 00:26:33,624",
        "text": "Кейт. Шевелись."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:33,625 --> 00:26:34,540",
        "text": "Убирайся, мелочь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:34,541 --> 00:26:36,624",
        "text": "Кейт, она же ребенок."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:36,625 --> 00:26:38,958",
        "text": "Шевелись. Она больше не уйдет."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:39,500 --> 00:26:40,750",
        "text": "Кейт."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:26:44,875 --> 00:26:46,166",
        "text": "Уходи. Кейт."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:27:03,708 --> 00:27:05,916",
        "text": "Нет, всё должно быть не так..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:28:06,541 --> 00:28:08,250",
        "text": "Мы должны идти."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:28:56,416 --> 00:28:57,625",
        "text": "Кейт."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:03,333 --> 00:29:04,625",
        "text": "Ты остановила меня."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:06,166 --> 00:29:07,583",
        "text": "Я не должна была этого делать."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:08,333 --> 00:29:09,957",
        "text": "У меня был шанс."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:09,958 --> 00:29:12,249",
        "text": "Это был ребенок. А если бы ты промахнулась?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:12,250 --> 00:29:14,083",
        "text": "Я бы не промахнулась."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:16,541 --> 00:29:17,916",
        "text": "Что с тобой?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:19,333 --> 00:29:21,875",
        "text": "Я постоянно говорю себе, что ты другая."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:22,625 --> 00:29:23,708",
        "text": "Но это не так."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:24,916 --> 00:29:26,999",
        "text": "В твоих жилах течет ее кровь."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:29:27,000 --> 00:29:29,541",
        "text": "Тогда почему это ты ведешь себя как она?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:30:48,500 --> 00:30:49,500",
        "text": "Элора?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:30:50,083 --> 00:30:50,916",
        "text": "Что случилось?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:06,666 --> 00:31:09,041",
        "text": "Черная роза."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:31,125 --> 00:31:33,458",
        "text": "Спасибо всем, кто откликнулся на мой призыв."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:34,041 --> 00:31:38,165",
        "text": "Я стал доверять опыту Амбессы Медарды."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:38,166 --> 00:31:40,290",
        "text": "Вы, несомненно, узнаете это имя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:40,291 --> 00:31:43,790",
        "text": "Она только что поделилась со мной очень печальной, но, к сожалению, неудивительной новостью."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:50,375 --> 00:31:51,375",
        "text": "Добрый вечер."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:51,958 --> 00:31:55,291",
        "text": "Вчера я встретилась с членом торговой гильдии Амарой."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:31:55,916 --> 00:31:57,665",
        "text": "Мы говорили о перестройке, о возвращении этому великому городу былой славы, как вдруг на нас напали двое убийц заунитов."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:06,916 --> 00:32:08,665",
        "text": "Я пыталась спасти ее."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:08,666 --> 00:32:11,125",
        "text": "Но лезвие пронзило ее сердце."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:12,416 --> 00:32:16,375",
        "text": "Наши семьи не должны бояться кинжала убийцы в ночи."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:17,250 --> 00:32:20,166",
        "text": "Пора положить этому конец."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:20,750 --> 00:32:23,915",
        "text": "Вы давали Зауну шанс за шансом, чтобы исправить их ошибки."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:25,666 --> 00:32:27,375",
        "text": "И как они ответили?"
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:30,916 --> 00:32:33,333",
        "text": "Половина вашего совета мертва."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:35,208 --> 00:32:37,708",
        "text": "Ваш памятник превращен в кровавую бойню."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:40,208 --> 00:32:41,333",
        "text": "Что ж, хватит."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:43,041 --> 00:32:46,125",
        "text": "Ярость должна быть встречена яростью."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:50,500 --> 00:32:52,790",
        "text": "Вы должны объявить военное положение."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:52,791 --> 00:32:56,874",
        "text": "Назначьте генерала для руководства, пока угроза не будет ликвидирована."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:32:56,875 --> 00:33:00,499",
        "text": "Того, кто не побледнеет, столкнувшись с выродками Зауна."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:00,500 --> 00:33:03,332",
        "text": "Чья уверенность не ослабеет."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:03,333 --> 00:33:05,707",
        "text": "Столп вашего общества, чей дом всегда стоял на страже прогресса."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:09,250 --> 00:33:11,624",
        "text": "Кто может быть уверен, что мой опыт и весь мой отряд ноксианских солдат в его распоряжении."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:20,958 --> 00:33:25,165",
        "text": "Пока все наши семьи не будут в безопасности."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:25,166 --> 00:33:29,208",
        "text": "Конечно, я могу подразумевать только..."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:33:34,166 --> 00:33:36,166",
        "text": "Кейтлин Кирамман."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:34:18,916 --> 00:34:20,666",
        "text": "Месть за вашего сына."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:34:34,500 --> 00:34:35,541",
        "text": "Это ты."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:34:55,083 --> 00:34:56,083",
        "text": "Идем, дитя."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:35:33,375 --> 00:35:35,916",
        "text": "Твоя мать добьется справедливости."
    },
    {
        "season": 2,
        "episode": 3,
        "time_code": "00:35:36,708 --> 00:35:37,833",
        "text": "Клянусь."
    }
]