[
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:04,083 --> 00:01:05,500",
        "text": "Тебе уже не помочь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:06,041 --> 00:01:08,290",
        "text": "Ух ты, расслабься, резвый."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:08,291 --> 00:01:10,458",
        "text": "У меня есть новая идея..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:15,750 --> 00:01:17,540",
        "text": "Ты только что бросил это?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:17,541 --> 00:01:18,875",
        "text": "Стой... Не подходи."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:21,750 --> 00:01:22,583",
        "text": "Эй."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:23,458 --> 00:01:26,208",
        "text": "Что это за шумиха в семи сточных ямах?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:28,750 --> 00:01:30,875",
        "text": "Ой, один из этих дней, да?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:32,958 --> 00:01:34,790",
        "text": "Ты ведь знаешь ужасных близнецов?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:34,791 --> 00:01:36,625",
        "text": "Гений и безумие."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:37,208 --> 00:01:39,540",
        "text": "Может, стоит убрать безумие?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:39,541 --> 00:01:42,000",
        "text": "У меня еще есть дела..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:01:44,291 --> 00:01:45,791",
        "text": "Что на него нашло?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:02:51,083 --> 00:02:53,833",
        "text": "АРКЕЙН Эй, космонавт!"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:03:46,458 --> 00:03:48,583",
        "text": "Я же не сама с собой разговариваю."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:03:49,125 --> 00:03:53,041",
        "text": "Что с тобой? Ты весь день не в себе."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:03:54,000 --> 00:03:57,249",
        "text": "Словно я проснулся не в той вселенной."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:03:57,250 --> 00:04:01,665",
        "text": "Так бывает, если не спать всю ночь. Дело в связях между нейронами."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:01,666 --> 00:04:03,499",
        "text": "Они как пьяные слизни."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:03,500 --> 00:04:06,583",
        "text": "У нас еще много времени до начала соревнований."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:07,125 --> 00:04:09,665",
        "text": "Так? Мы разберемся со всеми деталями."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:09,666 --> 00:04:10,875",
        "text": "Я с тобой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:15,250 --> 00:04:17,000",
        "text": "Это ли не королевская семья Зауна?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:17,625 --> 00:04:19,041",
        "text": "Мой лорд."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:20,916 --> 00:04:22,415",
        "text": "Садитесь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:22,416 --> 00:04:25,166",
        "text": "Эй, малыш. Неприятности в раю?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:26,416 --> 00:04:28,415",
        "text": "Обычные сложности с проектом."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:28,416 --> 00:04:29,915",
        "text": "И не говори."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:29,916 --> 00:04:33,957",
        "text": "Мы наконец-то заставили гибридов питаться газами из расщелины, но коэффициент трансформации слишком мал."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:36,375 --> 00:04:37,332",
        "text": "Почти не растут."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:37,333 --> 00:04:40,457",
        "text": "Они недостаточно сильны, чтобы очистить весь воздух здесь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:40,458 --> 00:04:43,457",
        "text": "Если только не посадить миллион. Этого не будет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:43,458 --> 00:04:45,790",
        "text": "Мы пробовали обрабатывать почву, вливать воду."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:48,208 --> 00:04:49,374",
        "text": "Безрезультатно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:49,375 --> 00:04:51,624",
        "text": "Я сейчас вернусь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:51,625 --> 00:04:52,707",
        "text": "О, нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:52,708 --> 00:04:54,916",
        "text": "Иди. Спаси его от самого себя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:04:58,000 --> 00:04:59,833",
        "text": "Где бы ты был без нее?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:05,833 --> 00:05:06,958",
        "text": "Привет, Герт."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:07,708 --> 00:05:08,832",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:08,833 --> 00:05:10,082",
        "text": "Да ладно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:10,083 --> 00:05:11,790",
        "text": "Привет... Привет, Герт."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:11,791 --> 00:05:14,665",
        "text": "У \"Кем Систерс\" будет еще одно шоу?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:14,666 --> 00:05:17,082",
        "text": "Майло – большой поклонник."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:17,083 --> 00:05:19,083",
        "text": "Прямо-таки огромный."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:20,083 --> 00:05:21,000",
        "text": "Круто."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:21,875 --> 00:05:24,957",
        "text": "Да, старик позволит нам сыграть на вечеринке накануне «Конкурса выдающихся изобретений», на который вы все так рветесь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:41,833 --> 00:05:43,874",
        "text": "Что бы они делали без тебя?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:43,875 --> 00:05:46,458",
        "text": "Наверное, стали бы махать руками."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:49,666 --> 00:05:53,125",
        "text": "Знаешь, чему я научился, работая барменом?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:05:53,958 --> 00:05:56,874",
        "text": "Как бы приятно ни было наливать всем их напитки, нужно время от времени наполнять свой собственный стакан."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:01,708 --> 00:06:03,040",
        "text": "Дай угадаю."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:03,041 --> 00:06:05,249",
        "text": "Ты думаешь, что я ограничиваю себя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:05,250 --> 00:06:09,583",
        "text": "Я думаю, что ты слишком умна, чтобы провести свою жизнь в баре."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:15,208 --> 00:06:16,166",
        "text": "Привет, профессор."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:17,416 --> 00:06:20,625",
        "text": "Профессор? Я опоздал на собрание интеллектуалов?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:45,375 --> 00:06:47,415",
        "text": "Нельзя кричать о том, что тебя занесло в параллельные измерения, без каких-либо последствий."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:06:53,458 --> 00:06:58,540",
        "text": "Похоже, аномалия, вырвавшая нас из нашей пресловутой реальности, также разбросала нас во времени."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:03,250 --> 00:07:05,208",
        "text": "А я думал, что схожу с ума."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:06,208 --> 00:07:07,749",
        "text": "Как давно ты здесь? 1128 дней, шесть часов и 20 минут."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:12,958 --> 00:07:13,916",
        "text": "Плюс-минус."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:15,666 --> 00:07:18,540",
        "text": "Так ты просто ждал меня всё это время?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:18,541 --> 00:07:21,999",
        "text": "Точно. Или, скорее, неточно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:22,000 --> 00:07:23,874",
        "text": "Я сомневался, что ты появишься, даже во время моей необычайно долгой жизни."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:26,750 --> 00:07:28,750",
        "text": "А что с Джейсом? Он здесь?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:31,000 --> 00:07:34,040",
        "text": "Боюсь, он мог оказаться в другом месте."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:34,041 --> 00:07:36,875",
        "text": "Рядом с ним аномалия вела себя иначе."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:37,708 --> 00:07:40,416",
        "text": "Скажи, что ты придумал способ вернуть нас домой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:41,458 --> 00:07:44,249",
        "text": "Это настоящая головоломка."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:44,250 --> 00:07:47,082",
        "text": "Боюсь, что здесь не изобрели хекстек."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:47,083 --> 00:07:51,499",
        "text": "А без столь выдающегося творения, как Хексврата..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:51,500 --> 00:07:53,333",
        "text": "Нет аномалии."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:54,541 --> 00:07:56,582",
        "text": "Всё не так плохо."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:56,583 --> 00:07:59,832",
        "text": "В этом мире мне удалось совершить удивительные вещи."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:07:59,833 --> 00:08:01,290",
        "text": "Дай себе время освоиться."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:01,291 --> 00:08:03,833",
        "text": "Это место тебе понравится. Вот увидишь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:04,625 --> 00:08:06,124",
        "text": "Понравится?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:06,125 --> 00:08:08,540",
        "text": "Дома есть люди, которым я нужен."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:08,541 --> 00:08:10,124",
        "text": "Нам здесь не место."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:10,125 --> 00:08:12,957",
        "text": "И всё же мы не можем уехать."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:12,958 --> 00:08:15,833",
        "text": "Я найду способ вернуться. С тобой или без тебя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:19,833 --> 00:08:22,000",
        "text": "Я собиралась навестить Вай."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:22,541 --> 00:08:23,582",
        "text": "Вай?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:23,583 --> 00:08:24,666",
        "text": "Хочешь пойти?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:08:26,500 --> 00:08:28,083",
        "text": "Что мы сделали?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:17,333 --> 00:09:18,166",
        "text": "Эй!"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:20,333 --> 00:09:21,541",
        "text": "Есть кто-нибудь?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:28,833 --> 00:09:29,666",
        "text": "Кто это?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:38,833 --> 00:09:39,666",
        "text": "Ты."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:42,458 --> 00:09:44,208",
        "text": "Это ты привел меня сюда?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:45,875 --> 00:09:46,833",
        "text": "Где мы находимся?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:09:51,750 --> 00:09:52,666",
        "text": "Подожди."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:22,000 --> 00:10:23,000",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:24,666 --> 00:10:25,666",
        "text": "Не может быть."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:32,166 --> 00:10:35,666",
        "text": "Что с третьей степенью? Мы работали над этим проектом несколько месяцев."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:37,041 --> 00:10:38,166",
        "text": "Рассмеши меня."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:38,833 --> 00:10:40,749",
        "text": "Тебе приснился очередной причудливый сон об устройстве для хранения энергии, которое выиграет конкурс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:44,583 --> 00:10:47,457",
        "text": "Поэтому ты пришел ко мне за помощью."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:47,458 --> 00:10:49,124",
        "text": "Я пришел к тебе?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:49,125 --> 00:10:51,624",
        "text": "Ты не собирался сам во всём разбираться."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:51,625 --> 00:10:54,041",
        "text": "«Химический энергоэлемент с нулевыми потерями»."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:56,750 --> 00:10:58,333",
        "text": "Это изобретение."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:10:58,875 --> 00:11:02,165",
        "text": "У вас нет какой-нибудь альтернативной цели для него?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:02,166 --> 00:11:04,040",
        "text": "Это ты у нас любитель больших идей."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:04,041 --> 00:11:05,666",
        "text": "Прости, сестренка."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:06,416 --> 00:11:10,291",
        "text": "Кое-кто сходит с ума от своего проекта и снова переживает кризис идентичности."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:10,875 --> 00:11:11,875",
        "text": "Без имен."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:13,250 --> 00:11:17,624",
        "text": "Я снова выслушала речь Вандера о том, что «не реализую свой потенциал»."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:17,625 --> 00:11:18,958",
        "text": "Напоминает мне о тебе."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:21,500 --> 00:11:23,541",
        "text": "Она умерла?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:26,541 --> 00:11:27,375",
        "text": "Как?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:28,625 --> 00:11:30,125",
        "text": "Это не смешно, Экко."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:31,708 --> 00:11:33,291",
        "text": "Было ошибкой приехать сюда."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:34,291 --> 00:11:36,083",
        "text": "Что это значит?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:37,791 --> 00:11:40,958",
        "text": "Если у тебя плохой день, не вымещай это на мне."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:41,708 --> 00:11:42,708",
        "text": "Это ты?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:44,583 --> 00:11:46,249",
        "text": "Ты дал нам наводку."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:46,250 --> 00:11:48,833",
        "text": "Мы пошли на эту работу из-за тебя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:49,833 --> 00:11:50,666",
        "text": "Работа."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:51,208 --> 00:11:53,415",
        "text": "Вот почему здесь нет хекстека."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:53,416 --> 00:11:54,499",
        "text": "Тебе лучше уйти."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:54,500 --> 00:11:57,415",
        "text": "Уходи. Прежде чем я сделаю то, о чём пожалею."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:11:57,416 --> 00:11:59,708",
        "text": "Поверь мне, я работаю над этим."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:12:49,291 --> 00:12:51,458",
        "text": "Пойдем. Я видел это здесь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:12:55,708 --> 00:12:57,749",
        "text": "Не желаете ли чашечку чая, сэр?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:12:57,750 --> 00:12:58,707",
        "text": "Давайте."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:12:58,708 --> 00:12:59,875",
        "text": "ПАРИКМАХЕРСКАЯ Покрути колесо."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:10,750 --> 00:13:14,500",
        "text": "И посмотри, где оно остановится."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:15,416 --> 00:13:17,415",
        "text": "Побывай в цирке."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:17,416 --> 00:13:19,749",
        "text": "Останься на танец."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:19,750 --> 00:13:24,040",
        "text": "А когда война утихнет, Заиграет оркестр."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:27,208 --> 00:13:30,790",
        "text": "Продолжайте маршировать, Мои друзья."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:33,583 --> 00:13:36,125",
        "text": "И делайте всё, что в ваших силах."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:46,875 --> 00:13:49,749",
        "text": "Подождите, пока ваши братья и сестры Увидят, где вы были."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:53,541 --> 00:13:56,124",
        "text": "И если вы любите путешествия Больше, чем конец, Идите вперед."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:13:59,666 --> 00:14:02,415",
        "text": "Просто переверните песочные часы И сосчитайте до десяти."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:05,791 --> 00:14:07,415",
        "text": "Это не прощание..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:07,416 --> 00:14:09,915",
        "text": "Вайолет, нет. Пожалуйста..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:09,916 --> 00:14:12,207",
        "text": "Пожалуйста, нет..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:12,208 --> 00:14:14,666",
        "text": "Это только что началось."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:18,166 --> 00:14:21,541",
        "text": "Марш вперед, друзья мои."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:51,166 --> 00:14:53,624",
        "text": "Идите и совершайте ошибки."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:53,625 --> 00:14:57,000",
        "text": "Вы живете и учитесь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:14:58,083 --> 00:14:59,874",
        "text": "И где упадут фишки, Не ваша забота."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:15:04,000 --> 00:15:06,874",
        "text": "Как ветер, который будет дуть, Костры будут гореть."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:15:09,791 --> 00:15:13,707",
        "text": "Просто позволь шестеренкам, Мой друг, Просто позволь шестеренкам, Мой друг, Вращаться."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:15:28,958 --> 00:15:30,166",
        "text": "Большое спасибо."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:31,875 --> 00:16:35,541",
        "text": "Думаешь, ты сможешь воссоздать аномалию с помощью этого?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:36,125 --> 00:16:37,208",
        "text": "Это теория."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:37,958 --> 00:16:39,750",
        "text": "Невозможно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:40,708 --> 00:16:41,875",
        "text": "Так ты мне поможешь?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:42,708 --> 00:16:44,790",
        "text": "Я говорил буквально."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:44,791 --> 00:16:46,833",
        "text": "Я не верю, что это возможно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:47,375 --> 00:16:49,082",
        "text": "Вмешательство в Аркейн никогда не заканчивается хорошо."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:50,750 --> 00:16:52,750",
        "text": "Риск слишком велик."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:54,208 --> 00:16:55,458",
        "text": "Ты назвал меня учеником."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:56,125 --> 00:16:57,375",
        "text": "Мне нужен профессор."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:16:58,000 --> 00:16:58,833",
        "text": "А еще лучше – партнер."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:17:02,291 --> 00:17:04,291",
        "text": "О, взрывные форсунки."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:17:05,000 --> 00:17:08,124",
        "text": "Как же я могу бросить талантливого парня в беде?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:17:08,125 --> 00:17:09,375",
        "text": "Снова."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:35,166 --> 00:18:36,625",
        "text": "Я никогда не просил об этом."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:39,291 --> 00:18:41,916",
        "text": "Это исследование – всё. Вся моя жизнь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:48,333 --> 00:18:49,666",
        "text": "Он был моим наставником, Мэл."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:50,666 --> 00:18:51,833",
        "text": "И я предал его."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:53,541 --> 00:18:54,833",
        "text": "Ты должен уничтожить его."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:55,958 --> 00:18:56,916",
        "text": "Оно развращает."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:57,500 --> 00:18:58,458",
        "text": "Потребляет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:18:59,250 --> 00:19:01,249",
        "text": "Я пытался творить волшебство."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:01,250 --> 00:19:03,458",
        "text": "Пилтовер... Твое время пришло, Джейс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:04,250 --> 00:19:05,499",
        "text": "Возможно, время пришло."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:05,500 --> 00:19:06,915",
        "text": "Нет, нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:06,916 --> 00:19:10,166",
        "text": "Для эпохи магии. Я видел, как уничтожают народы."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:11,250 --> 00:19:12,166",
        "text": "Пожалуйста."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:19:12,750 --> 00:19:13,875",
        "text": "Именно так."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:23,958 --> 00:20:24,958",
        "text": "Осторожно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:26,041 --> 00:20:27,290",
        "text": "Мы почти пришли."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:27,291 --> 00:20:29,499",
        "text": "Я не знаю, в чём дело."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:29,500 --> 00:20:32,958",
        "text": "Но если ты пытаешься извиниться, таща меня через..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:37,416 --> 00:20:40,125",
        "text": "Это ты нарисовал?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:41,875 --> 00:20:43,125",
        "text": "Мне приснился сон... ...в котором всё пошло по-другому."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:47,791 --> 00:20:50,375",
        "text": "Она выглядит так круто."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:51,583 --> 00:20:53,374",
        "text": "Ты и половины не знаешь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:53,375 --> 00:20:56,040",
        "text": "Она была самой суровой во всём Зауне."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:56,041 --> 00:20:57,707",
        "text": "Ее ничто не пугало."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:20:57,708 --> 00:20:59,375",
        "text": "Нет, не мою сестру."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:01,208 --> 00:21:03,625",
        "text": "Вай была сильной, потому что боялась."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:04,166 --> 00:21:07,875",
        "text": "Страх потерять нас заставлял ее бороться так упорно."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:09,958 --> 00:21:12,915",
        "text": "В моем сне ты тоже была другой. Неужели?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:12,916 --> 00:21:15,957",
        "text": "Так вот в чём дело? Ты хочешь, чтобы я изменилась?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:15,958 --> 00:21:16,875",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:18,083 --> 00:21:19,708",
        "text": "Нет, нет, я просто..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:21,041 --> 00:21:25,500",
        "text": "Ты не из тех, кто помогает другим людям с их делами."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:26,541 --> 00:21:28,916",
        "text": "Твои идеи меняют мир."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:29,625 --> 00:21:33,500",
        "text": "Я не могу избавиться от ощущения, что именно такой ты и должна быть."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:34,041 --> 00:21:36,125",
        "text": "Всё хорошо, Экко."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:37,041 --> 00:21:38,500",
        "text": "Мне нравится моя жизнь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:39,375 --> 00:21:43,290",
        "text": "Я не хочу терять то, что делает меня «мной», в погоне за какой-то дикой мечтой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:49,625 --> 00:21:53,958",
        "text": "Иногда сделать рывок вперед означает оставить что-то позади."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:21:54,791 --> 00:21:58,083",
        "text": "Вы настоящая загадка, не так ли, мистер?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:22:00,791 --> 00:22:02,916",
        "text": "Ладно, проехали."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:22:03,458 --> 00:22:04,666",
        "text": "Что тебе от меня нужно?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:24:40,875 --> 00:24:42,208",
        "text": "Он такой маленький."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:24:42,916 --> 00:24:45,166",
        "text": "Боже, мы сделали это."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:24:45,708 --> 00:24:46,958",
        "text": "На полпути."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:24:53,125 --> 00:24:55,375",
        "text": "И что это дает?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:03,708 --> 00:25:05,707",
        "text": "И что это дает?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:05,708 --> 00:25:07,500",
        "text": "Ты уже спрашивала меня об этом."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:08,291 --> 00:25:09,125",
        "text": "Не спрашивала."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:09,958 --> 00:25:11,625",
        "text": "Я слишком устал для игр."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:16,375 --> 00:25:17,708",
        "text": "Не спрашивала."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:21,958 --> 00:25:23,250",
        "text": "Это петля времени."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:24,416 --> 00:25:25,500",
        "text": "Петля времени?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:27,875 --> 00:25:29,416",
        "text": "Петля времени? Петля времени."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:31,250 --> 00:25:32,832",
        "text": "Вы возвращаетесь в прошлое."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:32,833 --> 00:25:35,457",
        "text": "Черт побери! Как ты об этом узнал?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:35,458 --> 00:25:39,374",
        "text": "Я играл с инверсиями на руне ускорения Джейса."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:39,375 --> 00:25:40,582",
        "text": "Как далеко продвинулся?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:40,583 --> 00:25:42,582",
        "text": "Не знаю. Секунду?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:42,583 --> 00:25:45,290",
        "text": "Попробуй вернуться еще дальше. Не спеши, парень."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:25:45,291 --> 00:25:48,958",
        "text": "Не стоит слишком быстро запускать новое изобретение."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:23,500 --> 00:26:24,500",
        "text": "Один."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:28,875 --> 00:26:29,875",
        "text": "Два."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:30,458 --> 00:26:31,583",
        "text": "Три."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:33,000 --> 00:26:34,541",
        "text": "Черт побери! Четыре."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:42,875 --> 00:26:44,790",
        "text": "Предел – четыре секунды."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:44,791 --> 00:26:47,708",
        "text": "Ты уверен, мой мальчик? Каковы показатели?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:48,833 --> 00:26:50,166",
        "text": "Доверься мне."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:50,750 --> 00:26:52,083",
        "text": "Это четыре секунды."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:53,208 --> 00:26:54,374",
        "text": "Потрясающе."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:54,375 --> 00:26:56,541",
        "text": "Можно показать это на вечеринке."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:26:57,500 --> 00:26:59,125",
        "text": "Мы еще не закончили."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:01,125 --> 00:27:03,208",
        "text": "Пожалуйста, переоденься перед вечеринкой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:09,041 --> 00:27:12,083",
        "text": "Думаю, я знаю, как ускорить процесс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:14,458 --> 00:27:15,457",
        "text": "Ускорить?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:15,458 --> 00:27:17,874",
        "text": "Моментальное улучшение, если хотите."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:17,875 --> 00:27:20,124",
        "text": "Отлично. С чего начнем?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:20,125 --> 00:27:22,458",
        "text": "Можешь начать с посещения вечеринки."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:23,333 --> 00:27:26,249",
        "text": "В одиночестве легче собраться с мыслями."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:27:26,250 --> 00:27:28,832",
        "text": "Зачем нужно такое устройство, если не наслаждаешься временем?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:21,666 --> 00:28:22,916",
        "text": "Вот и он."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:23,750 --> 00:28:25,499",
        "text": "Эй, нервничаешь, парень?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:25,500 --> 00:28:27,207",
        "text": "Завтра большой день."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:27,208 --> 00:28:28,958",
        "text": "Только об этом и думаю."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:29,875 --> 00:28:31,291",
        "text": "Где маленькая леди?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:31,875 --> 00:28:35,875",
        "text": "Не уверен. Она сказала что-то о том, что нужно готовиться к выходу."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:36,875 --> 00:28:38,916",
        "text": "Она любит зрелища, да?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:41,166 --> 00:28:42,083",
        "text": "Да."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:44,375 --> 00:28:48,208",
        "text": "Если я позабуду сказать тебе это завтра, ты всегда был для меня очень важен, Бензо."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:53,958 --> 00:28:55,541",
        "text": "Ну, ты..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:28:57,333 --> 00:29:00,624",
        "text": "Ты... Только не надо на меня набрасываться."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:00,625 --> 00:29:01,541",
        "text": "Эй."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:03,958 --> 00:29:08,165",
        "text": "Заставляешь здоровяка смущаться, да? О, эта проклятая аллергия."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:08,166 --> 00:29:10,415",
        "text": "Ты должен гордиться собой, Экко."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:10,416 --> 00:29:12,875",
        "text": "Паудер с восторгом отзывается о твоем Z-приводе."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:13,583 --> 00:29:16,166",
        "text": "Не помню, когда я в последний раз видел ее такой живой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:17,916 --> 00:29:20,707",
        "text": "Мне кажется, что скоро ты будешь управлять этим местом."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:20,708 --> 00:29:23,666",
        "text": "Так что у нас еще есть шанс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:24,291 --> 00:29:25,250",
        "text": "Ты?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:26,041 --> 00:29:29,665",
        "text": "Ты же не думал, что я пропущу твой важный день?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:29,666 --> 00:29:31,791",
        "text": "Разве ты не пытался его убить?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:33,291 --> 00:29:37,625",
        "text": "Самое важное, что мы можем совершить, – это найти в себе силы простить."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:29:47,041 --> 00:29:48,791",
        "text": "КОНКУРС ВЫДАЮЩИХСЯ ИЗОБРЕТЕНИЙ Какой вечер."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:30:55,625 --> 00:30:56,833",
        "text": "Так красиво."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:30:58,458 --> 00:31:00,291",
        "text": "Где ты научился этим движениям?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:01,333 --> 00:31:03,583",
        "text": "Я просто следовал за тобой."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:06,333 --> 00:31:07,583",
        "text": "У него есть приемы."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:09,833 --> 00:31:10,833",
        "text": "Эй."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:14,625 --> 00:31:16,125",
        "text": "Я просто хочу поблагодарить тебя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:17,000 --> 00:31:18,500",
        "text": "Знаешь, за всё."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:19,916 --> 00:31:22,583",
        "text": "Я мечтал, чтобы подземный город был таким."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:23,125 --> 00:31:27,750",
        "text": "Но я увлекся причинами, из-за которых он таким не был."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:29,625 --> 00:31:30,625",
        "text": "Я сдался."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:32,250 --> 00:31:33,458",
        "text": "Отказался от тебя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:34,375 --> 00:31:38,250",
        "text": "Я никогда не видела, чтобы ты сдавался, Экко."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:41,000 --> 00:31:45,000",
        "text": "Тебе никогда не хотелось остаться в одном моменте?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:45,875 --> 00:31:49,791",
        "text": "Иногда сделать рывок вперед означает... оставить что-то позади."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:53,208 --> 00:31:55,166",
        "text": "Обещаю, что никогда не забуду этого."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:55,791 --> 00:31:57,041",
        "text": "Уж постарайся."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:31:59,250 --> 00:32:00,916",
        "text": "Прости, я... Нет..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:32:01,750 --> 00:32:03,083",
        "text": "Всё в порядке, я..."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:32:06,291 --> 00:32:10,250",
        "text": "Мы можем притвориться, что это в первый раз?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:33:47,666 --> 00:33:50,582",
        "text": "Экко, дружище. Ты как раз вовремя."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:33:50,583 --> 00:33:52,332",
        "text": "Тут большой прогресс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:33:52,333 --> 00:33:53,790",
        "text": "Минутку."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:33:53,791 --> 00:33:56,833",
        "text": "Мне нужно только подключить последний блок питания."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:19,041 --> 00:34:21,250",
        "text": "Здесь всё и началось, не так ли?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:24,833 --> 00:34:26,541",
        "text": "Конец Пилтовера."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:27,291 --> 00:34:28,583",
        "text": "Из-за хекстека."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:34,916 --> 00:34:36,708",
        "text": "Зачем ты дал мне это?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:38,000 --> 00:34:38,833",
        "text": "Зачем?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:44,875 --> 00:34:47,250",
        "text": "Ведь необязательно всё должно быть именно так?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:34:50,291 --> 00:34:52,375",
        "text": "Просто скажи, что есть шанс."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:35:05,750 --> 00:35:08,540",
        "text": "Как бы мне хотелось извиниться перед мисс Паудер за то, что я вот так захватил ее пространство."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:35:11,250 --> 00:35:13,250",
        "text": "Это действительно был единственный выход."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:35:30,541 --> 00:35:31,708",
        "text": "Отправь меня назад."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:10,500 --> 00:36:12,625",
        "text": "Скучно не бывает."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:13,875 --> 00:36:16,665",
        "text": "Должен сказать, что с тех пор, как я встретил тебя, парень, я стал жить по-настоящему."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:18,291 --> 00:36:19,208",
        "text": "Что?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:20,750 --> 00:36:23,083",
        "text": "Вернемся через мгновение. Нет, подожди."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:47,875 --> 00:36:49,250",
        "text": "Я не подведу."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:54,708 --> 00:36:56,083",
        "text": "Клянусь."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:36:58,666 --> 00:36:59,791",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:37:47,666 --> 00:37:48,500",
        "text": "Паудер?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:37:51,916 --> 00:37:52,916",
        "text": "Что случилось?"
    },
    {
        "season": 2,
        "episode": 7,
        "time_code": "00:38:20,375 --> 00:38:21,500",
        "text": "ВАЙ"
    }
]