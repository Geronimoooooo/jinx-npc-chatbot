[
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:00:25,708 --> 00:00:27,625",
        "text": "Давай к нам. Скорее!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:00:52,083 --> 00:00:53,291",
        "text": "Скай?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:08,041 --> 00:02:09,208",
        "text": "Не бойся."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:10,958 --> 00:02:12,291",
        "text": "Это ты смастерил?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:14,583 --> 00:02:16,916",
        "text": "Почему ты не играешь с другими детьми?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:23,083 --> 00:02:26,083",
        "text": "Одиночество часто бывает признаком выдающегося ума."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:26,708 --> 00:02:27,708",
        "text": "Что это такое?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:30,750 --> 00:02:32,666",
        "text": "Это Рио."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:32,750 --> 00:02:35,208",
        "text": "Она результат редкой мутации, которую я создал."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:36,250 --> 00:02:37,125",
        "text": "Вот."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:02:38,000 --> 00:02:39,166",
        "text": "Держи."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:00,166 --> 00:03:01,458",
        "text": "Она умирает."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:03,916 --> 00:03:05,541",
        "text": "Я пытаюсь это предотвратить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:06,083 --> 00:03:08,625",
        "text": "Эта мутация должна выжить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:09,666 --> 00:03:10,625",
        "text": "Я могу помочь?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:11,458 --> 00:03:13,208",
        "text": "Хочешь стать моим помощником?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:14,833 --> 00:03:16,041",
        "text": "Хорошо."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:19,875 --> 00:03:21,625",
        "text": "Будем одиночками вместе."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:37,375 --> 00:03:40,208",
        "text": "Приятно, что некоторые вещи не меняются."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:40,750 --> 00:03:44,666",
        "text": "Будто только вчера я встретил здесь многообещающего юного ученого из Нижнего города, который раздумывал о чём-то в своем стальном оазисе."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:51,000 --> 00:03:52,625",
        "text": "Я слышал, что говорят врачи."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:53,708 --> 00:03:55,416",
        "text": "Мне так жаль, мой мальчик."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:03:57,666 --> 00:04:00,000",
        "text": "Вы думаете о смерти, профессор?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:00,833 --> 00:04:02,583",
        "text": "Только о смертях друзей."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:03,416 --> 00:04:05,791",
        "text": "Ваше наследие неоспоримо."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:05,875 --> 00:04:07,875",
        "text": "Вы один из основателей Пилтовера, столького добились за свою замечательную жизнь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:14,708 --> 00:04:18,333",
        "text": "Тебе есть чем гордиться, Виктор."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:22,666 --> 00:04:23,875",
        "text": "Ерунда."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:23,958 --> 00:04:27,833",
        "text": "Мой вклад не задержится надолго даже в вашей памяти."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:29,333 --> 00:04:31,375",
        "text": "Я повидал много студентов."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:04:32,291 --> 00:04:37,291",
        "text": "К сожалению, те, что ярче сияют, зачастую быстрее сгорают."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:03,958 --> 00:06:05,750",
        "text": "Не знал, что ты пишешь картины."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:09,333 --> 00:06:11,583",
        "text": "Ты многого обо мне не знаешь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:12,833 --> 00:06:15,375",
        "text": "Прости, что вчера ушел не попрощавшись."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:17,083 --> 00:06:18,666",
        "text": "Долг зовет."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:27,958 --> 00:06:29,416",
        "text": "Виктор умирает."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:37,000 --> 00:06:39,791",
        "text": "Думаю, это связано с газами в Расщелинах, где он вырос."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:39,875 --> 00:06:42,500",
        "text": "Именно такие вещи мы и хотели изменить хекстеком."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:44,583 --> 00:06:45,625",
        "text": "Улучшать жизни."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:45,708 --> 00:06:48,791",
        "text": "Решать реальные проблемы, а не торговые споры."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:50,333 --> 00:06:52,041",
        "text": "Виктор однажды спас мне жизнь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:52,125 --> 00:06:54,708",
        "text": "Теперь ему нужна помощь, а я ничего не могу сделать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:55,333 --> 00:06:57,333",
        "text": "Это съедает меня изнутри."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:06:58,291 --> 00:06:59,875",
        "text": "Не знала, что вы так близки."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:00,458 --> 00:07:02,000",
        "text": "Он мне как брат."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:05,625 --> 00:07:07,500",
        "text": "Почему ты пришел с этим ко мне?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:08,083 --> 00:07:09,416",
        "text": "Просто… С тобой всё кажется возможным."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:16,083 --> 00:07:18,208",
        "text": "Моя семья от меня отреклась."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:18,750 --> 00:07:20,458",
        "text": "Что? Почему?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:21,458 --> 00:07:23,750",
        "text": "Не дотягиваю до стандартов Медардов."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:23,833 --> 00:07:26,791",
        "text": "Мэл, я ни на секунду в это не поверю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:27,500 --> 00:07:28,625",
        "text": "Ты сама веришь?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:30,708 --> 00:07:32,708",
        "text": "Ты должен быть с ним, Джейс."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:33,416 --> 00:07:35,666",
        "text": "Нельзя изменить судьбу, которая нам уготована, но ее проще принять, если рядом друг."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:07:41,291 --> 00:07:42,666",
        "text": "Прекрасная картина."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:08:49,166 --> 00:08:50,041",
        "text": "Чак!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:08:52,666 --> 00:08:55,375",
        "text": "Тирам. Меня зовут Тирам."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:08:55,458 --> 00:08:57,083",
        "text": "Очень смешно, Чак."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:08:59,833 --> 00:09:01,083",
        "text": "А что стряслось?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:01,791 --> 00:09:03,666",
        "text": "Босс сказал нам кое-кого схватить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:04,250 --> 00:09:05,916",
        "text": "Кое-кого? Кого угодно?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:06,000 --> 00:09:08,041",
        "text": "Кого схватить? Каких-то девиц."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:08,958 --> 00:09:10,833",
        "text": "То есть, я не… Я не хватаю девиц."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:10,916 --> 00:09:14,125",
        "text": "Ну, разве что… Этих, наверное."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:14,208 --> 00:09:17,625",
        "text": "Соберись. Что за девицы? Почему меня не позвали?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:17,708 --> 00:09:19,375",
        "text": "Я не знаю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:19,458 --> 00:09:22,250",
        "text": "Они повздорили с Сэйвикой. Такой номер с ней провернули."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:23,000 --> 00:09:24,791",
        "text": "Правда? Какой номер?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:24,875 --> 00:09:26,500",
        "text": "Это такое выражение… Ты — молодчина, Чак."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:29,666 --> 00:09:31,208",
        "text": "Вот, сдачи не надо."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:49,916 --> 00:09:53,291",
        "text": "Головорезы Силко идут по пятам. Нельзя останавливаться."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:09:58,166 --> 00:10:00,458",
        "text": "Это еще что? Знак."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:10:01,833 --> 00:10:03,875",
        "text": "Неважно. Помоги дойти до края."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:10:16,125 --> 00:10:17,666",
        "text": "А ты сможешь в таком… Вот чёрт."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:10:41,875 --> 00:10:43,208",
        "text": "Вперед. Живее!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:10:49,041 --> 00:10:50,208",
        "text": "Мы ее потеряли."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:10:53,166 --> 00:10:54,166",
        "text": "Кого?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:29,958 --> 00:11:33,625",
        "text": "По-моему, тебе не хватает симметрии."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:35,541 --> 00:11:37,166",
        "text": "Подправить тебе вторую руку?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:40,500 --> 00:11:42,541",
        "text": "Не надо. Дело в твоей сестре."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:44,375 --> 00:11:47,166",
        "text": "Она вернулась. Ищет тебя."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:47,750 --> 00:11:49,625",
        "text": "Всё не так, как ты думаешь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:49,708 --> 00:11:53,041",
        "text": "С ней какая-то миротворица. Видимо, тебя заменили."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:54,291 --> 00:11:55,416",
        "text": "Врешь!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:56,416 --> 00:11:57,750",
        "text": "Зачем мне врать?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:11:57,833 --> 00:11:58,875",
        "text": "Раз она вернулась, значит, ты точно скоро сорвешься, и Силко наконец поймет, что ты только вредишь нашему делу — так же, как вредила своей семье."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:12:07,416 --> 00:12:08,666",
        "text": "Джинкс."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:12:17,000 --> 00:12:18,833",
        "text": "Сто очков, подруга!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:12:18,916 --> 00:12:22,958",
        "text": "Кажется, я придумала, как донести свою мысль."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:12:54,791 --> 00:12:57,000",
        "text": "А вот и папочка."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:12:57,916 --> 00:13:01,375",
        "text": "Ты был занят, поэтому меня впустила малышка Рен."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:16,291 --> 00:13:17,416",
        "text": "Поговорим снаружи."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:18,500 --> 00:13:20,041",
        "text": "Не видишь, мы играем?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:20,833 --> 00:13:25,666",
        "text": "Помнишь нашу старую подругу Вай? Дочь Вандера."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:25,750 --> 00:13:27,875",
        "text": "Она была твоего возраста."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:27,958 --> 00:13:30,083",
        "text": "Ее отец отправился в дальнее путешествие, а твой папа заверил меня, что она уехала вместе с ним."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:34,375 --> 00:13:38,250",
        "text": "Но похоже, она не добралась до места. Печально, правда?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:38,833 --> 00:13:42,541",
        "text": "Представь, если бы тебя разлучили с твоим папой."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:43,916 --> 00:13:46,791",
        "text": "Она в надежном месте."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:47,291 --> 00:13:49,083",
        "text": "Она в Линиях."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:50,250 --> 00:13:51,375",
        "text": "Не может быть."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:51,458 --> 00:13:54,541",
        "text": "А с ней миротворец. Девчонка."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:54,625 --> 00:13:58,041",
        "text": "Ее ровесница. Кейтлин."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:58,125 --> 00:13:59,625",
        "text": "Она из семьи Кирамман."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:13:59,708 --> 00:14:01,458",
        "text": "А они все делают что хотят."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:01,541 --> 00:14:03,541",
        "text": "Я не могу контролировать ее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:06,166 --> 00:14:08,208",
        "text": "Тогда какой от тебя прок?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:09,791 --> 00:14:10,833",
        "text": "Я выслежу ее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:11,750 --> 00:14:13,166",
        "text": "Я всё исправлю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:14,625 --> 00:14:15,625",
        "text": "Прошу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:16,750 --> 00:14:19,541",
        "text": "Все совершают ошибки, не правда ли?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:20,125 --> 00:14:23,666",
        "text": "Главное — чтобы мы их не повторяли."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:23,750 --> 00:14:27,916",
        "text": "Мои люди ищут Вай и эту Кейтлин."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:28,000 --> 00:14:30,708",
        "text": "Они не должны нас больше беспокоить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:31,666 --> 00:14:33,208",
        "text": "Ясно излагаю?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:14:51,791 --> 00:14:54,541",
        "text": "Какая жалость. Я нечаянно."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:04,666 --> 00:15:05,541",
        "text": "Смотри."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:12,375 --> 00:15:15,166",
        "text": "Он реагирует на органическую материю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:24,625 --> 00:15:25,666",
        "text": "Невероятно."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:26,500 --> 00:15:29,000",
        "text": "Это нечто совершенно новое, Джейс."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:29,083 --> 00:15:33,208",
        "text": "Это может быть ключом к коррекции тела, продлению жизни… Твоему излечению."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:40,416 --> 00:15:41,750",
        "text": "И так каждый раз."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:43,083 --> 00:15:44,833",
        "text": "Не могу понять почему."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:46,000 --> 00:15:49,416",
        "text": "Они отторгают трансмутацию."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:15:57,583 --> 00:16:00,166",
        "text": "Мы это исправим. Можем не успеть."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:00,250 --> 00:16:02,416",
        "text": "Мы так мало знаем об этих процессах, а… …я слабею с каждым часом."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:09,208 --> 00:16:12,375",
        "text": "Скай позовет Хеймердингера. Он поможет нам."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:12,458 --> 00:16:15,666",
        "text": "А пока сами пошевелим мозгами."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:29,291 --> 00:16:30,500",
        "text": "Что это за место?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:30,583 --> 00:16:32,458",
        "text": "Здесь обитают те, о ком вы, верхние, даже думать не хотите."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:46,875 --> 00:16:48,708",
        "text": "Но раньше их тут было меньше."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:16:51,375 --> 00:16:52,375",
        "text": "Туда."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:30,291 --> 00:17:32,125",
        "text": "Знаю, ты от меня не в восторге, но мы должны доверять друг другу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:34,416 --> 00:17:36,875",
        "text": "Мы с тобой не команда."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:36,958 --> 00:17:39,125",
        "text": "Вы, верхние, всегда хотите нас облапошить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:39,208 --> 00:17:42,708",
        "text": "Значит, Верхний город виноват во всех твоих несчастьях?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:44,875 --> 00:17:48,375",
        "text": "Нет. Не во всех."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:48,458 --> 00:17:51,375",
        "text": "Мы ведь не монстры. Мы такие же люди."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:52,166 --> 00:17:54,000",
        "text": "Ты ничего обо мне не знаешь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:56,708 --> 00:17:58,000",
        "text": "Зря я оставила тебя одну."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:17:58,958 --> 00:18:03,000",
        "text": "Ничего. Я же всё равно вижу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:04,333 --> 00:18:05,500",
        "text": "У тебя доброе сердце."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:07,583 --> 00:18:08,916",
        "text": "У тебя доброе сердце."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:14,541 --> 00:18:15,875",
        "text": "Что это?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:18,375 --> 00:18:20,041",
        "text": "Я зову это хекскором."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:21,625 --> 00:18:26,958",
        "text": "Это адаптивная рунная матрица. Хекстек, который развивается."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:28,125 --> 00:18:29,791",
        "text": "Это настоящий прорыв."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:29,875 --> 00:18:32,500",
        "text": "Самое интересное: он реагирует на биологическую материю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:33,166 --> 00:18:34,708",
        "text": "Говорят, магия может излечивать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:34,791 --> 00:18:36,875",
        "text": "До сих пор наши образцы гибли… Уничтожьте его."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:45,125 --> 00:18:46,000",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:47,958 --> 00:18:52,416",
        "text": "Прошу, если мое мнение что-то для вас значит, послушайте меня."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:52,500 --> 00:18:56,583",
        "text": "Я видел, как одно семечко уничтожало нации, и оно выглядело… …именно так."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:18:59,041 --> 00:19:01,291",
        "text": "Профессор, это может спасти Виктора."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:02,791 --> 00:19:05,125",
        "text": "Виктор, что-то произошло."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:05,666 --> 00:19:06,708",
        "text": "Ты изменился."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:06,791 --> 00:19:09,625",
        "text": "Что ты сделал? О чём вы, профессор?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:11,583 --> 00:19:15,000",
        "text": "Эта штука меняет тебя. Она должна быть уничтожена!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:15,083 --> 00:19:18,000",
        "text": "Стойте. Нет. Я не позволю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:18,958 --> 00:19:21,333",
        "text": "Джейс, это нарушение устава."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:21,833 --> 00:19:25,333",
        "text": "Я всё равно добьюсь его уничтожения."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:25,416 --> 00:19:28,333",
        "text": "Это ваше мнение. Посмотрим, что скажет совет."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:39,500 --> 00:19:41,666",
        "text": "Я знаю, кто еще мог бы помочь, но… Делай, что нужно. Мне надо готовиться."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:19:46,916 --> 00:19:47,875",
        "text": "К чему?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:01,333 --> 00:20:02,416",
        "text": "Как она?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:03,958 --> 00:20:07,791",
        "text": "Стой! Спокойно. Этот ведь Вай?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:09,958 --> 00:20:11,833",
        "text": "Я ее друг."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:13,375 --> 00:20:17,708",
        "text": "Ну, или был им. Я обязан ее отцу жизнью."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:18,375 --> 00:20:22,083",
        "text": "Возможно, не только жизнью. Наверное."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:23,041 --> 00:20:25,583",
        "text": "Она истекает кровью. Ей нужен врач. А, да."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:26,625 --> 00:20:28,958",
        "text": "Здесь с врачами напряжёнка."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:29,041 --> 00:20:30,000",
        "text": "Ой."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:30,541 --> 00:20:31,833",
        "text": "Простите."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:32,875 --> 00:20:38,208",
        "text": "Но я знаю кое-кого, кто сможет помочь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:39,416 --> 00:20:40,625",
        "text": "Идите за мной."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:52,166 --> 00:20:53,333",
        "text": "Какая хворь?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:20:57,250 --> 00:20:59,000",
        "text": "Ножевая рана."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:04,250 --> 00:21:05,875",
        "text": "Она варит зелья."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:05,958 --> 00:21:09,833",
        "text": "Снабжает местный народ… Этим."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:11,166 --> 00:21:14,333",
        "text": "Мерцанием. Но зачем пить эту отраву?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:16,000 --> 00:21:21,250",
        "text": "Я просто хотел почувствовать, каково это — быть кем-то."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:22,000 --> 00:21:26,125",
        "text": "Внушать страх другим, вместо того чтобы самому… Обмен."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:21:56,375 --> 00:21:58,208",
        "text": "Спасибо. Вы очень… Пойдем."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:01,416 --> 00:22:03,541",
        "text": "Думаю, Вай будет рада другу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:03,625 --> 00:22:09,000",
        "text": "Нет. Я не пойду. Она знала меня, когда я был еще… В общем, я не хочу, чтобы она видела меня таким."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:13,833 --> 00:22:16,291",
        "text": "Просто передайте ей… Передайте ей, что мне жаль. Очень жаль. Ладно?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:34,916 --> 00:22:37,041",
        "text": "Я нашел это у Поджигателей."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:37,125 --> 00:22:40,666",
        "text": "Совпадает с фрагментами, найденными у лаборатории и в Хексвратах."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:42,750 --> 00:22:46,666",
        "text": "Думаю, они планируют новые нападения."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:47,291 --> 00:22:49,666",
        "text": "Почему мы раньше не знали об этой угрозе?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:49,750 --> 00:22:53,083",
        "text": "После строительства Хексврат Расщелины перестали быть в приоритете."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:53,166 --> 00:22:54,541",
        "text": "Разберемся с этим позже."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:54,625 --> 00:22:56,666",
        "text": "Сейчас нужно предотвратить новые атаки."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:22:56,750 --> 00:23:00,375",
        "text": "Если только обыскивать каждого, кто пересекает мосты."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:00,458 --> 00:23:02,000",
        "text": "Это единственный способ."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:03,125 --> 00:23:04,625",
        "text": "Значит, будем обыскивать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:04,708 --> 00:23:06,583",
        "text": "Вы уверены? Такой приказ… Уверен. Мы должны защитить город."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:16,166 --> 00:23:17,250",
        "text": "Еще один вопрос."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:17,333 --> 00:23:20,833",
        "text": "Я видел Кейтлин Кирамман с заключенной, выпущенной по вашему приказу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:22,125 --> 00:23:23,958",
        "text": "Я могу чем-то помочь?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:26,083 --> 00:23:29,333",
        "text": "Нет, всё под контролем."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:31,083 --> 00:23:34,791",
        "text": "Советники, мы сбились с пути."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:35,708 --> 00:23:39,375",
        "text": "Этот город строился, чтобы стать оплотом просвещения."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:39,458 --> 00:23:43,916",
        "text": "В мире, который разрушает себя в погоне за властью и славой."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:44,541 --> 00:23:45,916",
        "text": "Но мы забылись."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:46,000 --> 00:23:50,125",
        "text": "Поступились принципами ради комфорта и удобства."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:50,208 --> 00:23:52,541",
        "text": "Променяли честь на престиж."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:53,208 --> 00:23:54,708",
        "text": "Когда-то мы были едины."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:55,500 --> 00:23:57,958",
        "text": "Но теперь каждый дом за себя."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:23:58,958 --> 00:24:04,958",
        "text": "Если мы забудем о жадности и гордыне, то снова сможем стать единым целым."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:05,541 --> 00:24:09,041",
        "text": "Потребуется бдительность. Мы должны призвать друг друга к ответу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:09,125 --> 00:24:10,666",
        "text": "А вы сами готовы ответить?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:11,333 --> 00:24:12,333",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:12,416 --> 00:24:14,708",
        "text": "Мерцание реками течет по Нижнему городу."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:14,791 --> 00:24:17,791",
        "text": "Нападения в Хексвратах и на Площади Академии."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:17,875 --> 00:24:22,416",
        "text": "Миротворцы боятся ступить в Линии. И всё у вас под носом."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:22,500 --> 00:24:25,166",
        "text": "Джейс, ты забываешься."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:25,250 --> 00:24:26,458",
        "text": "Простите, профессор, но для спасения этого города мало одних речей."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:28,750 --> 00:24:32,250",
        "text": "Вы всё время говорите нам, чего не делать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:32,333 --> 00:24:37,041",
        "text": "Но позвольте спросить: как вы планируете исправить ситуацию?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:37,125 --> 00:24:39,125",
        "text": "Я понял, в чём дело."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:39,208 --> 00:24:42,666",
        "text": "Твои хекстек-проекты требуют времени. Мер предосторожности."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:42,750 --> 00:24:47,666",
        "text": "Люди не живут веками! Мы не можем ждать прогресса."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:48,291 --> 00:24:53,166",
        "text": "Нам нужны лидеры, смотрящие в будущее, а не в прошлое."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:53,250 --> 00:24:55,041",
        "text": "Вы — основатель Пилтовера, и мы в неоплатном долгу за ваши годы службы."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:24:59,500 --> 00:25:02,583",
        "text": "Я считаю, что уважаемому основателю нашего города пора на заслуженный покой."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:25:05,750 --> 00:25:07,708",
        "text": "Джейс, не делай этого."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:25:17,708 --> 00:25:20,791",
        "text": "Решение должно быть единогласным. Кто за?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:25:27,833 --> 00:25:31,750",
        "text": "С глубочайшим уважением и признательностью, профессор."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:02,500 --> 00:26:03,666",
        "text": "Вай."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:16,916 --> 00:26:18,750",
        "text": "Тише, тише."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:23,416 --> 00:26:24,791",
        "text": "Пора возвращаться в строй."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:25,791 --> 00:26:28,583",
        "text": "Какое имя назвала Сэйвика? Джинкс?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:33,666 --> 00:26:36,208",
        "text": "Точно. Джинкс. Конечно."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:36,291 --> 00:26:38,291",
        "text": "Теперь нам надо быть осторожнее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:38,375 --> 00:26:39,791",
        "text": "Силко будет искать нас."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:46,833 --> 00:26:48,833",
        "text": "ВАЙОЛЕТ ПАУДЕР Ты раньше здесь жила?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:54,583 --> 00:26:56,375",
        "text": "Кто такая Паудер?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:26:58,666 --> 00:27:02,166",
        "text": "Моя сестра. Я думала, она умерла, но теперь… Я должна найти ее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:04,958 --> 00:27:07,166",
        "text": "Как можно не знать, жива ли твоя сестра?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:07,833 --> 00:27:10,958",
        "text": "Трудновато поддерживать связи с людьми из тюремной камеры."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:11,041 --> 00:27:12,875",
        "text": "У тебя что, нет родителей?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:13,625 --> 00:27:16,958",
        "text": "Нет! Их убили миротворцы."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:41,958 --> 00:27:43,541",
        "text": "Любимица Вандера."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:27:51,791 --> 00:27:54,916",
        "text": "Жаль, что у нас не было возможности пообщаться."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:01,333 --> 00:28:03,000",
        "text": "Что ты сделал с моей сестрой?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:03,833 --> 00:28:05,791",
        "text": "Я освободил ее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:06,458 --> 00:28:10,583",
        "text": "Если честно, я думал, что ты — главный талант вашей семейки."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:11,291 --> 00:28:12,500",
        "text": "Но Джинкс."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:16,791 --> 00:28:18,958",
        "text": "Она просто сокровище."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:28,458 --> 00:28:33,291",
        "text": "Я найду ее и прочищу ей голову от бреда, который ты ей наплел."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:33,375 --> 00:28:37,416",
        "text": "Но сначала я разнесу в щепки твою липовую империю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:40,458 --> 00:28:43,541",
        "text": "Ты себя переоцениваешь, девочка. Это и погубило Вандера."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:43,625 --> 00:28:45,625",
        "text": "Из-за этого от тебя отвернулась сестра."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:45,708 --> 00:28:47,708",
        "text": "И поэтому я сейчас здесь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:28:49,000 --> 00:28:49,916",
        "text": "Короче… Ты много болтаешь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:29:33,333 --> 00:29:36,625",
        "text": "Где бы ты ни была, зажги его, и я тебя найду."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:29:57,833 --> 00:30:00,916",
        "text": "ВАЙОЛЕТ ПАУДЕР Рио будет жить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:31:46,291 --> 00:31:47,875",
        "text": "Это вы сделали?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:31:47,958 --> 00:31:49,541",
        "text": "Я думал, ты понимаешь."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:31:50,416 --> 00:31:53,166",
        "text": "Мутация должна выжить."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:32:20,416 --> 00:32:22,416",
        "text": "Теперь я понимаю."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:32:37,416 --> 00:32:40,375",
        "text": "Сколько проблем может доставить одна девчонка?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:32:48,791 --> 00:32:50,708",
        "text": "ЛГУНЬЯ ЛГУНЬЯ Паудер?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:36,750 --> 00:33:37,583",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:38,500 --> 00:33:39,541",
        "text": "Паудер!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:50,416 --> 00:33:52,291",
        "text": "Прости меня, Паудер. Я… Я пыталась вернуться. Правда. Но меня арестовали."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:56,291 --> 00:33:57,541",
        "text": "Маркус?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:57,625 --> 00:33:59,541",
        "text": "Не знаю. Это неважно."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:33:59,625 --> 00:34:01,791",
        "text": "Я думала, что больше не увижу тебя."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:04,333 --> 00:34:05,458",
        "text": "Это правда ты?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:07,791 --> 00:34:09,541",
        "text": "Ну конечно."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:09,625 --> 00:34:13,875",
        "text": "Это я, Вай. Твоя сестра. Я здесь. Я рядом."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:15,875 --> 00:34:19,208",
        "text": "Всё так изменилось, когда ты ушла. Я изменилась."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:20,500 --> 00:34:25,000",
        "text": "Я знаю, Пыщ-пыщ. Я знаю. Тебе пришлось выживать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:26,625 --> 00:34:30,708",
        "text": "Мне тоже. Это ничего. Главное, что мы вместе."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:39,500 --> 00:34:40,875",
        "text": "Кто это?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:40,958 --> 00:34:42,416",
        "text": "А ты кто?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:42,500 --> 00:34:44,208",
        "text": "Всё в порядке. Она со мной."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:44,291 --> 00:34:48,125",
        "text": "Сэйвика не врала? Ты водишься с миротворцем?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:51,125 --> 00:34:53,000",
        "text": "Твоя сестра — Джинкс?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:53,083 --> 00:34:56,375",
        "text": "Кейтлин, послушай. Я всё объясню."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:56,458 --> 00:34:58,750",
        "text": "Это ловушка! Ты меня подставила!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:34:59,375 --> 00:35:02,000",
        "text": "Молчать! Я не в настроении."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:02,500 --> 00:35:04,833",
        "text": "Мы молчали. Это вообще не вам!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:04,916 --> 00:35:06,500",
        "text": "Паудер, успокойся."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:06,583 --> 00:35:08,458",
        "text": "Хватит меня так называть."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:08,541 --> 00:35:11,958",
        "text": "Теперь я Джинкс. Паудер больше нет."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:12,041 --> 00:35:13,958",
        "text": "Ты не джинкс. Я глупость сказала… Не говори со мной, как с ребенком!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:15,791 --> 00:35:19,291",
        "text": "Ты поэтому пришла? За этим дурацким камушком?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:19,875 --> 00:35:22,333",
        "text": "Нет, я даже не знаю, что это."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:22,416 --> 00:35:25,166",
        "text": "Ты неподражаема, сестра."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:25,250 --> 00:35:29,416",
        "text": "Сестра. Я думала, что скучала. Вот ты бы не скучал."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:29,500 --> 00:35:32,666",
        "text": "Паудер! Я пришла за тобой. Только за тобой."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:32,750 --> 00:35:35,541",
        "text": "Можешь стрелять, если хочешь, но я не уйду."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:35,625 --> 00:35:37,958",
        "text": "Я больше не оставлю тебя."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:41,333 --> 00:35:44,000",
        "text": "Всем молчать. Мне надо подумать."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:35:44,958 --> 00:35:46,041",
        "text": "Ты это слышишь?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:37:23,833 --> 00:37:24,958",
        "text": "Паудер."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:37:34,125 --> 00:37:35,541",
        "text": "Паудер!"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:37:51,833 --> 00:37:52,875",
        "text": "Забери ее."
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:38:14,500 --> 00:38:15,333",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 6,
        "time_code": "00:38:17,583 --> 00:38:18,916",
        "text": "Нет!"
    }
]