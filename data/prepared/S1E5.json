[
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:43,083 --> 00:01:45,166",
        "text": "Неплохая была стрельба, Кирамман."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:46,083 --> 00:01:48,125",
        "text": "Родители заплатили вам за мою победу?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:49,625 --> 00:01:51,416",
        "text": "Это серьезное обвинение."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:52,125 --> 00:01:54,000",
        "text": "Вы промедлили, я видела."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:55,125 --> 00:01:57,541",
        "text": "Кубок твой. Заслуженно."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:01:58,125 --> 00:02:00,041",
        "text": "Вы не ответили на вопрос."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:01,833 --> 00:02:04,000",
        "text": "Нет, они не платили за твой кубок."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:04,083 --> 00:02:05,833",
        "text": "Просто я решила, что ты его заслужила."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:10,458 --> 00:02:11,750",
        "text": "Я миротворец."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:12,500 --> 00:02:16,916",
        "text": "Я должна уметь обращаться с оружием, чтобы защищать людей."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:17,500 --> 00:02:21,083",
        "text": "Служить этому городу. Мне не нужно другой награды."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:21,916 --> 00:02:24,500",
        "text": "Возникает вопрос, юная Кирамман."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:24,583 --> 00:02:26,291",
        "text": "Какую награду хочешь ты?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:36,208 --> 00:02:40,666",
        "text": "Я просмотрела твое дело. Там ничего. Ни о тебе, ни о твоих преступлениях."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:40,750 --> 00:02:43,416",
        "text": "За что ты здесь? За свое обаяние."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:45,000 --> 00:02:47,083",
        "text": "Ты напала на заключенного. Почему?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:47,708 --> 00:02:48,916",
        "text": "А почему нет?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:49,000 --> 00:02:51,625",
        "text": "Он был свидетелем в текущем расследовании."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:52,583 --> 00:02:53,541",
        "text": "Не повезло."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:54,833 --> 00:02:57,250",
        "text": "Зря теряю тут время. В точку."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:02:57,333 --> 00:03:00,208",
        "text": "Поцелуй от меня Силко в его прелестный глаз."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:03,458 --> 00:03:05,875",
        "text": "Силко? Промышленник?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:05,958 --> 00:03:07,541",
        "text": "Ну всё, мне надоело."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:07,625 --> 00:03:10,083",
        "text": "Запускай уже громилу, который меня отметелит, и покончим с этим, ладно?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:18,666 --> 00:03:20,291",
        "text": "Знаешь, что это?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:27,041 --> 00:03:28,416",
        "text": "Откуда это у тебя?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:30,458 --> 00:03:32,166",
        "text": "Я первая спросила."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:32,250 --> 00:03:34,458",
        "text": "Он работал на Силко? На него все работают."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:34,541 --> 00:03:36,791",
        "text": "Это ж всем известно. Где ты это взяла?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:37,666 --> 00:03:40,166",
        "text": "Было совершено нападение. Это улика."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:40,791 --> 00:03:44,208",
        "text": "Если обвиняешь Силко — докажи."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:45,333 --> 00:03:48,916",
        "text": "Я могу доказать. Только не отсюда."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:50,833 --> 00:03:53,958",
        "text": "Думаешь, я поверю на слово такой, как ты?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:54,041 --> 00:03:57,666",
        "text": "Такой, как я? Вы, миротворцы, все одинаковые."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:57,750 --> 00:03:59,791",
        "text": "Кучка мерзавцев в красивенькой форме."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:03:59,875 --> 00:04:03,083",
        "text": "Знаешь что? Ищи Силко сама. И найду."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:04,166 --> 00:04:06,625",
        "text": "В нижнем городе тебя живьем сожрут."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:13,083 --> 00:04:16,791",
        "text": "Приказ советника Талиса по заключенной 516."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:17,875 --> 00:04:19,916",
        "text": "Не сотрудничает со следствием?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:20,000 --> 00:04:22,375",
        "text": "Хотите, проведем воспитательную беседу?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:23,416 --> 00:04:25,250",
        "text": "Нет! Нет?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:26,000 --> 00:04:27,375",
        "text": "Это приказ об освобождении."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:28,541 --> 00:04:30,708",
        "text": "Когда это он стал советником?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:30,791 --> 00:04:32,333",
        "text": "Сегодня."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:37,166 --> 00:04:38,916",
        "text": "Сколько «бесед» вы с ней провели?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:04:40,916 --> 00:04:44,125",
        "text": "Да разве упомнишь?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:17,333 --> 00:06:20,125",
        "text": "Эти бесстрашные миротворцы отдали свои жизни, чтобы защитить ценности нашего великого города."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:24,291 --> 00:06:25,791",
        "text": "Среди них были матери."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:27,833 --> 00:06:28,916",
        "text": "Отцы."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:29,875 --> 00:06:30,875",
        "text": "Сыновья."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:34,166 --> 00:06:35,250",
        "text": "Дочери."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:06:37,291 --> 00:06:38,458",
        "text": "И все они… …были героями."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:07,208 --> 00:07:08,791",
        "text": "Кто это, папа?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:10,791 --> 00:07:13,583",
        "text": "ГРЕЙСОН Настоящая героиня."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:19,833 --> 00:07:21,625",
        "text": "Ты обещал держать ее в узде."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:22,250 --> 00:07:25,458",
        "text": "Я потерял шестерых человек. Шестерых!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:27,333 --> 00:07:30,875",
        "text": "Она зашла слишком далеко. Совет рвет и мечет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:30,958 --> 00:07:35,083",
        "text": "Я не смогу это замять, если ты не пойдешь на уступки."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:35,708 --> 00:07:38,541",
        "text": "Ее арестом я окажу тебе услугу."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:38,625 --> 00:07:39,958",
        "text": "Мне не нужны услуги."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:40,583 --> 00:07:42,708",
        "text": "Мне нужно, чтобы ты делал свою работу."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:46,541 --> 00:07:49,541",
        "text": "Поджигатели — наша общая проблема."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:49,625 --> 00:07:53,291",
        "text": "В тот же день у хексврат они сорвали мою поставку."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:53,958 --> 00:07:57,208",
        "text": "Вот их и отдай совету."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:07:58,666 --> 00:08:00,333",
        "text": "Как удобно для тебя."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:00,416 --> 00:08:03,000",
        "text": "А если я не стану тебе подыгрывать?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:04,250 --> 00:08:06,375",
        "text": "Мы многого достигли вместе, Маркус."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:07,041 --> 00:08:08,125",
        "text": "Шериф."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:09,125 --> 00:08:11,375",
        "text": "И достигнем еще большего."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:12,875 --> 00:08:15,250",
        "text": "Надеюсь, ты останешься с нами."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:21,333 --> 00:08:25,583",
        "text": "Их семьям. От анонимного доброжелателя."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:42,125 --> 00:08:44,458",
        "text": "Вчерашний срыв контрабанды — это вершина айсберга."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:44,541 --> 00:08:47,500",
        "text": "В путевых листах за много месяцев есть расхождения."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:47,583 --> 00:08:49,583",
        "text": "Мы не этим должны заниматься."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:49,666 --> 00:08:51,416",
        "text": "Я теперь советник, Виктор."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:51,500 --> 00:08:54,750",
        "text": "Я отвечаю за безопасность хексврат."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:54,833 --> 00:08:58,666",
        "text": "А как же наша клятва улучшать жизни нуждающихся?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:08:58,750 --> 00:09:00,416",
        "text": "Жителей нижнего города."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:01,666 --> 00:09:04,958",
        "text": "Прости, что не затронул в своей речи другие наши проекты."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:05,041 --> 00:09:07,125",
        "text": "Скоро мы сможем делать всё… Скоро?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:07,208 --> 00:09:10,250",
        "text": "Людям нужна наша помощь прямо сейчас!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:11,875 --> 00:09:13,291",
        "text": "Вызывали?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:13,375 --> 00:09:15,333",
        "text": "Вы хоть раз проверяли эти накладные?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:15,416 --> 00:09:17,458",
        "text": "Господин Талис, уверяю… Советник."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:17,541 --> 00:09:18,875",
        "text": "Не надо уверять, надо найти и изъять весь незаконный товар."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:22,083 --> 00:09:24,291",
        "text": "Я составил список подозрительных сделок."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:25,125 --> 00:09:27,500",
        "text": "При всём уважении, советник. Сегодня ваш первый день… Второй."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:28,583 --> 00:09:32,041",
        "text": "Конечно. Вы не хотите сначала обсудить это с другими советниками… Шериф, коррупция проникла всюду."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:34,458 --> 00:09:35,916",
        "text": "Я намерен искоренить ее."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:37,333 --> 00:09:39,458",
        "text": "Есть новости по украденному самоцвету?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:39,541 --> 00:09:43,416",
        "text": "Да, мы подозреваем банду из нижнего города."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:44,166 --> 00:09:46,916",
        "text": "Они зовут себя Поджигателями. Их трудно поймать."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:47,000 --> 00:09:49,958",
        "text": "Нападают на граждан и исчезают в ночи как призраки."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:50,041 --> 00:09:51,791",
        "text": "Как скоро сможем их выследить?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:51,875 --> 00:09:53,166",
        "text": "На это брошены все силы."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:53,250 --> 00:09:54,958",
        "text": "Хорошо. Держите меня в курсе."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:09:55,791 --> 00:09:58,041",
        "text": "Мы выведем их на чистую воду, шериф."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:03,291 --> 00:10:05,083",
        "text": "Виктор? Ты в порядке?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:06,750 --> 00:10:08,791",
        "text": "Мигрень. Мне… Мне нужно в лабораторию."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:17,583 --> 00:10:19,208",
        "text": "Тоска."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:19,791 --> 00:10:21,416",
        "text": "Тоска."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:22,375 --> 00:10:23,625",
        "text": "Тоска зеленая."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:26,708 --> 00:10:28,083",
        "text": "Нашла!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:29,375 --> 00:10:31,458",
        "text": "Всё дело в рунах."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:31,541 --> 00:10:35,958",
        "text": "Они создают какой-то мате-магический портал."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:37,375 --> 00:10:39,916",
        "text": "В какое-то стремное место."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:40,000 --> 00:10:42,875",
        "text": "И вот это все запускает."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:10:44,291 --> 00:10:46,500",
        "text": "Так. Поехали."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:11:18,041 --> 00:11:22,416",
        "text": "Нет! Нет, я не хотела!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:11:31,583 --> 00:11:33,416",
        "text": "Я слышала, из батисферы отличный вид."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:11:34,125 --> 00:11:37,000",
        "text": "Неплохой способ разведать обстановку."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:11:38,333 --> 00:11:39,500",
        "text": "Слишком рискованно."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:11:41,125 --> 00:11:42,000",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:12:56,458 --> 00:12:57,625",
        "text": "Классная куртка."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:12,041 --> 00:13:14,666",
        "text": "Добро пожаловать на Линии. Ты меня чуть не угробила."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:14,750 --> 00:13:16,833",
        "text": "Моя сестра так умела в семь лет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:16,916 --> 00:13:19,458",
        "text": "Тут все так умеют. Учись, а то будешь выделяться."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:30,833 --> 00:13:32,125",
        "text": "Так тебя осенило?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:32,208 --> 00:13:34,041",
        "text": "Что, если мы зашли не с того конца?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:34,125 --> 00:13:37,250",
        "text": "Мы ищем руны с определенным эффектом и комбинируем для нужного результата."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:40,125 --> 00:13:41,250",
        "text": "Как инструменты."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:41,333 --> 00:13:47,500",
        "text": "Но если легенды не врут, маги не ограничены набором функций."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:47,583 --> 00:13:50,375",
        "text": "Считается, что Аркана говорит через них."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:51,291 --> 00:13:53,208",
        "text": "Я всё равно не понимаю."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:53,291 --> 00:13:55,708",
        "text": "Они думают. Приспосабливаются."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:13:55,791 --> 00:13:58,416",
        "text": "Думаешь, хекстек может обучаться?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:03,791 --> 00:14:05,208",
        "text": "Уверен, что это безопасно?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:05,291 --> 00:14:06,625",
        "text": "Конечно нет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:22,708 --> 00:14:25,125",
        "text": "Иерихон! Как я скучала по твоей стряпне!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:31,291 --> 00:14:32,500",
        "text": "Нет. Спасибо."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:33,125 --> 00:14:34,041",
        "text": "Ну и зря."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:35,000 --> 00:14:38,333",
        "text": "Собираешься его расспросить? О чём? О мясе?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:39,916 --> 00:14:41,541",
        "text": "Напрямую — точно нет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:41,625 --> 00:14:45,000",
        "text": "О Силко. О его связях. Мы ведь ради этого пришли?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:45,083 --> 00:14:48,000",
        "text": "Мы пришли, потому что я голодна. Знаешь, чем кормят в тюрьме?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:48,083 --> 00:14:49,333",
        "text": "Нет. Конечно, не знаешь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:50,375 --> 00:14:51,583",
        "text": "Уму непостижимо."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:51,666 --> 00:14:54,416",
        "text": "Я тебя вытащила не для того, чтобы ты объедалась помоями."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:54,500 --> 00:14:58,666",
        "text": "Так и знала, что зря это затеяла. Ты ведь ничего не знаешь, да?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:14:59,791 --> 00:15:01,000",
        "text": "Вкуснотища."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:06,625 --> 00:15:08,041",
        "text": "АА Много лет тут не был."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:26,125 --> 00:15:28,208",
        "text": "Только когда-то давно с родителями."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:28,291 --> 00:15:31,041",
        "text": "Мы здесь не ради представления. Твоя семья в опасности."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:32,666 --> 00:15:35,708",
        "text": "У той дамочки торговля процветала."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:35,791 --> 00:15:37,500",
        "text": "Еще бы: столько привилегий."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:37,583 --> 00:15:40,375",
        "text": "В обмен на щедрые пожертвования Академии."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:40,458 --> 00:15:43,250",
        "text": "Привилегии — это взятки?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:43,833 --> 00:15:45,208",
        "text": "Амара безобидна."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:46,166 --> 00:15:47,958",
        "text": "Посмотри на этих двух увальней."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:48,041 --> 00:15:49,750",
        "text": "Советники Хоскел и Сэйло?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:49,833 --> 00:15:51,250",
        "text": "Они же друг друга не выносят."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:51,791 --> 00:15:54,791",
        "text": "Зато оба любят ноксианское спиртное, которое ввозится нелегально."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:58,208 --> 00:15:59,875",
        "text": "Я усилил контроль на границах."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:15:59,958 --> 00:16:03,500",
        "text": "И тем самым сделал себя мишенью."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:16:04,250 --> 00:16:08,583",
        "text": "Кое-кто мечтает о преимуществах, которые дает контроль над хексвратами."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:16:08,666 --> 00:16:11,458",
        "text": "И они не упустят шанс отнять ее у тебя."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:16:12,416 --> 00:16:15,291",
        "text": "Ты стал для всех врагом, Джейс."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:16:47,916 --> 00:16:49,500",
        "text": "Что такое, Майло?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:16:49,583 --> 00:16:52,916",
        "text": "Боишься, Паудер снова тебя уделает?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:17:40,500 --> 00:17:43,125",
        "text": "Ты приносишь неудачу!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:17:44,125 --> 00:17:47,208",
        "text": "Твоя сила в том, чем ты непохожа на других."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:17:55,125 --> 00:17:56,041",
        "text": "ПАУ ПАУ ПАУ 4406 ПОСЛЕДНЯЯ КАПЛЯ Не удивлюсь, если в подвале того бара куча трупов."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:18:48,000 --> 00:18:49,416",
        "text": "Ты ничего не знаешь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:01,875 --> 00:19:04,833",
        "text": "Я не могу рисковать безопасностью хексврат из-за такой ерунды."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:04,916 --> 00:19:09,291",
        "text": "Никто и не просит. Это лишь небольшие дружеские услуги."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:09,375 --> 00:19:11,458",
        "text": "Я не хотел ввязываться в политику."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:11,541 --> 00:19:12,958",
        "text": "Вы меня в это втянули."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:13,041 --> 00:19:16,333",
        "text": "Теперь ты символ будущего, Джейс — нравится тебе это или нет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:16,416 --> 00:19:19,916",
        "text": "И теперь ты можешь сам решать свою судьбу."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:20,666 --> 00:19:24,375",
        "text": "Совет уверен, что ты не справишься. Докажи, что они ошибаются."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:24,458 --> 00:19:25,500",
        "text": "В очередной раз."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:28,500 --> 00:19:30,916",
        "text": "Здравствуйте, Амара! Как малыш Рохан?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:31,000 --> 00:19:32,958",
        "text": "Советница Медарда."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:33,041 --> 00:19:34,416",
        "text": "Советник Талис."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:35,583 --> 00:19:37,791",
        "text": "Он развит не по годам."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:39,500 --> 00:19:42,125",
        "text": "Утром со мной случилось неприятное событие."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:42,208 --> 00:19:44,541",
        "text": "Ко мне заявились миротворцы."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:45,458 --> 00:19:48,708",
        "text": "Надеюсь, вы поймете. Джейс должен был показать, что принимает меры."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:48,791 --> 00:19:52,083",
        "text": "Но он здесь, чтобы обсудить всё лично."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:52,916 --> 00:19:55,833",
        "text": "Советник Талис готов вернуть торговые привилегии тем, кто разделяет его взгляды."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:57,875 --> 00:19:59,541",
        "text": "Мы можем надеяться на вас?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:19:59,625 --> 00:20:01,375",
        "text": "Советник Болбок считает, что выгоднее будет пойти другим путем."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:03,708 --> 00:20:05,458",
        "text": "Он глупец."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:05,541 --> 00:20:07,666",
        "text": "С ним вы будете инвестировать в прошлое."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:07,750 --> 00:20:10,583",
        "text": "А с нами — в будущее."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:12,916 --> 00:20:16,291",
        "text": "Советница Медарда права. Хексврата — это только начало."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:16,791 --> 00:20:20,708",
        "text": "Сейчас мы ищем новых партнеров для работы с хекстеком."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:20,791 --> 00:20:22,791",
        "text": "И вы, как покровительница дома Талисов, станете первой, кто получит наши изобретения."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:31,041 --> 00:20:34,000",
        "text": "Не могу отказаться от столь заманчивого предложения."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:37,000 --> 00:20:40,291",
        "text": "Партнерство в развитии хекстека? Хорошо звучит, не правда ли?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:41,666 --> 00:20:44,375",
        "text": "Публика ждет вас, советник."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:20:50,833 --> 00:20:55,375",
        "text": "Он оказался удачным вложением. Определенно. Превзошел ожидания."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:21:27,708 --> 00:21:30,291",
        "text": "АА Место, где обнажается истина."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:01,750 --> 00:22:05,625",
        "text": "Это было что-то. Прямо как фанфары."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:07,250 --> 00:22:10,375",
        "text": "Как именно мы это провернем?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:11,375 --> 00:22:12,708",
        "text": "Прикинься, что работаешь тут."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:13,416 --> 00:22:14,416",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:15,291 --> 00:22:16,416",
        "text": "Ни за что."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:16,500 --> 00:22:18,125",
        "text": "Знаешь, в чём твоя проблема?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:18,208 --> 00:22:19,750",
        "text": "Просвети меня."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:19,833 --> 00:22:21,916",
        "text": "Думаешь, что тебе все должны."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:22,000 --> 00:22:23,708",
        "text": "Если хочешь, чтобы с тобой говорили, сделай вид, что у тебя есть то, что им нужно."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:26,875 --> 00:22:28,541",
        "text": "А что у меня есть?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:31,208 --> 00:22:32,833",
        "text": "Ты красотка, кексик."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:35,000 --> 00:22:37,041",
        "text": "Так кто тебе нравится? Мальчики? Девочки?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:41,166 --> 00:22:43,333",
        "text": "Привет. Я Пим."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:43,416 --> 00:22:45,875",
        "text": "А тебя как зовут? Матильда."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:45,958 --> 00:22:50,166",
        "text": "Но можешь называть ее, как хочешь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:52,375 --> 00:22:54,416",
        "text": "Да. Матильда."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:22:54,500 --> 00:23:00,416",
        "text": "Родители назвали меня Матильдой в честь прабабушки Матильды, она… Смотрите, кто пожаловал."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:14,500 --> 00:23:17,750",
        "text": "Шериф, какой приятный сюрприз."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:18,750 --> 00:23:20,875",
        "text": "Наш гений хекстека стал членом совета и задает вопросы."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:23,625 --> 00:23:26,250",
        "text": "Рано или поздно он докопается до правды."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:27,500 --> 00:23:29,750",
        "text": "Правда — это история тех, кто выжил."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:29,833 --> 00:23:32,666",
        "text": "Если раскроют меня — нам обоим конец."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:33,333 --> 00:23:36,666",
        "text": "Как удачно, что ты доказал причастность Поджигателей."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:42,958 --> 00:23:44,541",
        "text": "Это зашло слишком далеко."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:48,500 --> 00:23:51,000",
        "text": "Воображаешь себя героем?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:23:51,083 --> 00:23:56,166",
        "text": "Одно движение — и станешь мучеником, которым всегда себя считал."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:04,125 --> 00:24:06,041",
        "text": "Чего же ты ждешь?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:19,625 --> 00:24:21,041",
        "text": "Он на грани."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:21,125 --> 00:24:23,875",
        "text": "Нужно сделать оружие на основе хекстека как можно скорее."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:23,958 --> 00:24:28,333",
        "text": "Тогда верхние будут бессильны против нас."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:28,416 --> 00:24:32,333",
        "text": "Я не смогу. Поручи это доктору."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:32,416 --> 00:24:35,333",
        "text": "Я могу доверить это только тебе, Джинкс."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:36,083 --> 00:24:39,375",
        "text": "Я всё время вижу их. Вижу тот день."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:43,833 --> 00:24:46,458",
        "text": "Страх преследует всех нас, Джинкс."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:48,500 --> 00:24:52,416",
        "text": "Милая, мне было так жаль Вандера."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:52,500 --> 00:24:55,625",
        "text": "И ребят. Как ужасно."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:56,208 --> 00:24:59,458",
        "text": "Похоже, никто пальцем не пошевелил, чтобы остановить Силко."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:24:59,541 --> 00:25:00,958",
        "text": "Кое-кто пытался."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:01,041 --> 00:25:04,000",
        "text": "Но у Силко есть люди и деньги."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:04,666 --> 00:25:06,041",
        "text": "Он присвоил «Последнюю каплю»."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:06,625 --> 00:25:07,791",
        "text": "Я видела."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:08,375 --> 00:25:11,083",
        "text": "Без Вандера всё изменилось: нас некому защитить."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:11,958 --> 00:25:14,958",
        "text": "Ты слышала что-нибудь о Паудер? Думаю, она у Силко."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:17,583 --> 00:25:18,666",
        "text": "Я должна ее найти."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:20,333 --> 00:25:22,625",
        "text": "Помощник Силко — наш постоянный клиент."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:22,708 --> 00:25:25,125",
        "text": "Мигель скажет тебе, где ее найти."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:26,291 --> 00:25:27,208",
        "text": "С меня причитается."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:30,458 --> 00:25:31,416",
        "text": "Пустяки."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:35,375 --> 00:25:39,708",
        "text": "Я никогда не была в саду. Только вот в таком, воображаемом."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:53,666 --> 00:25:55,000",
        "text": "Ты отлично справился."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:55,083 --> 00:25:56,625",
        "text": "У меня хорошая учительница."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:25:57,708 --> 00:26:00,291",
        "text": "Рано или поздно эти старые дураки из совета официально признают твои исследования."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:04,166 --> 00:26:06,458",
        "text": "Мой отец снабдил людей молотками, и они построили этот чудесный город."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:09,291 --> 00:26:12,583",
        "text": "Представь, что они смогут создать с помощью магии."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:13,666 --> 00:26:15,666",
        "text": "Мир уже не будет прежним."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:17,583 --> 00:26:20,166",
        "text": "Клан Медарда привык только брать."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:20,875 --> 00:26:23,583",
        "text": "Нечасто у нас есть возможность что-то ему дать."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:25,583 --> 00:26:27,250",
        "text": "Я бы не справился без тебя."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:55,708 --> 00:26:59,833",
        "text": "Какая красота! Не могу понять, почему не работает."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:26:59,916 --> 00:27:01,041",
        "text": "У вас получится."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:27:03,208 --> 00:27:07,666",
        "text": "А вы скоро домой? Могли бы вместе пройтись."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:27:07,750 --> 00:27:11,041",
        "text": "Я, наверное, сегодня переночую здесь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:27:11,125 --> 00:27:12,166",
        "text": "Опять?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:27:12,250 --> 00:27:14,708",
        "text": "Знаете ведь, утро вечера мудренее?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:27:15,416 --> 00:27:16,916",
        "text": "Доброй ночи, госпожа Янг."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:02,625 --> 00:29:07,458",
        "text": "Я чуть не утонул в этих водах. Ты рассказывал миллион раз."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:07,541 --> 00:29:10,333",
        "text": "Вандер был не таким, каким ты его считала."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:10,416 --> 00:29:12,958",
        "text": "Знаю, он был тебе как брат, а потом предал тебя, бла-бла-бла."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:16,541 --> 00:29:17,875",
        "text": "Ничего не упустила?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:19,625 --> 00:29:21,125",
        "text": "У меня есть новая история."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:27,583 --> 00:29:31,583",
        "text": "В тот день я дал умереть слабаку."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:40,375 --> 00:29:42,291",
        "text": "Я возродился другим."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:43,750 --> 00:29:45,041",
        "text": "Предательство."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:45,125 --> 00:29:49,791",
        "text": "Эта боль, которая съедает тебя изнутри."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:49,875 --> 00:29:51,708",
        "text": "Она может либо сломать тебя, либо сделать намного сильнее."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:55,625 --> 00:29:58,000",
        "text": "Дай Паудер умереть."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:29:58,916 --> 00:30:01,583",
        "text": "И страх боли больше не будет управлять тобой."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:30:04,250 --> 00:30:07,875",
        "text": "Теперь ты сильная. Такая, какой и должна быть."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:30:09,333 --> 00:30:10,791",
        "text": "Джинкс совершенна."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:31:23,333 --> 00:31:25,208",
        "text": "ПОЛИЦЕЙСКОЕ УПРАВЛЕНИЕ Джейс?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:31:57,500 --> 00:31:58,375",
        "text": "Виктор."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:31:59,041 --> 00:32:02,416",
        "text": "Врачи… Они говорят, что ты… Сколько мне осталось?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:32:13,958 --> 00:32:15,041",
        "text": "СМЕРТЬ, ВОЛШЕБНИК Не везет вам, парни!"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:32:28,125 --> 00:32:29,000",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:32:33,083 --> 00:32:36,333",
        "text": "Жалкая предательница. У Вандера был шанс."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:33:03,625 --> 00:33:05,291",
        "text": "Ты так и не научилась терпению."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:34:27,541 --> 00:34:29,041",
        "text": "Где моя сестра?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:34:29,125 --> 00:34:31,750",
        "text": "Где он ее держит? Держит?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:34:32,375 --> 00:34:33,416",
        "text": "Ты про Джинкс?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:34:35,125 --> 00:34:36,666",
        "text": "Она работает на него."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:34:48,833 --> 00:34:50,333",
        "text": "Она ему как дочь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:03,375 --> 00:35:05,125",
        "text": "Я передам ей привет."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:29,666 --> 00:35:31,041",
        "text": "Почему ты дала ей уйти?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:31,125 --> 00:35:32,875",
        "text": "Знаешь слово «спасибо»?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:32,958 --> 00:35:35,708",
        "text": "Теперь он узнает, что мы здесь. И чья это вина?"
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:41,583 --> 00:35:43,041",
        "text": "Неплохо стреляешь."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:43,125 --> 00:35:45,125",
        "text": "Я прекрасно стреляю."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:46,416 --> 00:35:50,041",
        "text": "Помоги встать, кексик. Не зови меня так."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:50,875 --> 00:35:52,125",
        "text": "Меня зовут Кейтлин."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:52,875 --> 00:35:54,000",
        "text": "Но ты такая сладкая."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:54,750 --> 00:35:55,833",
        "text": "Как кексик."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:35:57,416 --> 00:35:58,291",
        "text": "Заткнись."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:36:21,166 --> 00:36:22,833",
        "text": "Ты пачкаешь пол."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:36:42,083 --> 00:36:43,458",
        "text": "Сестра."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:36:44,041 --> 00:36:45,250",
        "text": "Она вернулась."
    },
    {
        "season": 1,
        "episode": 5,
        "time_code": "00:36:47,916 --> 00:36:49,166",
        "text": "С того света?"
    }
]