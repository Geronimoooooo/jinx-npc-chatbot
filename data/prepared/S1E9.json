[
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:40,083 --> 00:00:41,166",
        "text": "У тебя не было выбора."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:42,500 --> 00:00:45,041",
        "text": "Он знал, на что идет."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:47,833 --> 00:00:48,958",
        "text": "С меня хватит."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:49,541 --> 00:00:52,708",
        "text": "Да мы же только начали. Силко по-прежнему на свободе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:54,708 --> 00:00:57,708",
        "text": "Ты не понимаешь? Я теперь ничем не лучше него!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:00:59,250 --> 00:01:02,166",
        "text": "Из-за меня чей-то сын не вернется домой."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:03,250 --> 00:01:05,000",
        "text": "Я даже не знаю, что дальше."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:05,583 --> 00:01:07,000",
        "text": "Мы просто оставим его здесь?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:07,750 --> 00:01:09,708",
        "text": "Из-за тебя погибли уже многие!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:09,791 --> 00:01:12,375",
        "text": "Ты просто не хотел этого знать. Мальчик умер?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:12,458 --> 00:01:14,666",
        "text": "Они умирают сотнями. Из-за Силко и таких, как ты, кто прячет голову в песок."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:18,916 --> 00:01:21,000",
        "text": "Всё кончено. Не для меня."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:23,916 --> 00:01:25,666",
        "text": "Сними их сейчас же."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:31,541 --> 00:01:32,958",
        "text": "Не дождешься."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:38,333 --> 00:01:40,166",
        "text": "Я не дам тебе в них уйти."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:40,250 --> 00:01:42,833",
        "text": "Тогда тебе придется убить еще одного оборванца."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:01:59,375 --> 00:02:00,708",
        "text": "Ты не справишься в одиночку."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:41,208 --> 00:03:44,250",
        "text": "Давненько верхние так не наглели."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:44,333 --> 00:03:47,625",
        "text": "Что бы ни говорили о покойном шерифе - а польза от него была."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:48,291 --> 00:03:50,083",
        "text": "Жаль, Джинкс этого не поняла."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:51,333 --> 00:03:52,958",
        "text": "Купим другого."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:53,500 --> 00:03:55,125",
        "text": "Ты хоть что-нибудь сделаешь, чтобы отомстить уроду, который убил моего мальчика?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:03:58,125 --> 00:04:01,500",
        "text": "Дай угадаю: Джинкс обо всем позаботится?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:01,583 --> 00:04:04,541",
        "text": "У нее же это просто отлично получается!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:06,041 --> 00:04:11,083",
        "text": "Мы все скорбим о твоем сыне, Ренни."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:11,625 --> 00:04:18,416",
        "text": "Но пусть тебя утешит мысль, что он погиб, сражаясь за общее дело, а не в нелепой потасовке, какие здесь не редкость."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:25,250 --> 00:04:28,708",
        "text": "Не смей мне говорить о жертвах ради дела."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:29,583 --> 00:04:31,208",
        "text": "Где твоя Джинкс?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:04:33,125 --> 00:04:34,916",
        "text": "Помоги ей с телом."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:05:14,833 --> 00:05:18,958",
        "text": "Виктор, вероятно, ты никогда этого не прочтешь, но видя, как ты упорно трудишься день и ночь, чтобы сделать мир лучше… Я просто обязана была попытаться."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:05:29,541 --> 00:05:31,708",
        "text": "Каждый должен внести свой вклад, так?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:15,000 --> 00:06:16,083",
        "text": "Ладно."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:33,333 --> 00:06:35,791",
        "text": "Ноксианские вина намного крепче."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:35,875 --> 00:06:37,375",
        "text": "В суровом климате виноград становится лучше."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:37,458 --> 00:06:41,458",
        "text": "Как и всё, чему удается выжить в Ноксусе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:45,250 --> 00:06:46,500",
        "text": "Мэл, не желаешь… Вон!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:06:58,375 --> 00:06:59,916",
        "text": "Оставь Джейса в покое!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:00,000 --> 00:07:01,416",
        "text": "Ты и правда от него без ума."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:01,500 --> 00:07:05,166",
        "text": "А лучше садись на корабль и убирайся из моего города."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:06,583 --> 00:07:09,208",
        "text": "Держи себя в руках. Я тебя не так воспитывала."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:26,208 --> 00:07:27,625",
        "text": "У нас неприятности, Мэл."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:28,166 --> 00:07:31,250",
        "text": "Убийца твоего брата никак не успокоится, а его возможности превосходят наши."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:33,625 --> 00:07:37,125",
        "text": "Единственная надежда - что хекстек можно использовать как оружие."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:37,208 --> 00:07:39,541",
        "text": "Пилтовер не твой испытательный полигон."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:39,625 --> 00:07:42,291",
        "text": "Я лишь ускорила то, что начала ты сама."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:42,375 --> 00:07:45,125",
        "text": "Я хотела защитить город от таких, как ты."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:45,666 --> 00:07:49,333",
        "text": "Неужели ты готова начать войну, только чтобы прикрыть свой зад?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:49,416 --> 00:07:52,916",
        "text": "Я готова спалить весь мир, чтобы защитить нашу семью."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:53,000 --> 00:07:54,166",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:07:54,250 --> 00:07:58,333",
        "text": "Я перестала быть частью семьи в тот момент, когда ты меня прогнала."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:00,291 --> 00:08:02,958",
        "text": "Почему? Почему ты так поступила?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:03,750 --> 00:08:05,416",
        "text": "Ты была моей слабостью!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:05,500 --> 00:08:08,791",
        "text": "Я не могла выносить, как ты смотрела на меня каждый раз, когда я принимала суровые решения ради нашей безопасности!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:19,041 --> 00:08:20,458",
        "text": "Нам нужно это оружие, Мэл."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:22,750 --> 00:08:24,291",
        "text": "Пусть начнется война."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:26,083 --> 00:08:27,291",
        "text": "А ты вернешься домой и займешь свое место рядом со мной."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:31,833 --> 00:08:33,291",
        "text": "Там, где тебе положено быть."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:44,875 --> 00:08:45,750",
        "text": "Прости."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:08:46,708 --> 00:08:49,375",
        "text": "Я не знаю, где ты сама бы хотела… Прости меня."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:27,458 --> 00:09:28,458",
        "text": "Не помешаю?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:41,375 --> 00:09:44,041",
        "text": "Помнишь конкурс выдающихся изобретений?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:45,333 --> 00:09:48,416",
        "text": "Помню, как ты на ходу подгонял шестеренки."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:49,833 --> 00:09:52,500",
        "text": "Она так тряслась, когда завели двигатель!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:52,583 --> 00:09:54,875",
        "text": "Я боялся, из нее вылетит болт и выбьет кому-нибудь глаз."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:56,125 --> 00:09:58,291",
        "text": "По крайней мере тебя не стошнило."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:09:59,875 --> 00:10:01,500",
        "text": "Тогда всё казалось таким простым."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:05,000 --> 00:10:06,541",
        "text": "Ты должен уничтожить его."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:08,125 --> 00:10:08,958",
        "text": "Знаю."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:09,750 --> 00:10:10,583",
        "text": "Хекстековое ядро."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:13,083 --> 00:10:15,500",
        "text": "Я сам не могу."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:16,750 --> 00:10:19,083",
        "text": "Это должен сделать ты. Пожалуйста."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:22,625 --> 00:10:25,208",
        "text": "А как же ты? Без хекстекового ядра… Пообещай мне."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:32,791 --> 00:10:34,583",
        "text": "Хорошо."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:35,541 --> 00:10:36,791",
        "text": "Я обещаю."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:38,583 --> 00:10:41,500",
        "text": "Мы забыли, кто мы и о чём мы мечтали."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:42,083 --> 00:10:46,875",
        "text": "В погоне за величием мы разучились делать добро."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:48,875 --> 00:10:50,500",
        "text": "Мы должны всё исправить."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:10:55,375 --> 00:10:56,291",
        "text": "Я занят."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:16,916 --> 00:11:19,708",
        "text": "Когда ты убрал Вандера, я подумал: «Наконец-то нашелся тот, кто знает, как вести бизнес»."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:24,041 --> 00:11:26,958",
        "text": "Деловой подход, чутье, интуиция."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:27,458 --> 00:11:29,041",
        "text": "У тебя было всё, что требуется."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:29,875 --> 00:11:33,083",
        "text": "Всегда на два шага впереди."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:34,125 --> 00:11:36,625",
        "text": "Но время тебя не пощадило, старина."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:40,958 --> 00:11:42,375",
        "text": "Ты с ним, как я понимаю?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:42,958 --> 00:11:44,625",
        "text": "Ты облажался, Силко."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:48,125 --> 00:11:50,458",
        "text": "Ты молод и не помнишь, как жилось в нижнем городе до того, как мы начали «бизнес»."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:54,250 --> 00:11:55,250",
        "text": "У нас не было ничего."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:11:56,125 --> 00:11:58,208",
        "text": "Знаешь, что помогло нам выстоять?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:00,583 --> 00:12:01,875",
        "text": "Преданность."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:02,791 --> 00:12:06,291",
        "text": "Мы помогали друг другу справиться с любыми проблемами."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:07,166 --> 00:12:11,125",
        "text": "А теперь я вынужден дышать одним воздухом с паразитами вроде тебя, которые привыкли жить за чужой счет."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:15,291 --> 00:12:18,291",
        "text": "Сегодня ты умрешь, Силко."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:18,916 --> 00:12:21,083",
        "text": "Я всегда знал, что это может случиться."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:22,583 --> 00:12:25,166",
        "text": "Но я до сих пор верю в преданность."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:54,666 --> 00:12:56,833",
        "text": "За такое я убил бы твоего сына."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:12:56,916 --> 00:12:59,583",
        "text": "Но меня уже опередили."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:13:00,333 --> 00:13:01,416",
        "text": "Убирайся."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:13:08,750 --> 00:13:09,875",
        "text": "Был соблазн?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:13:10,625 --> 00:13:12,500",
        "text": "Не ради такого червяка, как он."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:13:15,166 --> 00:13:16,791",
        "text": "Но он не последний."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:13:56,541 --> 00:13:58,000",
        "text": "Идеальное место для засады."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:02,125 --> 00:14:03,625",
        "text": "А ты не взял молот."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:07,083 --> 00:14:10,125",
        "text": "Мне недавно напомнили о том, что когда-то свело нас вместе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:10,708 --> 00:14:12,583",
        "text": "Враги за стенами."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:13,500 --> 00:14:15,291",
        "text": "Этот город быстро все забывает."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:15,958 --> 00:14:16,958",
        "text": "Цена прогресса."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:18,500 --> 00:14:20,833",
        "text": "Я не тот, кто встанет у него на пути."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:40,125 --> 00:14:42,666",
        "text": "Свободная торговля, всеобщая амнистия, неограниченный доступ к хексвратам, независимость?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:46,083 --> 00:14:48,458",
        "text": "Вы всерьез думаете, что вправе требовать всего этого?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:48,541 --> 00:14:51,458",
        "text": "Я оценил твою выходку, юноша."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:51,541 --> 00:14:53,500",
        "text": "Не думал, что ты на такое способен."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:14:54,083 --> 00:14:56,708",
        "text": "Но просьба о встрече после нападения говорит сама за себя."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:02,041 --> 00:15:03,083",
        "text": "Тебе страшно."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:03,875 --> 00:15:04,916",
        "text": "Да, мне страшно."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:05,541 --> 00:15:08,375",
        "text": "Сегодня я увидел, к чему может привести война между нами."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:09,583 --> 00:15:11,708",
        "text": "У вас нет шансов."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:12,500 --> 00:15:13,791",
        "text": "Совету плевать на это."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:15,375 --> 00:15:17,625",
        "text": "Я пытаюсь сделать так, чтобы вас всех не перебили."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:21,250 --> 00:15:22,208",
        "text": "Так, так."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:22,958 --> 00:15:26,083",
        "text": "А ты уже не тот наивный студент."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:26,916 --> 00:15:28,916",
        "text": "Хочешь мира - вот моя цена."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:31,000 --> 00:15:32,916",
        "text": "Вы остановите производство мерцания?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:33,000 --> 00:15:34,083",
        "text": "Уже останавливаем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:34,708 --> 00:15:35,791",
        "text": "Вернете самоцвет?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:37,458 --> 00:15:38,500",
        "text": "И мне нужна Джинкс."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:39,166 --> 00:15:41,000",
        "text": "Она должна ответить за свои преступления."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:41,916 --> 00:15:44,958",
        "text": "Это не ее преступления. Она работала на меня."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:45,666 --> 00:15:49,583",
        "text": "Поверьте, я бы с удовольствием отправил вас в «Тихий омут»."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:50,458 --> 00:15:53,416",
        "text": "Но отрубив змее голову, я ничего не добьюсь."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:53,500 --> 00:15:55,083",
        "text": "Это дрянная сделка для нас обоих."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:15:56,583 --> 00:15:59,666",
        "text": "Выдайте мне Джинкс, и я дам вам свободный Заун."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:32,916 --> 00:16:33,916",
        "text": "Потрясающе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:34,625 --> 00:16:37,583",
        "text": "И всё это появилось за вашу недолгую жизнь?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:38,333 --> 00:16:41,791",
        "text": "Как вам удалось сделать так много и так быстро?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:41,875 --> 00:16:45,125",
        "text": "Чего только не сделаешь, когда от этого зависит твоя жизнь."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:47,500 --> 00:16:48,958",
        "text": "Но зачем такой траспорт?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:49,041 --> 00:16:53,000",
        "text": "Ведь есть куда более практичные и безопасные способы передвижения."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:16:54,458 --> 00:16:56,208",
        "text": "Поджигатели!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:04,791 --> 00:17:06,958",
        "text": "Мало обеспечить людям выживание, нужно дать им то, ради чего стоит жить."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:20,500 --> 00:17:23,500",
        "text": "Я столько раз представлял себе этот момент."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:25,000 --> 00:17:26,291",
        "text": "Но только не так."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:27,750 --> 00:17:29,083",
        "text": "Всё, о чём мы мечтали."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:30,208 --> 00:17:31,791",
        "text": "Мальчишка даже не торговался."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:33,166 --> 00:17:35,291",
        "text": "И что я теряю, кроме проблем?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:37,875 --> 00:17:40,041",
        "text": "Теперь я понимаю, брат."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:17:54,375 --> 00:17:58,333",
        "text": "От дочерей одни беды."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:18:05,583 --> 00:18:10,500",
        "text": "ПОСЛЕДНЯЯ КАПЛЯ Отвали."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:19:12,708 --> 00:19:14,916",
        "text": "Все вон."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:20:00,958 --> 00:20:03,791",
        "text": "ПОСЛЕДНЯЯ КАПЛЯ Да уж, защита у тебя хромает."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:11,750 --> 00:21:14,083",
        "text": "Хотел бы я сказать, что время лечит."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:14,791 --> 00:21:16,208",
        "text": "Но это вранье."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:17,166 --> 00:21:20,625",
        "text": "Скажу лишь одно: ты по-прежнему нужна ей."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:20,708 --> 00:21:22,416",
        "text": "Им всем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:22,916 --> 00:21:24,291",
        "text": "Так что будешь делать?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:21:31,625 --> 00:21:32,750",
        "text": "Вот умница."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:22:43,291 --> 00:22:44,625",
        "text": "Силко."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:22:58,250 --> 00:22:59,625",
        "text": "Браво, сестричка."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:05,416 --> 00:23:09,291",
        "text": "Советники, мой недавний самовольный рейд по нижнему городу позволил мне понять две вещи."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:12,541 --> 00:23:15,250",
        "text": "Я не могу управлять его жителями."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:15,916 --> 00:23:17,208",
        "text": "И вы тоже."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:17,958 --> 00:23:20,416",
        "text": "Мы упустили шанс проявить к ним сочувствие, внимание, заботу."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:27,333 --> 00:23:29,333",
        "text": "Не удивительно, что они нам не доверяют."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:29,416 --> 00:23:31,750",
        "text": "Ты ступил на тонкий лед, Джейс."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:33,125 --> 00:23:36,625",
        "text": "При всём уважении - мне уже плевать, что вы все обо мне думаете."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:39,666 --> 00:23:40,541",
        "text": "Кроме тебя."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:41,541 --> 00:23:42,458",
        "text": "Ты была права."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:43,125 --> 00:23:44,250",
        "text": "С самого начала."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:45,333 --> 00:23:48,208",
        "text": "Я знаю, что недолго пробуду советником, но здесь со мной Виктор, мой партнер из Зауна, и у нас есть последнее предложение."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:54,625 --> 00:23:58,000",
        "text": "Джейс заключил мирный договор с Силко."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:23:59,000 --> 00:24:02,833",
        "text": "С условием предоставить нижнему городу независимость."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:24:03,416 --> 00:24:06,541",
        "text": "Что? Неслыханно! Есть протокол… Я-то думала, что этого места не стало."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:24:45,958 --> 00:24:48,625",
        "text": "Но, похоже, я ошибалась."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:24:49,791 --> 00:24:50,875",
        "text": "Паудер?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:24:50,958 --> 00:24:53,791",
        "text": "Никто не хочет оставаться мертвым."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:24:57,625 --> 00:24:58,916",
        "text": "Мы тут одни?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:00,166 --> 00:25:01,791",
        "text": "Пока да."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:02,916 --> 00:25:04,375",
        "text": "А может, всегда будем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:06,375 --> 00:25:07,916",
        "text": "Хочешь, открою секрет?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:09,541 --> 00:25:11,375",
        "text": "Силко думает, что он создал Джинкс своей пустой болтовней и жестокими уроками."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:17,125 --> 00:25:19,958",
        "text": "«Избавься от сомнений, Джинкс»."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:20,041 --> 00:25:21,833",
        "text": "«Заставь их бояться, Джинкс»."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:21,916 --> 00:25:25,958",
        "text": "Как будто после их с Вандером ссоры время остановилось."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:26,833 --> 00:25:29,708",
        "text": "Но не он создал Джинкс."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:31,125 --> 00:25:32,333",
        "text": "А ты."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:34,750 --> 00:25:36,166",
        "text": "Прости меня, Паудер."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:37,250 --> 00:25:39,000",
        "text": "Я не должна была оставлять тебя одну."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:39,750 --> 00:25:41,125",
        "text": "А я и не была одна."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:42,125 --> 00:25:43,791",
        "text": "Я всегда тебя слышала."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:43,875 --> 00:25:48,458",
        "text": "Тени на улицах, мурашки по спине."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:49,833 --> 00:25:51,708",
        "text": "Твой голос."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:52,291 --> 00:25:54,041",
        "text": "Не давал мне отчаяться."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:54,125 --> 00:25:57,250",
        "text": "Придавал сил, когда вокруг был сплошной мрак."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:25:58,708 --> 00:26:00,541",
        "text": "Я жива лишь благодаря тебе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:01,708 --> 00:26:04,375",
        "text": "Я провела столько ночей в той поганой тюрьме."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:04,458 --> 00:26:08,458",
        "text": "Лежала на ледяном полу, голодная и избитая, и считала часы."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:10,000 --> 00:26:11,291",
        "text": "Единственное… Единственное, что помогало мне держаться - желание вернуться к тебе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:19,958 --> 00:26:22,833",
        "text": "Мы по-прежнему сестры?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:24,375 --> 00:26:27,333",
        "text": "Конечно, и всегда будем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:31,625 --> 00:26:34,750",
        "text": "Я знала, что ты вернешься. Что ты делаешь?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:51,125 --> 00:26:53,125",
        "text": "Он забрал у нас всё."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:54,125 --> 00:26:56,375",
        "text": "Здесь он вонзил Вандеру нож в спину."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:26:56,458 --> 00:26:58,166",
        "text": "И со мной собирался поступить так же."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:01,666 --> 00:27:04,916",
        "text": "Всё твердил, что ты бросила меня, хотя знал правду."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:06,416 --> 00:27:07,541",
        "text": "Лжец."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:10,750 --> 00:27:12,166",
        "text": "Кого-то не хватает."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:42,958 --> 00:27:45,333",
        "text": "Я навестила сегодня твою подружку."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:46,916 --> 00:27:47,958",
        "text": "Что ты сделала?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:48,833 --> 00:27:50,000",
        "text": "Вкусняшку."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:27:56,500 --> 00:27:57,666",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:01,041 --> 00:28:02,375",
        "text": "Я же не настолько чокнутая."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:13,541 --> 00:28:15,791",
        "text": "Паудер! Она тут ни при чём."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:21,875 --> 00:28:22,833",
        "text": "Итак… А где место для меня?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:28,708 --> 00:28:30,291",
        "text": "ПАУДЕР Выбор за тобой."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:35,166 --> 00:28:37,291",
        "text": "ДЖИНКС Избавься от нее. Пожалуйста."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:44,291 --> 00:28:45,875",
        "text": "Пусть она исчезнет, и… И тогда Паудер вернется к тебе."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:53,833 --> 00:28:54,875",
        "text": "Я не могу."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:56,833 --> 00:28:58,916",
        "text": "Нет! Паудер, послушай."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:28:59,000 --> 00:29:01,375",
        "text": "Мы можем уехать."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:01,458 --> 00:29:03,166",
        "text": "Уедем и никогда сюда не вернемся."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:04,291 --> 00:29:05,375",
        "text": "И куда мы поедем?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:05,958 --> 00:29:08,666",
        "text": "Нет. Она же не это сказала."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:09,500 --> 00:29:11,500",
        "text": "Поверь мне, это всё останется в прошлом."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:11,583 --> 00:29:13,833",
        "text": "Тебе больше не придется иметь с ним дело, Паудер!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:17,250 --> 00:29:19,041",
        "text": "А ты что хочешь сказать?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:21,333 --> 00:29:23,708",
        "text": "Ее зовут Джинкс!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:23,791 --> 00:29:25,041",
        "text": "Она лжет."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:25,125 --> 00:29:27,250",
        "text": "Ровно через день она поймет, что ты уже не та милая девчушка, и отвернется от тебя."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:32,500 --> 00:29:34,166",
        "text": "Ты же не врешь?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:34,250 --> 00:29:37,000",
        "text": "Ты не стала бы мне врать. Снова."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:37,083 --> 00:29:38,166",
        "text": "Я не вру."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:38,250 --> 00:29:40,541",
        "text": "Я на твоей стороне. Даю слово."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:47,541 --> 00:29:50,500",
        "text": "Заткнись! Мы разговариваем!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:50,583 --> 00:29:52,875",
        "text": "Пилтошки предложили мне всё: независимость, право голоса - в обмен на тебя."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:29:57,791 --> 00:29:59,708",
        "text": "Что б они сдохли!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:00,250 --> 00:30:04,125",
        "text": "Все предали нас, Джинкс. Вандер. Она."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:04,958 --> 00:30:06,875",
        "text": "Им никогда не понять."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:08,125 --> 00:30:09,458",
        "text": "Есть только ты и я."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:11,375 --> 00:30:12,500",
        "text": "Ты моя дочь."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:14,208 --> 00:30:15,750",
        "text": "Я никогда тебя не брошу."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:18,625 --> 00:30:19,708",
        "text": "Брось оружие!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:33,583 --> 00:30:35,791",
        "text": "Не надо. Пожалуйста."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:45,375 --> 00:30:46,458",
        "text": "Забудь о них."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:47,416 --> 00:30:48,791",
        "text": "Нет! Стой!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:49,958 --> 00:30:51,666",
        "text": "Брось оружие."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:30:59,708 --> 00:31:02,583",
        "text": "Стой! Она моя сестра."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:03,833 --> 00:31:05,541",
        "text": "Вай, ее уже не спасти."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:18,208 --> 00:31:19,500",
        "text": "Нет, не надо."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:28,583 --> 00:31:29,583",
        "text": "Берегись!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:35,458 --> 00:31:37,833",
        "text": "Видишь? Пора с этим покончить."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:38,583 --> 00:31:41,125",
        "text": "Нет же! Паудер! Приди в себя!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:41,208 --> 00:31:44,000",
        "text": "Вспомни, кто ты! Я же знаю, ты не забыла!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:46,166 --> 00:31:50,791",
        "text": "Вспомни Майло! Клаггора! Прекрати."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:50,875 --> 00:31:53,041",
        "text": "Вандера! Заткнись! Не слушай ее!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:53,125 --> 00:31:55,291",
        "text": "Папу!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:56,625 --> 00:31:58,208",
        "text": "Маму!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:31:59,458 --> 00:32:00,666",
        "text": "Меня!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:32:04,583 --> 00:32:05,750",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:32:06,916 --> 00:32:08,541",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:32:45,166 --> 00:32:46,791",
        "text": "Нет… Нет."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:32:48,541 --> 00:32:52,333",
        "text": "Прости меня… Я бы никогда тебя им не отдал."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:32:58,750 --> 00:33:00,000",
        "text": "Ни за что на свете."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:02,291 --> 00:33:03,458",
        "text": "Не плачь."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:04,458 --> 00:33:06,125",
        "text": "Ты совершенна."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:37,041 --> 00:33:38,250",
        "text": "Паудер?"
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:40,791 --> 00:33:41,958",
        "text": "Всё нормально."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:44,708 --> 00:33:45,875",
        "text": "Мы со всем справимся."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:33:48,500 --> 00:33:50,500",
        "text": "ДЖИНКС Я думала, ты будешь любить меня, как раньше."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:34:19,000 --> 00:34:22,250",
        "text": "Хоть я теперь и другая."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:34:28,750 --> 00:34:30,458",
        "text": "Но ты тоже изменилась."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:34:32,208 --> 00:34:33,333",
        "text": "Что ж… За новых нас."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:35:16,416 --> 00:35:17,541",
        "text": "Мы им покажем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:35:19,250 --> 00:35:20,750",
        "text": "Мы им всем покажем."
    },
    {
        "season": 1,
        "episode": 9,
        "time_code": "00:35:31,958 --> 00:35:35,416",
        "text": "Я поддерживаю предложение советника Талиса о мире."
    }
]