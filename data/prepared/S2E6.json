[
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:00:44,500 --> 00:00:46,125",
        "text": "Теперь я это вижу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:00:53,916 --> 00:00:55,416",
        "text": "Не могу позволить тебе уйти."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:00:57,500 --> 00:00:59,915",
        "text": "Мне жаль, что ты так считаешь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:00:59,916 --> 00:01:01,375",
        "text": "Мне тоже жаль."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:19,625 --> 00:01:21,125",
        "text": "Бедный Сейло."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:21,708 --> 00:01:23,499",
        "text": "Это не Джейс."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:23,500 --> 00:01:26,333",
        "text": "В нём присутствует и другая воля."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:27,166 --> 00:01:31,040",
        "text": "Мне показалось, что я что-то слышала перед закрытием портала."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:31,041 --> 00:01:32,582",
        "text": "Что-то древнее..."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:32,583 --> 00:01:33,916",
        "text": "Голос."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:35,166 --> 00:01:38,208",
        "text": "Это сложное колдовство."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:38,916 --> 00:01:40,332",
        "text": "Сингулярность, одновременно самовоспроизводящаяся и самоуничтожающаяся."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:44,791 --> 00:01:47,708",
        "text": "Мы никогда не видели такой сложной системы."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:01:49,250 --> 00:01:50,458",
        "text": "Безупречный... ...изысканный... ...хаос."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:06,291 --> 00:03:08,291",
        "text": "Аркейн Ноксус ценит силу превыше всего, определяя ее тремя основными принципами."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:26,125 --> 00:03:27,000",
        "text": "Видение."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:27,625 --> 00:03:29,250",
        "text": "Вершина треугольника."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:30,000 --> 00:03:33,583",
        "text": "Наметь курс и будь мудр, чтобы следовать ему."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:34,416 --> 00:03:37,332",
        "text": "Эта форма – твоя основа, дитя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:37,333 --> 00:03:40,250",
        "text": "Твои глаза видят то, чего не видят другие."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:41,625 --> 00:03:42,458",
        "text": "Могущество."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:43,125 --> 00:03:46,625",
        "text": "Подчини окружение своей воле."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:47,625 --> 00:03:50,082",
        "text": "Твоя скорость улучшается."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:50,083 --> 00:03:53,250",
        "text": "Но в конце концов тебе понадобится сила."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:03:56,791 --> 00:03:59,833",
        "text": "Слишком большая сила подвергает риску."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:01,375 --> 00:04:02,333",
        "text": "Правда."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:06,833 --> 00:04:09,416",
        "text": "Последнее – это хитрость."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:10,458 --> 00:04:11,665",
        "text": "Призраки."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:11,666 --> 00:04:13,125",
        "text": "Фокусники."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:13,916 --> 00:04:14,915",
        "text": "Маги."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:14,916 --> 00:04:16,333",
        "text": "Отсутствие чести."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:17,041 --> 00:04:18,833",
        "text": "Отсутствие контроля."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:24,833 --> 00:04:26,208",
        "text": "Помни об этом, Кейтлин."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:27,791 --> 00:04:29,291",
        "text": "Глубина в твоих глазах."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:29,958 --> 00:04:31,458",
        "text": "Лава в твоих венах."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:32,125 --> 00:04:34,166",
        "text": "Тени в твоем сердце."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:37,208 --> 00:04:39,416",
        "text": "Вот истина боя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:41,416 --> 00:04:43,791",
        "text": "Я открыла для себя четвертый принцип."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:44,333 --> 00:04:47,208",
        "text": "Тот, что усиливает все остальные."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:48,541 --> 00:04:50,582",
        "text": "Жертвоприношение."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:50,583 --> 00:04:52,583",
        "text": "Нрав, рожденный страданием."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:53,250 --> 00:04:56,208",
        "text": "Мы понимаем его так, как не понимают другие."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:04:56,916 --> 00:04:58,916",
        "text": "Мы родня."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:03,875 --> 00:05:05,041",
        "text": "Простите, что прерываю."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:07,041 --> 00:05:09,125",
        "text": "Я отследил его до Зауна."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:10,666 --> 00:05:12,791",
        "text": "Устроим охоту на зверя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:34,583 --> 00:05:35,416",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:36,083 --> 00:05:37,583",
        "text": "Я надеялся, что ты вернешься."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:38,625 --> 00:05:40,375",
        "text": "Ты мерзкий предатель."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:41,833 --> 00:05:42,666",
        "text": "Да."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:43,208 --> 00:05:45,124",
        "text": "Это был худший я."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:45,125 --> 00:05:46,333",
        "text": "Просто ужас."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:47,083 --> 00:05:50,374",
        "text": "Но Механический вестник освободил меня от моего прошлого."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:50,375 --> 00:05:53,416",
        "text": "Он дал мне шанс всё исправить."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:55,083 --> 00:05:57,707",
        "text": "Извините. Воды? Мы рады всем."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:05:57,708 --> 00:06:01,374",
        "text": "Но я должен попросить сдать оружие."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:06:01,375 --> 00:06:03,125",
        "text": "Это место мира."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:06:44,250 --> 00:06:45,541",
        "text": "Добро пожаловать, вы двое."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:06:46,791 --> 00:06:47,875",
        "text": "Привет, дружочек."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:06:49,750 --> 00:06:51,125",
        "text": "Хочешь фруктов?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:06:53,375 --> 00:06:55,208",
        "text": "Видение Механического вестника."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:07:23,583 --> 00:07:26,041",
        "text": "Пойдемте, он вас ждет."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:08:00,208 --> 00:08:02,000",
        "text": "Говорят, ты можешь исцелять людей."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:08:58,333 --> 00:08:59,166",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:00,000 --> 00:09:03,958",
        "text": "Однажды ты сказал мне, что у всех систем есть пределы."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:07,041 --> 00:09:09,583",
        "text": "Он стоит того, чтобы рискнуть."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:18,458 --> 00:09:22,416",
        "text": "Дух Вандера тесно переплетен с духом зверя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:23,000 --> 00:09:24,500",
        "text": "Как ты узнал его имя?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:25,041 --> 00:09:26,665",
        "text": "Он сказал мне."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:26,666 --> 00:09:28,957",
        "text": "Обратитесь к чудо-целителю, получите печенье с предсказаниями."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:32,208 --> 00:09:34,041",
        "text": "Я видел твоего отца."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:34,833 --> 00:09:39,249",
        "text": "Его мечты о вашей семье и представления о том, каким мог бы стать Заун, были... восхитительными."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:43,000 --> 00:09:43,875",
        "text": "Печенье."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:45,208 --> 00:09:46,208",
        "text": "Можешь ему помочь?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:46,916 --> 00:09:49,208",
        "text": "Я сделаю всё, что в моих силах."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:51,041 --> 00:09:54,207",
        "text": "Однако у меня есть одно условие."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:54,208 --> 00:09:55,791",
        "text": "Похоже, у тебя их несколько."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:09:56,875 --> 00:10:00,000",
        "text": "Ты можешь многое предложить этой общине, Паудер."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:04,916 --> 00:10:09,125",
        "text": "Твои таланты можно использовать для созидания, а не для разрушения."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:09,791 --> 00:10:13,208",
        "text": "Буду придерживаться того, что умею, спасибо."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:14,583 --> 00:10:17,832",
        "text": "Мое условие – ночью он должен быть закован."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:17,833 --> 00:10:21,666",
        "text": "Я видел, на какой ужас он способен."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:24,708 --> 00:10:25,791",
        "text": "Что думаешь?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:27,791 --> 00:10:31,791",
        "text": "Ты правда хочешь знать мое мнение?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:38,041 --> 00:10:39,916",
        "text": "Я ненавижу печенье с предсказаниями."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:10:43,500 --> 00:10:45,916",
        "text": "Мы вытащим тебя оттуда, Вандер."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:12:42,250 --> 00:12:44,625",
        "text": "Мои девочки. Пау-Пау, иди ко мне."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:20,916 --> 00:13:22,916",
        "text": "ВАЙОЛЕТ Ты их помнишь?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:35,708 --> 00:13:37,791",
        "text": "Лучше всего я помню мамин запах."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:39,291 --> 00:13:40,500",
        "text": "Смазка для подшипников."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:43,000 --> 00:13:44,250",
        "text": "Это место."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:46,333 --> 00:13:48,166",
        "text": "Думаешь, получится?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:48,708 --> 00:13:52,875",
        "text": "Подземная утопия, которой управляет тощий Механический вестник."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:53,416 --> 00:13:55,833",
        "text": "Может, когда Пилтовер скатится в отстойник."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:13:59,166 --> 00:14:00,750",
        "text": "А если мы останемся?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:01,583 --> 00:14:02,541",
        "text": "Поможем им?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:04,750 --> 00:14:05,583",
        "text": "«Мы»?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:23,708 --> 00:14:24,708",
        "text": "Вперед."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:34,333 --> 00:14:35,166",
        "text": "Стоять."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:37,333 --> 00:14:38,375",
        "text": "Никакого оружия."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:39,125 --> 00:14:40,916",
        "text": "Это требование Механического вестника."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:57,250 --> 00:14:58,541",
        "text": "Позвольте."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:14:59,333 --> 00:15:03,040",
        "text": "Полагаю, что Механический вестник – мой бывший ученик."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:03,041 --> 00:15:04,957",
        "text": "Человек науки."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:04,958 --> 00:15:06,375",
        "text": "Позвольте поговорить с ним."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:17,708 --> 00:15:19,749",
        "text": "Готовьте войска к сегодняшней ночи."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:19,750 --> 00:15:22,375",
        "text": "Я хочу познакомиться с этим Механическим вестником."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:51,625 --> 00:15:53,666",
        "text": "Ты чувствуешь это, верно?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:54,375 --> 00:15:55,541",
        "text": "Упадок сил?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:15:59,000 --> 00:16:01,249",
        "text": "Твоя сила ограничена и уменьшается с каждым использованием."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:03,833 --> 00:16:06,041",
        "text": "Я ждал вас, доктор."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:07,291 --> 00:16:08,624",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:08,625 --> 00:16:10,083",
        "text": "Невероятно."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:10,666 --> 00:16:14,165",
        "text": "Чего бы я только не отдал, чтобы взглянуть на мир твоими глазами."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:14,166 --> 00:16:15,958",
        "text": "Знать то, что знаешь ты."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:17,833 --> 00:16:21,624",
        "text": "Поиски сбили его с проторенного пути."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:21,625 --> 00:16:24,499",
        "text": "Его собственная тень растворилась во тьме."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:24,500 --> 00:16:27,500",
        "text": "Теперь остается только идти вперед."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:28,375 --> 00:16:31,916",
        "text": "Единственное утешение – мечта о ее танце."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:34,750 --> 00:16:36,749",
        "text": "Знание – это парадокс."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:36,750 --> 00:16:38,415",
        "text": "Чем больше человек познает, тем больше он видит глубину своего невежества."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:45,625 --> 00:16:48,208",
        "text": "Чудесный экземпляр, не правда ли?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:49,291 --> 00:16:53,166",
        "text": "Регенеративные свойства его крови укрепят тебя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:16:53,875 --> 00:16:56,915",
        "text": "Пик Мерцания в сочетании с тобой – наивысшая форма Хекстека."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:00,500 --> 00:17:03,000",
        "text": "То, что вы предлагаете, уничтожит его."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:03,833 --> 00:17:04,875",
        "text": "И ради чего?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:05,500 --> 00:17:06,458",
        "text": "Завоевания?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:07,041 --> 00:17:09,166",
        "text": "Жадности военных?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:10,958 --> 00:17:12,915",
        "text": "Чтобы завершить твою работу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:12,916 --> 00:17:15,458",
        "text": "Чтобы спасти нас от самих себя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:17,041 --> 00:17:19,375",
        "text": "Ты должен выжить, Виктор."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:21,250 --> 00:17:24,249",
        "text": "Вы верите в судьбу, доктор?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:24,250 --> 00:17:27,332",
        "text": "Наши пути уже известны."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:27,333 --> 00:17:30,916",
        "text": "Ведомые невидимой рукой."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:31,458 --> 00:17:34,707",
        "text": "Не судьба, а эволюция."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:34,708 --> 00:17:38,833",
        "text": "Величайшая сила природы, постоянно пребывающая в движении."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:39,416 --> 00:17:40,250",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:40,916 --> 00:17:43,624",
        "text": "Эволюция имеет свое предназначение."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:43,625 --> 00:17:45,916",
        "text": "Не бороться с природой, а подчинить ее."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:49,083 --> 00:17:52,416",
        "text": "Последняя, славная эволюция."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:55,250 --> 00:17:57,250",
        "text": "Но он не подопытный."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:58,000 --> 00:17:59,208",
        "text": "Он человек."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:17:59,916 --> 00:18:01,833",
        "text": "И ему нужна моя помощь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:18:03,500 --> 00:18:07,875",
        "text": "Я не стану жертвовать его человечностью ради вашего дела."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:18:09,125 --> 00:18:10,458",
        "text": "Вы можете идти."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:18:11,875 --> 00:18:12,708",
        "text": "Хорошо."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:18:13,416 --> 00:18:16,082",
        "text": "Но я полагаю, ты уже понял, что если ты погибнешь, это сообщество быстро последует за тобой."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:21,166 --> 00:19:22,541",
        "text": "На работе, как я вижу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:25,125 --> 00:19:26,500",
        "text": "Ты не можешь быть здесь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:27,250 --> 00:19:31,790",
        "text": "Здесь – это там, где я упала, когда на меня напал невменяемый мангуст?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:31,791 --> 00:19:33,333",
        "text": "Мангуст?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:35,083 --> 00:19:36,083",
        "text": "Твои волосы."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:36,833 --> 00:19:40,125",
        "text": "Ты похожа на злобное нефтяное пятно."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:41,083 --> 00:19:43,083",
        "text": "Не приукрашивай, кексик."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:46,791 --> 00:19:50,125",
        "text": "Ведется наблюдение за маршрутами, ведущими в каньон и из него."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:52,375 --> 00:19:55,333",
        "text": "Никто не может войти или выйти без допроса."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:19:55,875 --> 00:19:56,875",
        "text": "Кто это?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:01,333 --> 00:20:04,165",
        "text": "Мы отследили здесь какое-то новое химическое оружие."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:04,166 --> 00:20:06,333",
        "text": "Кровожадный зверь-убийца."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:07,583 --> 00:20:09,375",
        "text": "Что ты здесь делаешь?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:10,750 --> 00:20:13,666",
        "text": "Пытаюсь спасти отца."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:19,583 --> 00:20:22,874",
        "text": "Виктор верит, что сможет спасти человека, живущего внутри зверя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:22,875 --> 00:20:27,540",
        "text": "Если ему это удастся, боюсь, польза от этого существа для нас исчезнет."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:27,541 --> 00:20:29,875",
        "text": "Тогда нам придется заставить его."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:30,458 --> 00:20:35,916",
        "text": "Думаю, я могу создать сыворотку, которая помешает успеху Виктора."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:37,125 --> 00:20:38,500",
        "text": "Убедитесь, что он закреплен."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:40,666 --> 00:20:41,958",
        "text": "Да?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:20:48,333 --> 00:20:49,541",
        "text": "Это Вай."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:21:13,458 --> 00:21:15,666",
        "text": "Вот и счастливое воссоединение."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:21:16,708 --> 00:21:18,166",
        "text": "Отличная работа, Кейтлин."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:21:46,875 --> 00:21:47,750",
        "text": "Пора."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:03,916 --> 00:22:05,541",
        "text": "У нас уже есть разведчики, сэр."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:06,083 --> 00:22:07,333",
        "text": "Всего шесть."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:24,750 --> 00:22:27,000",
        "text": "Ускользает, как угорь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:36,375 --> 00:22:37,916",
        "text": "Так и знала, что получится."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:43,541 --> 00:22:45,916",
        "text": "У меня было время подумать."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:47,416 --> 00:22:53,041",
        "text": "С тех пор как ты появилась в моей жизни, я как будто надела очки."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:22:53,791 --> 00:22:58,333",
        "text": "Вот только я не могу понять, размыто всё или четко."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:02,875 --> 00:23:04,624",
        "text": "Хочешь услышать тупую шутку?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:04,625 --> 00:23:08,457",
        "text": "Сентиментальный злоумышленник, огромный пушистик, и двое самых разыскиваемых в Пилтовере попадают в странную секту."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:15,541 --> 00:23:18,416",
        "text": "А вот и кульминация."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:21,625 --> 00:23:22,666",
        "text": "Вай."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:23,333 --> 00:23:25,999",
        "text": "Ты была весьма любопытна."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:26,000 --> 00:23:28,665",
        "text": "Пленила сердце Кейтлин."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:28,666 --> 00:23:30,666",
        "text": "Я должна тебя поблагодарить."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:31,250 --> 00:23:34,833",
        "text": "Твое отсутствие создало пустоту, которую я смогла заполнить."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:36,541 --> 00:23:41,165",
        "text": "При других обстоятельствах я бы предложила тебе должность."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:41,166 --> 00:23:42,916",
        "text": "Твоя выдержка неоспорима."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:46,416 --> 00:23:48,250",
        "text": "Конечно, это невозможно."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:48,791 --> 00:23:51,708",
        "text": "Ты создаешь слишком много проблем."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:52,291 --> 00:23:55,166",
        "text": "Кейтлин не должна отвлекаться."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:23:56,166 --> 00:23:58,791",
        "text": "Не волнуйтесь, она не отвлекается."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:00,250 --> 00:24:02,458",
        "text": "Знаете, мой отец учил меня доверять."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:03,250 --> 00:24:07,166",
        "text": "Он сказал, что если я чего-то хочу, то мне нужно сделать три вещи."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:07,916 --> 00:24:11,165",
        "text": "Быть честной, даже если это означает сказать самодовольной зазнайке, что у нее изо рта пахнет выгребной ямой."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:13,833 --> 00:24:14,958",
        "text": "Быть терпеливой."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:15,708 --> 00:24:19,250",
        "text": "До сих пор не умею. Но это легче делать, если ты связан."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:19,916 --> 00:24:21,250",
        "text": "А третья?"
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:22,083 --> 00:24:25,541",
        "text": "Просто заткнуться."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:40,958 --> 00:24:42,707",
        "text": "Расщелины блокируют защитные башни."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:42,708 --> 00:24:45,415",
        "text": "Патрули обходят территорию с равными интервалами."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:45,416 --> 00:24:49,707",
        "text": "Ее личная охрана размещена здесь, здесь и здесь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:49,708 --> 00:24:51,874",
        "text": "Они не ожидают проблем дома."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:51,875 --> 00:24:54,290",
        "text": "Идеальное время, удача и..."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:24:54,291 --> 00:24:56,291",
        "text": "Серьезный отвлекающий маневр."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:05,708 --> 00:25:07,457",
        "text": "Что бы ты ни делала, не стоит недооценивать Амбессу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:20,458 --> 00:25:21,874",
        "text": "Вандер в беде."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:21,875 --> 00:25:23,125",
        "text": "У меня есть план."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:23,666 --> 00:25:25,250",
        "text": "Тебе он не понравится."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:40,750 --> 00:25:42,416",
        "text": "Надеюсь, я стоила вашего времени."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:25:57,208 --> 00:25:58,333",
        "text": "Я не подведу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:27:39,291 --> 00:27:40,291",
        "text": "Вай прислала меня."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:27:41,333 --> 00:27:43,291",
        "text": "Я собираюсь вытащить тебя отсюда."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:27:51,458 --> 00:27:53,541",
        "text": "Амбесса верила в тебя."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:27:55,833 --> 00:27:58,875",
        "text": "Твоя смерть будет болезненной."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:28:56,333 --> 00:29:00,833",
        "text": "Не трогай мою дочь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:29:24,250 --> 00:29:25,250",
        "text": "Ты."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:30:04,916 --> 00:30:05,750",
        "text": "Я не подведу."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:30:07,166 --> 00:30:08,541",
        "text": "Я клянусь."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:32:09,000 --> 00:32:10,041",
        "text": "Вандер."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:02,958 --> 00:33:04,500",
        "text": "Теперь я понимаю."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:05,458 --> 00:33:08,000",
        "text": "Послание, скрытое в узоре."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:08,791 --> 00:33:12,166",
        "text": "Причина наших неудач в общине."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:12,916 --> 00:33:14,208",
        "text": "Доктор был прав."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:15,541 --> 00:33:16,875",
        "text": "Это неизбежно."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:18,416 --> 00:33:19,541",
        "text": "Гуманность."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:21,333 --> 00:33:23,375",
        "text": "Наша сущность."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:24,708 --> 00:33:26,041",
        "text": "Наши эмоции..."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:27,625 --> 00:33:28,625",
        "text": "Ярость."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:29,791 --> 00:33:31,208",
        "text": "Сострадание."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:32,250 --> 00:33:33,083",
        "text": "Ненависть."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:34,958 --> 00:33:37,625",
        "text": "Две стороны одной медали."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:38,166 --> 00:33:40,916",
        "text": "Неразрывно связанные."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:33:51,875 --> 00:33:53,208",
        "text": "Вандер, подожди."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:35:32,500 --> 00:35:34,500",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:35:44,458 --> 00:35:45,500",
        "text": "Иша."
    },
    {
        "season": 2,
        "episode": 6,
        "time_code": "00:36:04,375 --> 00:36:08,166",
        "text": "То, что вдохновляет нас на величайшее добро, также является причиной нашего величайшего зла."
    }
]