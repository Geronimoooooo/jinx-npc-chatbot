[
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:16,916 --> 00:00:20,416",
        "text": "Всё летит к чертям."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:22,208 --> 00:00:25,541",
        "text": "Химбароны, воюющие за контроль над Линиями."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:26,291 --> 00:00:30,083",
        "text": "Уличные бандиты, сцепившиеся за объедки."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:31,791 --> 00:00:34,291",
        "text": "Как и тогда, когда ушел Вандер."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:36,666 --> 00:00:38,291",
        "text": "Только на этот раз... ...тебя нет здесь, чтобы собрать всё воедино, потому что..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:46,666 --> 00:00:49,166",
        "text": "Потому что кто-то проделал в тебе все эти дыры."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:00:58,416 --> 00:01:00,291",
        "text": "Вай говорила, что я могу починить всё."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:02,791 --> 00:01:04,833",
        "text": "До того, как я всё сломала."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:06,958 --> 00:01:08,666",
        "text": "Она много чего говорила."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:10,083 --> 00:01:11,416",
        "text": "Она и ты."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:11,958 --> 00:01:15,000",
        "text": "Вы всегда управляли мной."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:17,208 --> 00:01:19,000",
        "text": "Теперь так тихо."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:21,708 --> 00:01:23,791",
        "text": "Что мне теперь делать?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:01:58,500 --> 00:01:59,750",
        "text": "Достаточно?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:03:12,833 --> 00:03:15,750",
        "text": "АРКЕЙН Чувствуешь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:05:57,791 --> 00:05:58,833",
        "text": "Это... ...жужжание в голове?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:06,291 --> 00:06:08,290",
        "text": "Потому что знаешь, что через мгновение всё это может..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:13,583 --> 00:06:15,416",
        "text": "Лучшее чувство в мире, мелочь."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:17,333 --> 00:06:19,125",
        "text": "ДЖИНКС ПИЛТОВЕР РОЗЫСК Да, это я."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:24,583 --> 00:06:26,957",
        "text": "Если тебе нужно будет проклясть брата, сестру, семью или общество... {\\an8}...вот моя визитка."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:46,875 --> 00:06:48,999",
        "text": "Ну, знаешь, как бы то ни было, но ты нанял меня произвести расчет."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:51,958 --> 00:06:55,540",
        "text": "И с тех пор, как мы стали бороться с другими химбаронами, цифры в..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:57,708 --> 00:06:58,790",
        "text": "В заднице?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:06:58,791 --> 00:07:00,374",
        "text": "Не совсем тот термин, что я..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:00,375 --> 00:07:04,540",
        "text": "Не задумывался, почему такие умники, как ты, работают на громил, как я?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:04,541 --> 00:07:05,791",
        "text": "Нет, никогда."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:06,375 --> 00:07:08,415",
        "text": "Вы используете только половину головы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:08,416 --> 00:07:09,790",
        "text": "Продумываете ходы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:09,791 --> 00:07:11,540",
        "text": "Вычисляете шансы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:11,541 --> 00:07:13,874",
        "text": "Знаешь, как Силко взял Линии?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:13,875 --> 00:07:16,207",
        "text": "Голыми руками."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:16,208 --> 00:07:19,457",
        "text": "Просто это кажется опрометчивым."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:19,458 --> 00:07:22,999",
        "text": "Согласно подсчетам, у Марго не менее десяти убийц, охраняющих тайник."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:23,000 --> 00:07:26,415",
        "text": "Марго и Кросс могут брыкаться сколько угодно, но в конце концов это я буду улыбаться."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:28,333 --> 00:07:30,082",
        "text": "Пока я не сяду в кресло Силко, твоя единственная задача – заставить цифры работать."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:48,458 --> 00:07:49,624",
        "text": "Серое небо."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:49,625 --> 00:07:50,915",
        "text": "Прямо здесь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:50,916 --> 00:07:53,582",
        "text": "Кто бы мог подумать? Расчистить место."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:53,583 --> 00:07:55,915",
        "text": "Это могло бы значительно облегчить нашу работу."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:55,916 --> 00:07:57,457",
        "text": "Нет. Мы не можем."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:07:57,458 --> 00:08:00,499",
        "text": "Это заводской смог, запертый под землей."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:00,500 --> 00:08:01,915",
        "text": "Ни больше, ни меньше."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:01,916 --> 00:08:02,833",
        "text": "Босс."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:09,166 --> 00:08:10,790",
        "text": "Иди вперед."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:10,791 --> 00:08:12,041",
        "text": "Отчитаешься."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:13,416 --> 00:08:14,250",
        "text": "Я?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:08:58,458 --> 00:09:01,790",
        "text": "Я знаю, что вы все мечтаете отрезать друг другу головы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:01,791 --> 00:09:03,708",
        "text": "Так что я сразу перейду к делу."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:04,250 --> 00:09:06,040",
        "text": "Внутренние войны должны прекратиться."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:06,041 --> 00:09:09,790",
        "text": "Эти двое – агрессоры. Я лишь защищал свои интересы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:09,791 --> 00:09:12,374",
        "text": "Притворство тебе не идет, милый."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:12,375 --> 00:09:14,915",
        "text": "Ты начал эту игру, совершив набег на Тропу Восторга."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:14,916 --> 00:09:17,499",
        "text": "Что мне могло понадобиться от вашего скверного бульвара?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:17,500 --> 00:09:19,665",
        "text": "Верхний город – настоящий враг."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:19,666 --> 00:09:22,999",
        "text": "То, что мы убиваем друг друга, играет им на руку."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:23,000 --> 00:09:26,290",
        "text": "Наш лучший шанс – отбросить эти мелкие дрязги и объединить усилия."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:28,083 --> 00:09:31,665",
        "text": "Союзничать с этими двумя? Я скорее испытаю удачу с верхними."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:31,666 --> 00:09:34,832",
        "text": "Даже если объединимся, их в четыре раза больше, чем нас."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:34,833 --> 00:09:37,582",
        "text": "И так было еще до всех недавних жертв."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:37,583 --> 00:09:39,040",
        "text": "Это важно Наверху, но они ничего не знают о сражениях в расщелинах."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:44,208 --> 00:09:45,208",
        "text": "Он умер?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:45,750 --> 00:09:47,041",
        "text": "Почему он такой тихий?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:49,375 --> 00:09:50,291",
        "text": "Она права."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:51,333 --> 00:09:54,332",
        "text": "Если не избавимся от верхних, то не протянем долго."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:54,333 --> 00:09:56,665",
        "text": "Но у меня есть другое решение."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:56,666 --> 00:09:58,457",
        "text": "Мы отдадим им Джинкс."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:09:58,458 --> 00:10:00,082",
        "text": "Это то, чего они хотят."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:00,083 --> 00:10:01,166",
        "text": "ДЖИНКС ПИЛТОВЕР РОЗЫСК Мы не выдаем своих людей."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:04,708 --> 00:10:08,499",
        "text": "«Мы»? Ты ведь больше ничего не делаешь, болтунья?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:08,500 --> 00:10:11,458",
        "text": "Птица без крыльев похожа на крысу."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:14,916 --> 00:10:16,249",
        "text": "Задел за живое, да?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:16,250 --> 00:10:18,499",
        "text": "Хорошо, я предложу тебе сделку."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:18,500 --> 00:10:22,082",
        "text": "Ты поможешь мне покончить с Синевлаской для наших друзей наверху, и я дам тебе новенькое снаряжение, лучшее, со всеми наворотами."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:26,625 --> 00:10:27,874",
        "text": "Подумай об этом."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:10:27,875 --> 00:10:29,290",
        "text": "Но я обещаю, это последнее предложение, которое ты получишь."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:16,833 --> 00:11:20,583",
        "text": "Поверить не могу, что ты мертв, а я всё еще убираю за тобой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:22,958 --> 00:11:24,625",
        "text": "Боже, леди, вы с ума сошли?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:26,583 --> 00:11:28,458",
        "text": "Разговоры с мертвыми людьми."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:30,708 --> 00:11:32,583",
        "text": "Ты здесь, чтобы прикончить меня?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:33,250 --> 00:11:35,416",
        "text": "Разве я уже не оказала тебе достаточно услуг?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:45,166 --> 00:11:46,666",
        "text": "Каждый день в одно и то же время."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:11:48,958 --> 00:11:51,583",
        "text": "Большой малыш не мог сделать это сам."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:01,291 --> 00:12:02,916",
        "text": "Сам он мало что мог сделать."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:03,625 --> 00:12:07,665",
        "text": "Сейчас он бы заставил меня бегать за своими коллекциями по всем Линиям."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:07,666 --> 00:12:09,040",
        "text": "Создавал оружие."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:09,041 --> 00:12:10,332",
        "text": "Заключал сделки."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:10,333 --> 00:12:12,208",
        "text": "Взрывал бы своих врагов."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:17,750 --> 00:12:19,124",
        "text": "Он исчез, и весь мир перевернулся."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:30,833 --> 00:12:32,749",
        "text": "Все его планы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:32,750 --> 00:12:34,041",
        "text": "Всё, что мы построили."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:35,708 --> 00:12:37,916",
        "text": "Что нам теперь делать?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:44,791 --> 00:12:46,250",
        "text": "Смотреть, как всё горит."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:12:59,875 --> 00:13:01,125",
        "text": "Что я тебе говорил?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:11,791 --> 00:13:12,666",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:16,750 --> 00:13:17,708",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:19,416 --> 00:13:20,749",
        "text": "Виктор!"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:20,750 --> 00:13:22,124",
        "text": "Виктор..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:22,125 --> 00:13:23,332",
        "text": "Виктор!"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:23,333 --> 00:13:25,082",
        "text": "Виктор..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:13:25,083 --> 00:13:26,166",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:14,666 --> 00:14:15,666",
        "text": "Джейс?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:20,666 --> 00:14:21,500",
        "text": "Виктор?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:22,541 --> 00:14:23,583",
        "text": "Боже мой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:24,916 --> 00:14:25,750",
        "text": "Что... ...со мной?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:28,541 --> 00:14:29,666",
        "text": "Ты..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:30,208 --> 00:14:31,166",
        "text": "Ты жив."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:34,416 --> 00:14:35,333",
        "text": "Ты жив."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:47,333 --> 00:14:48,833",
        "text": "Тебе, наверное, холодно."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:51,000 --> 00:14:51,958",
        "text": "Холодно."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:52,625 --> 00:14:54,000",
        "text": "Нет, я так не думаю."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:54,666 --> 00:14:57,749",
        "text": "Я чувствую заряд."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:57,750 --> 00:14:59,000",
        "text": "Потенциал."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:14:59,583 --> 00:15:01,333",
        "text": "Рекурсивный импульс."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:02,208 --> 00:15:03,666",
        "text": "Неприятно, но... ...«холод» – это неправильное слово."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:12,083 --> 00:15:13,499",
        "text": "Хекстековое ядро."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:13,500 --> 00:15:15,082",
        "text": "Виктор, оно спасло тебя."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:15,083 --> 00:15:17,915",
        "text": "Каким-то образом оно адаптировалось к твоим травмам."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:17,916 --> 00:15:19,374",
        "text": "Изменилось и развивается."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:19,375 --> 00:15:22,666",
        "text": "Как будто оно было связано с тобой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:23,250 --> 00:15:26,415",
        "text": "Я сделал всё возможное, использовал заметки о ноге. Всё записал."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:26,416 --> 00:15:29,875",
        "text": "Всё еще очень много вопросов, но... Я должен был умереть."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:31,541 --> 00:15:33,874",
        "text": "Ты обещал уничтожить хекстековое ядро."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:33,875 --> 00:15:34,957",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:34,958 --> 00:15:36,499",
        "text": "Разве ты не видишь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:36,500 --> 00:15:38,041",
        "text": "Хеймердингер ошибался."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:38,625 --> 00:15:40,624",
        "text": "Мы ошибались. Всё не так плохо, как мы..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:40,625 --> 00:15:43,165",
        "text": "Это убило Скай, Джейс."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:43,166 --> 00:15:44,083",
        "text": "Что?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:45,000 --> 00:15:45,833",
        "text": "Нет."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:46,583 --> 00:15:48,416",
        "text": "У нее были такие мечты."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:15:57,541 --> 00:15:59,083",
        "text": "Как и у нас когда-то."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:03,166 --> 00:16:05,374",
        "text": "Я собираюсь выйти из состава Совета."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:05,375 --> 00:16:06,874",
        "text": "Теперь я понимаю."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:06,875 --> 00:16:10,624",
        "text": "Мое место всегда было здесь, в лаборатории, вместе с тобой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:10,625 --> 00:16:13,083",
        "text": "Мы всё исправим. Вместе."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:15,416 --> 00:16:17,791",
        "text": "Я должен попрощаться с этим местом."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:18,416 --> 00:16:19,250",
        "text": "И с тобой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:19,791 --> 00:16:20,625",
        "text": "Попрощаться?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:21,250 --> 00:16:22,832",
        "text": "Виктор, ты мой партнер."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:22,833 --> 00:16:25,666",
        "text": "Наши пути давно разошлись."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:26,208 --> 00:16:30,291",
        "text": "Только привязанность удерживала нас вместе."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:32,166 --> 00:16:33,874",
        "text": "Думаешь, это так просто?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:33,875 --> 00:16:37,500",
        "text": "Отвернуться, когда город ждет от тебя спасения?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:38,291 --> 00:16:41,625",
        "text": "Цепляться за принципы, пока твой друг истекает кровью на твоих руках?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:42,500 --> 00:16:44,083",
        "text": "Я никогда не просил об этом."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:47,541 --> 00:16:48,750",
        "text": "Куда ты идешь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:16:51,500 --> 00:16:53,041",
        "text": "Прощай, Джейс."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:11,458 --> 00:17:13,000",
        "text": "Их так много."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:13,750 --> 00:17:17,291",
        "text": "Это всё из-за боев. Скоро у нас будут проблемы с вместимостью."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:18,000 --> 00:17:19,832",
        "text": "Кроме того, есть риск безопасности."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:19,833 --> 00:17:22,208",
        "text": "Мы не откажем людям."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:23,500 --> 00:17:26,916",
        "text": "Через столько лет мы наконец-то избавились от Силко."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:27,708 --> 00:17:29,916",
        "text": "Только для того, чтобы на его место пришел новый."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:32,750 --> 00:17:33,666",
        "text": "Смотрите."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:53,541 --> 00:17:56,041",
        "text": "Это очень тревожно."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:56,625 --> 00:17:58,791",
        "text": "Это дерево так много значит."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:17:59,416 --> 00:18:03,458",
        "text": "Это наша еда. Свежий воздух. Мы построили всю жизнь вокруг него."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:04,458 --> 00:18:07,374",
        "text": "Каждый раз, когда кажется, что мы можем передохнуть..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:07,375 --> 00:18:10,290",
        "text": "Еще не всё потеряно, дружище."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:10,291 --> 00:18:14,625",
        "text": "Если есть способ сохраниться, мы его найдем."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:15,208 --> 00:18:18,666",
        "text": "Я уже видел нечто подобное."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:48,625 --> 00:18:51,166",
        "text": "Разве вы не владеете этим местом?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:18:53,291 --> 00:18:54,125",
        "text": "Пошли."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:02,583 --> 00:19:05,125",
        "text": "Огнедрев покинул джунгли."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:06,625 --> 00:19:10,375",
        "text": "Вы же понимаете, что код не работает, если придумывать его на ходу?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:42,000 --> 00:19:42,832",
        "text": "Профессор?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:42,833 --> 00:19:44,790",
        "text": "Да, конечно."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:44,791 --> 00:19:47,666",
        "text": "Что за дьявол на тебя напал? Я думал..."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:48,375 --> 00:19:50,458",
        "text": "Почему вы врываетесь в мою лабораторию?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:51,041 --> 00:19:52,125",
        "text": "А это кто?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:54,416 --> 00:19:57,124",
        "text": "Это мой новый ученик, Экко."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:19:57,125 --> 00:20:00,291",
        "text": "Экко, а это Джейс, мой бывший ученик."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:05,291 --> 00:20:07,374",
        "text": "Прошу прощения за вторжение."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:07,375 --> 00:20:09,916",
        "text": "Мы пытались пробраться внутрь."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:11,041 --> 00:20:13,790",
        "text": "Ой, как будто ты никогда этого не делал."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:13,791 --> 00:20:16,541",
        "text": "Ты здесь спал?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:19,166 --> 00:20:21,166",
        "text": "Ты пьешь чай, Экко?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:32,416 --> 00:20:33,250",
        "text": "Вы правы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:34,083 --> 00:20:35,540",
        "text": "Такие же повреждения мы видели на растениях, на которых тестировали хекстековое ядро. Где вы это нашли?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:40,041 --> 00:20:41,540",
        "text": "Глубоко в подземелье."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:41,541 --> 00:20:43,790",
        "text": "Дом Экко – чудесное место."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:43,791 --> 00:20:44,915",
        "text": "Поистине чудо."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:44,916 --> 00:20:47,165",
        "text": "Ты должен увидеть, что... Эй."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:47,166 --> 00:20:49,040",
        "text": "Верно, когда я сказал «дом», то, конечно, имел в виду его когнитивный центр."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:52,416 --> 00:20:57,874",
        "text": "Не физическое место, спрятанное в... Хеймер, что ты делаешь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:20:57,875 --> 00:20:59,708",
        "text": "Выжило ли хоть одно из растений?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:00,250 --> 00:21:02,666",
        "text": "Мы пытались спасти не их, а этот узор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:05,416 --> 00:21:07,791",
        "text": "Как он может быть и там, и здесь?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:11,666 --> 00:21:12,500",
        "text": "О, нет."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:16,458 --> 00:21:17,458",
        "text": "Где Виктор?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:38,000 --> 00:21:39,166",
        "text": "Всё хорошо."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:21:57,333 --> 00:21:58,250",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:22:03,416 --> 00:22:04,416",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:26:08,041 --> 00:26:09,291",
        "text": "Всё чисто."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:26:11,625 --> 00:26:12,916",
        "text": "Простите, командир."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:30,833 --> 00:27:32,500",
        "text": "Синевласка."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:33,791 --> 00:27:35,374",
        "text": "Прямо сквозь пальцы."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:35,375 --> 00:27:37,332",
        "text": "Ты, должно быть, отчасти угорь."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:37,333 --> 00:27:40,165",
        "text": "Это значит, что я могу увеличить гонорар за поимку."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:40,166 --> 00:27:42,500",
        "text": "Всегда можно договориться."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:45,333 --> 00:27:46,790",
        "text": "Ты нужна им живой."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:46,791 --> 00:27:49,665",
        "text": "Но не думай, что я не выдеру эти глазки."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:49,666 --> 00:27:52,291",
        "text": "Недостаток – дальнобойность."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:52,916 --> 00:27:55,833",
        "text": "А я из тех, кто любит подходить близко."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:57,208 --> 00:27:59,540",
        "text": "Никогда бы не подумал, что застану тебя в слезах."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:27:59,541 --> 00:28:02,290",
        "text": "Интересно, видел ли это Силко?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:02,291 --> 00:28:03,208",
        "text": "Дважды."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:03,916 --> 00:28:05,375",
        "text": "Когда он встретил меня, и когда я убила его."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:07,875 --> 00:28:09,040",
        "text": "Ты?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:09,041 --> 00:28:11,249",
        "text": "Это всегда я."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:11,250 --> 00:28:13,457",
        "text": "Независимо от того, выдергиваю я чеку или нет."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:13,458 --> 00:28:16,125",
        "text": "Все, кто приближаются ко мне, умирают."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:16,708 --> 00:28:18,333",
        "text": "Хочешь знать, в чём тут дело?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:28:20,541 --> 00:28:25,291",
        "text": "Ты из тех, кто любит подходить близко."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:30:47,541 --> 00:30:50,999",
        "text": "Так, подожди, подожди. Мы можем заключить сделку."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:30:51,000 --> 00:30:54,291",
        "text": "Ты забыл, Смич? Ты уже сделал последнее предложение."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:15,250 --> 00:31:16,083",
        "text": "Скажи мне."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:16,625 --> 00:31:18,666",
        "text": "Кто теперь похож на смешную крысу?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:42,833 --> 00:31:44,415",
        "text": "Рада встретить тебя здесь."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:44,416 --> 00:31:47,250",
        "text": "Болван никогда не умел держать свой проклятый рот на замке."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:52,833 --> 00:31:55,040",
        "text": "Ты могла бы просто дать мне его съесть."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:55,041 --> 00:31:57,166",
        "text": "Разве я уже не оказала тебе достаточно услуг?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:31:58,625 --> 00:32:00,458",
        "text": "Я не просила тебя об этом."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:01,041 --> 00:32:02,750",
        "text": "Я могла это исправить."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:03,500 --> 00:32:05,666",
        "text": "Опять у тебя этот взгляд."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:06,208 --> 00:32:07,791",
        "text": "Что ты задумала?"
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:08,875 --> 00:32:11,416",
        "text": "Покончить с тем, что осталось от моей семьи."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:17,041 --> 00:32:18,166",
        "text": "Боже."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:35,708 --> 00:32:36,708",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:38,916 --> 00:32:39,750",
        "text": "Виктор."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:47,833 --> 00:32:50,707",
        "text": "Осторожно, не повреди механизм."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:32:50,708 --> 00:32:53,125",
        "text": "Иначе не сможем так хорошо продать."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:33:04,416 --> 00:33:06,249",
        "text": "Ничего личного, друг."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:33:06,250 --> 00:33:10,000",
        "text": "Просто у нас есть потребности, которые мы не можем игнорировать."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:33:15,541 --> 00:33:17,541",
        "text": "Столько бессмысленной боли."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:33:33,666 --> 00:33:34,750",
        "text": "Нет, не надо."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:34:53,083 --> 00:34:55,375",
        "text": "Вам больше не нужно страдать."
    },
    {
        "season": 2,
        "episode": 2,
        "time_code": "00:34:58,083 --> 00:34:58,916",
        "text": "Но..."
    }
]