[
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:00:43,250 --> 00:00:45,458",
        "text": "Никогда не думали, каково это — тонуть?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:00:49,041 --> 00:00:50,458",
        "text": "Единство противоположностей."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:00:52,583 --> 00:00:54,916",
        "text": "Вода дарит покой."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:00:55,958 --> 00:01:01,083",
        "text": "Она держит тебя, шепотом уговаривая впустить ее."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:03,250 --> 00:01:06,750",
        "text": "И тогда все проблемы в мире исчезнут."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:15,208 --> 00:01:18,291",
        "text": "Но у тебя в голове что-то бушует."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:22,833 --> 00:01:25,041",
        "text": "Поражая каждый нерв безумием."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:26,125 --> 00:01:26,958",
        "text": "Борись."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:29,125 --> 00:01:30,166",
        "text": "Живи."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:31,708 --> 00:01:34,458",
        "text": "И в мыслях крутится один вопрос: «А может, хватит?» Забавно."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:42,416 --> 00:01:45,416",
        "text": "Можно ни разу в жизни не столкнуться с таким выбором."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:46,583 --> 00:01:48,500",
        "text": "Но он меняет тебя навсегда."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:01:50,583 --> 00:01:53,500",
        "text": "И за это я благодарен тебе… …мой старый друг."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:06,666 --> 00:03:08,333",
        "text": "ЛАВКА БЕНЗО Вандер?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:27,625 --> 00:03:29,750",
        "text": "У нас мало времени. Как ты меня нашел?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:29,833 --> 00:03:32,750",
        "text": "Я тобой горжусь. Всегда гордился."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:32,833 --> 00:03:34,458",
        "text": "Прости, я… Только так можно защитить остальных."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:38,041 --> 00:03:39,500",
        "text": "Вандер!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:39,583 --> 00:03:42,416",
        "text": "У тебя доброе сердце. Не дай ему ожесточиться."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:42,500 --> 00:03:45,083",
        "text": "Как бы мир ни пытался тебя сломить."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:45,166 --> 00:03:46,750",
        "text": "Защищай семью."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:46,833 --> 00:03:48,375",
        "text": "Что ты… Нет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:54,875 --> 00:03:58,041",
        "text": "Вандер! Выпусти меня! Так нельзя!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:03:58,125 --> 00:03:59,958",
        "text": "Полагаю, я вовремя."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:08,583 --> 00:04:11,208",
        "text": "Дашь себя арестовать или как?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:11,291 --> 00:04:14,625",
        "text": "Вы ведь дадите обреченному сделать последнюю затяжку?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:20,416 --> 00:04:21,833",
        "text": "Правда?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:24,125 --> 00:04:26,000",
        "text": "Я не стану тебя сажать, Вандер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:26,083 --> 00:04:28,375",
        "text": "Совету нужен козел отпущения."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:28,458 --> 00:04:31,833",
        "text": "Без тебя здесь внизу всё развалится."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:33,666 --> 00:04:35,583",
        "text": "Бензо меня заменит."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:35,666 --> 00:04:41,125",
        "text": "Ему недостает моего убийственного шарма, зато хватка железная."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:41,208 --> 00:04:44,083",
        "text": "Нет! Вандер, нет! Не делай этого!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:44,166 --> 00:04:47,458",
        "text": "Тебя не скоро выпустят. Я знаю."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:47,541 --> 00:04:50,291",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:50,375 --> 00:04:51,416",
        "text": "Почему ты это делаешь?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:52,833 --> 00:04:54,125",
        "text": "Другого пути нет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:04:56,916 --> 00:04:59,375",
        "text": "Бензо, открой эту сраную дверь!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:04,833 --> 00:05:06,125",
        "text": "Что происходит?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:12,208 --> 00:05:13,875",
        "text": "Эй, стоять!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:28,125 --> 00:05:29,291",
        "text": "Что это за чудовище?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:31,375 --> 00:05:32,208",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:48,000 --> 00:05:51,083",
        "text": "Силко? Ах ты тварь."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:51,166 --> 00:05:55,000",
        "text": "Ползи обратно в ту дыру, из которой вылез!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:55,083 --> 00:05:56,250",
        "text": "Бензо, назад!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:56,333 --> 00:05:59,666",
        "text": "Ты никогда не умел вовремя отступить."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:05:59,750 --> 00:06:00,666",
        "text": "Стой!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:01,750 --> 00:06:04,291",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:07,291 --> 00:06:09,416",
        "text": "Редкостный упрямец."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:13,416 --> 00:06:15,041",
        "text": "Что ты натворил?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:15,916 --> 00:06:17,708",
        "text": "Уговор был не такой!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:19,291 --> 00:06:20,916",
        "text": "Я передумал."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:24,375 --> 00:06:25,375",
        "text": "Нет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:06:34,916 --> 00:06:35,833",
        "text": "Нет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:26,041 --> 00:07:29,416",
        "text": "Всё это время я думал, что нужно ослабить вибрацию."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:29,500 --> 00:07:32,125",
        "text": "Кристаллы стабилизируются только при высокой частоте."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:32,208 --> 00:07:33,833",
        "text": "Их нужно… Раскрутить!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:35,166 --> 00:07:38,000",
        "text": "Да. Их нужно раскрутить!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:38,541 --> 00:07:40,833",
        "text": "Должно сработать. В теории."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:40,916 --> 00:07:43,208",
        "text": "Это можно было бы проверить на моём оборудовании."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:43,291 --> 00:07:46,083",
        "text": "Которое завтра уничтожат. Что?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:46,166 --> 00:07:49,791",
        "text": "Ах, я… Да, я собирался тебе сказать."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:50,416 --> 00:07:53,666",
        "text": "В этой работе вся моя жизнь."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:54,458 --> 00:07:56,333",
        "text": "Может, покажем им расчеты, и нам разрешат… Нам нужны не пустые выкладки, а что-то весомое."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:07:58,958 --> 00:08:02,208",
        "text": "Без кристаллов нам их не добыть. Миротворцы их все забрали."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:03,333 --> 00:08:05,916",
        "text": "Ну да. И заперли в лаборатории Хеймердингера."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:08,000 --> 00:08:10,666",
        "text": "Нет. Ты слышал, что сказал совет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:10,750 --> 00:08:12,750",
        "text": "Одна ошибка — и… Так не ошибись."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:13,750 --> 00:08:15,958",
        "text": "Зачем? Зачем так рисковать?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:16,666 --> 00:08:19,500",
        "text": "Думаешь, я всю жизнь мечтал быть чьим-то помощником?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:19,583 --> 00:08:24,583",
        "text": "Ученый жаждет открытий. Мечтает сделать мир лучше."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:24,666 --> 00:08:28,958",
        "text": "А твой хекстек вполне может это осуществить."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:31,791 --> 00:08:33,375",
        "text": "Наш хекстек."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:08:59,375 --> 00:09:00,875",
        "text": "Я всё видел."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:02,250 --> 00:09:04,500",
        "text": "Бензо. Они… А Вандер? Они его забрали."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:13,666 --> 00:09:14,875",
        "text": "Куда?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:43,208 --> 00:09:45,583",
        "text": "Грубовато, признаю."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:45,666 --> 00:09:48,583",
        "text": "Но без насилия не будет перемен."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:48,666 --> 00:09:53,041",
        "text": "Мы оба знаем, что наверху понимают только такой язык."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:09:59,083 --> 00:10:03,375",
        "text": "Даже с твоими монстрами тебе не победить Пилтовер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:03,458 --> 00:10:07,833",
        "text": "Мне этого и не нужно. Мне надо всего лишь напугать их."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:07,916 --> 00:10:11,000",
        "text": "Тогда они не посмеют снова сунуться в нижний город."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:11,583 --> 00:10:15,625",
        "text": "Из-за тебя погибнут люди. И ради чего? Ради гордости?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:15,708 --> 00:10:17,791",
        "text": "Ради уважения!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:18,666 --> 00:10:22,125",
        "text": "Возможностей. Ради всего, чего они нас лишили."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:22,708 --> 00:10:25,250",
        "text": "Я уважал тебя."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:25,333 --> 00:10:28,125",
        "text": "Все Линии уважали тебя. Но тебе этого было мало."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:28,208 --> 00:10:30,000",
        "text": "У нас была общая мечта, Вандер!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:30,625 --> 00:10:32,666",
        "text": "Мы мечтали о свободе."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:33,458 --> 00:10:35,000",
        "text": "Не только для Линий, а для всего нижнего города, единого."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:40,375 --> 00:10:42,125",
        "text": "Всех жителей Зауна."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:44,083 --> 00:10:45,750",
        "text": "Ты хоть помнишь?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:47,541 --> 00:10:48,791",
        "text": "Я доверял тебе."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:52,083 --> 00:10:53,583",
        "text": "А ты предал меня."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:10:58,166 --> 00:10:59,500",
        "text": "За тот поступок… …я никогда себя не прощу. Ты был мне братом."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:08,208 --> 00:11:10,458",
        "text": "Нет, ты так и не понял."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:11,583 --> 00:11:13,875",
        "text": "Ты хоть представляешь, каково это?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:15,125 --> 00:11:17,083",
        "text": "Когда твоя кровь смешивается с грязью, а речные токсины разъедают твои нервы."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:22,208 --> 00:11:25,041",
        "text": "О, как же я тебя ненавидел!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:26,541 --> 00:11:29,833",
        "text": "Но шло время, а с ним уходила и ненависть."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:32,500 --> 00:11:34,500",
        "text": "И осталось только понимание."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:35,583 --> 00:11:40,000",
        "text": "Единственный способ победить сильного врага — идти до конца."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:40,083 --> 00:11:42,291",
        "text": "Стать тем, кого он боится."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:45,000 --> 00:11:48,208",
        "text": "Я ненавидел тебя, но всё равно уважал."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:49,375 --> 00:11:51,458",
        "text": "Пока ты не заключил с ними мир."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:51,541 --> 00:11:54,291",
        "text": "Стал их верным псом после всего, что мы пережили."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:55,916 --> 00:11:58,041",
        "text": "У меня не было выбора."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:11:58,125 --> 00:11:59,166",
        "text": "Возможно."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:00,000 --> 00:12:02,083",
        "text": "Но теперь он у тебя есть."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:02,166 --> 00:12:05,458",
        "text": "Мерцание. Cила на нашей стороне."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:05,541 --> 00:12:08,458",
        "text": "Мы наконец можем воплотить нашу мечту."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:10,875 --> 00:12:11,958",
        "text": "Брат."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:12,625 --> 00:12:14,000",
        "text": "Посмотри, что ты натворил."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:14,916 --> 00:12:17,291",
        "text": "Бензо. Ребята."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:17,375 --> 00:12:22,916",
        "text": "В борьбе с верхним городом ты готов пожертвовать всем, что у нас есть."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:23,000 --> 00:12:26,083",
        "text": "Так нельзя. Разве ты не понимаешь?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:27,166 --> 00:12:33,333",
        "text": "Убей меня, если хочешь. Но прошу, пощади Линии."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:34,541 --> 00:12:38,208",
        "text": "Ты готов умереть за идею, но не готов сражаться за неё?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:40,833 --> 00:12:44,291",
        "text": "Просто я уже не тот человек."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:12:45,416 --> 00:12:47,250",
        "text": "Я покажу тебе, кто ты."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:06,708 --> 00:13:10,166",
        "text": "ПРОФ. ХЕЙМЕРДИНГЕР Пока всё идет хорошо."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:29,166 --> 00:13:32,875",
        "text": "Рискуете изгнанием ради своей идеи? Какая преданность делу!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:32,958 --> 00:13:33,833",
        "text": "Советница!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:33,916 --> 00:13:35,916",
        "text": "Ой, это не моя спальня. Какой сюрприз."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:36,000 --> 00:13:37,041",
        "text": "Как я мог перепутать… Прошу. Мы докажем, что это возможно."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:41,083 --> 00:13:44,458",
        "text": "Сегодня днем вы не могли этого сделать, что же изменилось?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:45,208 --> 00:13:47,125",
        "text": "Мы поняли, как их стабилизировать."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:48,208 --> 00:13:49,916",
        "text": "Ты помощник профессора."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:50,416 --> 00:13:52,583",
        "text": "Нет, он мой новый напарник."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:53,541 --> 00:13:57,083",
        "text": "Даже если вы докажете свою теорию, совет уничтожит вашу работу."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:57,166 --> 00:13:59,625",
        "text": "Хеймердингер увидит ее потенциал."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:13:59,708 --> 00:14:04,041",
        "text": "Он уже увидел. И он испугался. Все испугались."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:04,125 --> 00:14:05,333",
        "text": "А вы?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:06,250 --> 00:14:09,625",
        "text": "Я понимаю, что любая стоящая затея подразумевает риск."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:19,791 --> 00:14:22,833",
        "text": "Советница, эта технология реальна."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:22,916 --> 00:14:25,916",
        "text": "И она в любом случае изменит мир."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:26,000 --> 00:14:27,583",
        "text": "Так возглавим эти перемены."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:27,666 --> 00:14:31,916",
        "text": "Пилтовер — родина прогресса, равенства, инноваций."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:32,000 --> 00:14:35,708",
        "text": "Знаю, это кажется невозможным, но когда нас это останавливало?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:36,291 --> 00:14:38,875",
        "text": "Прошу, дайте нам шанс."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:43,958 --> 00:14:45,500",
        "text": "Даю вам одну ночь, господа."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:45,583 --> 00:14:48,750",
        "text": "Удивите меня, или советую собирать вещи."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:51,666 --> 00:14:53,291",
        "text": "Харольд!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:54,583 --> 00:14:58,125",
        "text": "Ах, советница Медарда. Вы меня до смерти напугали!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:14:58,833 --> 00:15:01,666",
        "text": "Снова пришлось задержаться. Столько работы."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:01,750 --> 00:15:04,208",
        "text": "Наверное, это значит, что дела идут хорошо, так?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:13,833 --> 00:15:16,375",
        "text": "Если миротворцы заявятся сегодня, мы будем готовы."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:16,958 --> 00:15:18,250",
        "text": "Наверное. Чур дубина моя."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:18,333 --> 00:15:19,375",
        "text": "Нет. Я ее нашел."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:19,458 --> 00:15:21,500",
        "text": "Но я первый застолбил. Но я нашел."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:21,583 --> 00:15:25,000",
        "text": "А я застолбил, это важнее! Тебе пять лет, что ли?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:27,041 --> 00:15:27,958",
        "text": "Вай?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:28,791 --> 00:15:30,375",
        "text": "Где… Ты вернулась!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:39,416 --> 00:15:42,791",
        "text": "Эй! Это Вандера. Притормози! Что происходит?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:43,958 --> 00:15:45,291",
        "text": "Бензо мертв."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:45,375 --> 00:15:46,375",
        "text": "Мертв?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:46,458 --> 00:15:47,541",
        "text": "Вандера забрали."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:47,625 --> 00:15:50,500",
        "text": "Кто забрал? Не знаю. Но его надо вытаскивать."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:50,583 --> 00:15:51,666",
        "text": "Мы пойдем с тобой."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:53,041 --> 00:15:54,875",
        "text": "Тот, кто убил Бензо… Я еще не видела такого монстра."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:15:58,541 --> 00:15:59,916",
        "text": "Он разорвал его на куски."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:02,416 --> 00:16:05,416",
        "text": "Ты не пойдешь одна, Вай. Он и наш отец тоже."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:07,208 --> 00:16:10,125",
        "text": "Знаешь, куда его забрали? Экко проследил за ними."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:11,291 --> 00:16:14,416",
        "text": "Они на старой консервной фабрике у пристани. Он сказал… Я не могу тебя взять, Паудер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:22,083 --> 00:16:23,000",
        "text": "Что?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:23,500 --> 00:16:25,541",
        "text": "Ты не пойдешь. Я не боюсь."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:25,625 --> 00:16:26,500",
        "text": "Это слишком опасно."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:26,583 --> 00:16:29,291",
        "text": "Но родные держатся вместе! Ты сама говорила!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:29,375 --> 00:16:31,833",
        "text": "Знаю, что говорила. Я хочу драться. Я могу помочь!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:31,916 --> 00:16:33,041",
        "text": "Ты не готова!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:37,291 --> 00:16:38,958",
        "text": "Кроме тебя у меня никого нет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:40,083 --> 00:16:41,375",
        "text": "Я не могу потерять тебя."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:44,291 --> 00:16:48,416",
        "text": "Вот. Если они придут, хватай это и беги."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:49,000 --> 00:16:51,958",
        "text": "Где бы ты ни была, зажги его, и я тебя найду."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:16:52,041 --> 00:16:53,000",
        "text": "Обещаю."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:13,666 --> 00:17:14,791",
        "text": "Всё готово."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:26,500 --> 00:17:29,083",
        "text": "А теперь мы его раскрутим."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:29,166 --> 00:17:30,916",
        "text": "Ты точно знаешь, что делаешь?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:46,250 --> 00:17:48,625",
        "text": "Не выдержит! Слишком большая мощность!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:48,708 --> 00:17:50,791",
        "text": "Резонанс его стабилизирует."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:51,500 --> 00:17:52,583",
        "text": "Я уверен."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:17:53,833 --> 00:17:55,666",
        "text": "Эй. Ты это видишь?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:18:50,916 --> 00:18:52,125",
        "text": "Я могу помочь им."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:03,125 --> 00:19:04,875",
        "text": "Забираем Вандера и уходим."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:12,958 --> 00:19:14,666",
        "text": "Я же говорил, что сработает."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:16,000 --> 00:19:18,250",
        "text": "Дальше дело за тобой."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:19,333 --> 00:19:21,000",
        "text": "Такого я еще не видел."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:21,583 --> 00:19:23,916",
        "text": "Ладно. Поехали."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:38,791 --> 00:19:39,875",
        "text": "Отключай его!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:19:59,250 --> 00:20:01,208",
        "text": "Потрясающе."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:25,166 --> 00:20:26,125",
        "text": "Вай."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:27,666 --> 00:20:30,625",
        "text": "Что вы здесь делаете? Мы за тобой."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:32,083 --> 00:20:32,916",
        "text": "Майло."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:33,750 --> 00:20:34,625",
        "text": "Я мигом."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:39,875 --> 00:20:41,583",
        "text": "Как вы сюда пробрались?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:42,208 --> 00:20:44,000",
        "text": "Тут же везде охрана."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:44,708 --> 00:20:47,500",
        "text": "Проще простого. Мы нашли открытое окно и… О нет."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:49,916 --> 00:20:51,791",
        "text": "Вам надо уходить. Сейчас же!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:20:51,875 --> 00:20:53,708",
        "text": "Добро пожаловать!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:03,916 --> 00:21:06,250",
        "text": "Поздравляю вас."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:07,250 --> 00:21:11,083",
        "text": "Но боюсь, это воссоединение будет коротким."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:15,458 --> 00:21:17,250",
        "text": "До вас доходили слухи?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:18,375 --> 00:21:21,166",
        "text": "Трус Вандер сбежал из города со своими ребятишками."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:22,583 --> 00:21:24,125",
        "text": "И больше их никто не видел."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:27,041 --> 00:21:29,041",
        "text": "Клаггор, поищи другой выход отсюда."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:29,125 --> 00:21:30,125",
        "text": "Понял."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:30,708 --> 00:21:33,625",
        "text": "Ты не должна этого делать. Должна."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:21:37,208 --> 00:21:38,125",
        "text": "Вай!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:22:45,416 --> 00:22:46,416",
        "text": "Майло."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:22:50,083 --> 00:22:53,166",
        "text": "Сделай глубокий вдох. У тебя получится."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:23:07,750 --> 00:23:09,166",
        "text": "Мы выберемся отсюда."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:23:37,541 --> 00:23:39,458",
        "text": "Готов выйти наружу?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:24:18,625 --> 00:24:20,208",
        "text": "Майло, скорее."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:24:29,958 --> 00:24:30,875",
        "text": "Вай!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:24:32,750 --> 00:24:36,583",
        "text": "Силко! Не троньте ее! Это касается только нас с тобой!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:24:36,666 --> 00:24:38,125",
        "text": "Ты упустил свой шанс!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:24:51,708 --> 00:24:53,125",
        "text": "Вай!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:14,833 --> 00:25:15,833",
        "text": "Молодец."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:20,375 --> 00:25:21,458",
        "text": "Открывайте!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:21,541 --> 00:25:23,250",
        "text": "Открывайте! Прекратите немедленно!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:23,333 --> 00:25:24,958",
        "text": "Сейчас прорвутся! Открывайте!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:25,041 --> 00:25:26,750",
        "text": "Я не тороплю. Ага, совсем нет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:25:34,666 --> 00:25:35,500",
        "text": "Открывайте!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:00,875 --> 00:26:02,125",
        "text": "Разрешите! Я тут, внизу."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:26,750 --> 00:26:29,083",
        "text": "У вас получилось."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:29,166 --> 00:26:32,750",
        "text": "Но то, что это возможно, еще не означает… Пожалуйста, прекратите летать."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:36,000 --> 00:26:38,083",
        "text": "Боюсь, я не знаю, как это сделать."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:40,000 --> 00:26:44,125",
        "text": "Будущее Пилтовера не может быть таким, юноши."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:45,375 --> 00:26:47,416",
        "text": "Это решать совету."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:49,833 --> 00:26:51,500",
        "text": "Наступает новая эра."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:52,416 --> 00:26:54,125",
        "text": "Эра магии."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:54,208 --> 00:26:55,166",
        "text": "Хекстека."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:26:55,750 --> 00:26:57,458",
        "text": "Эра хекстека."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:27:12,666 --> 00:27:15,833",
        "text": "Ты только не подведи. Ради меня. Ладно?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:30:13,375 --> 00:30:14,708",
        "text": "Убей их."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:32:35,916 --> 00:32:38,291",
        "text": "Я знал, что ты всё тот же."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:32:55,250 --> 00:32:56,500",
        "text": "Найти девчонку."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:34:00,416 --> 00:34:01,666",
        "text": "Силко!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:34:33,250 --> 00:34:34,291",
        "text": "Вандер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:34:35,916 --> 00:34:37,000",
        "text": "Вандер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:34:41,166 --> 00:34:42,708",
        "text": "Позаботься о Паудер."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:11,708 --> 00:35:13,166",
        "text": "Вай, сработало!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:13,875 --> 00:35:15,083",
        "text": "Что? Ты это видела?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:15,166 --> 00:35:17,416",
        "text": "Моя бомба-обезьянка сработала!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:19,208 --> 00:35:20,833",
        "text": "Так это ты?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:28,875 --> 00:35:29,875",
        "text": "Зачем?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:31,000 --> 00:35:32,000",
        "text": "Зачем ты это сделала?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:33,125 --> 00:35:34,250",
        "text": "Я не… Я хотела вас спасти."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:40,583 --> 00:35:42,416",
        "text": "Я только хотела помочь."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:43,208 --> 00:35:46,250",
        "text": "Я только хотела помочь!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:46,333 --> 00:35:48,250",
        "text": "Я же просила не лезть."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:48,916 --> 00:35:52,250",
        "text": "Прошу! Я просила не лезть!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:52,958 --> 00:35:55,625",
        "text": "Нет. Почему ты не взяла меня с собой?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:55,708 --> 00:35:59,666",
        "text": "Потому что ты приносишь неудачу! Ты джинкс! Слышишь? Майло был прав."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:35:59,750 --> 00:36:04,250",
        "text": "Нет! Вайолет, пожалуйста!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:36:15,791 --> 00:36:17,333",
        "text": "Вайолет, прошу!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:36:27,791 --> 00:36:30,541",
        "text": "Вай! Вай, вернись! Пожалуйста, вернись!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:36:30,625 --> 00:36:33,875",
        "text": "Прошу, Вайолет! Ты нужна мне! Прошу!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:36:47,875 --> 00:36:49,333",
        "text": "Вайолет!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:36:50,416 --> 00:36:52,916",
        "text": "Вайолет! Пожалуйста!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:37:20,083 --> 00:37:22,083",
        "text": "Паудер. Паудер!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:37:23,166 --> 00:37:24,583",
        "text": "Он убьет тебя, если услышит."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:37:25,625 --> 00:37:27,250",
        "text": "Давай. Идем."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:37:48,833 --> 00:37:50,666",
        "text": "Здравствуй, девочка."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:37:52,041 --> 00:37:53,708",
        "text": "Где твоя сестра?"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:38:08,041 --> 00:38:09,166",
        "text": "Она меня бросила."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:38:16,833 --> 00:38:20,791",
        "text": "Она мне больше не сестра!"
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:38:40,500 --> 00:38:41,541",
        "text": "Ничего."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:38:44,875 --> 00:38:45,916",
        "text": "Мы им покажем."
    },
    {
        "season": 1,
        "episode": 3,
        "time_code": "00:38:48,791 --> 00:38:50,166",
        "text": "Мы всем им покажем."
    }
]